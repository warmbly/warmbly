---
import Layout from './Layout.astro';
import Icon from '../components/Icon.astro';
import { learnArticles, glossaryHref, neighborsOf, levelTone } from '../lib/learn';

interface Props {
  /** SEO <title>, e.g. "Email Warmup - How It Works | Warmbly". */
  title: string;
  /** Editorial H1. Falls back to the title with the SEO suffix stripped. */
  headline?: string;
  description?: string;
  eyebrow?: string;
  reading?: string;
  updated?: string;
}
const {
  title,
  headline = title.split(/\s*[|]\s*/)[0],
  description,
  eyebrow = 'Learn',
  reading = '6 min read',
  updated,
} = Astro.props;

const path = Astro.url.pathname;
const current = learnArticles.find((a) => a.href === path);
const { prev, next } = neighborsOf(path);
const tone = current ? levelTone(current.level) : null;

const neighbors = [
  prev ? { label: 'Previously', article: prev } : null,
  next ? { label: 'Up next', article: next } : null,
].filter(Boolean) as { label: string; article: (typeof learnArticles)[number] }[];

// BlogPosting structured data for each guide. Helps the essays surface as
// articles rather than generic pages, and ties them back to the org.
const siteOrigin = (Astro.site ?? new URL('https://warmbly.com')).toString().replace(/\/$/, '');
const canonical = new URL(path, Astro.site ?? 'https://warmbly.com').toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline,
  description: description ?? headline,
  image: `${siteOrigin}/og-image.png`,
  ...(updated ? { dateModified: updated, datePublished: updated } : {}),
  author: { '@id': `${siteOrigin}#org` },
  publisher: { '@id': `${siteOrigin}#org` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  isAccessibleForFree: true,
};
---
<Layout title={title} description={description ?? headline} ogType="article" jsonLd={articleJsonLd}>
  <!-- TOP BAR: sticky under the site header, carries the reading progress -->
  <div class="sticky top-14 z-30 bg-white/90 backdrop-blur-md border-b border-[color:var(--border)]">
    <div class="container-page py-3 flex items-center justify-between text-[11.5px] font-mono">
      <a href="/learn/" class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors">
        <Icon name="arrowRight" size={11} class="rotate-180" />
        Library
      </a>
      <div class="flex items-center gap-4 text-muted-foreground">
        <span class="hidden md:inline">{eyebrow}</span>
        <span class="hidden md:inline w-1 h-1 rounded-full bg-[color:var(--border)]"></span>
        <span>{reading}</span>
        {updated && <span class="hidden sm:inline w-1 h-1 rounded-full bg-[color:var(--border)]"></span>}
        {updated && <span class="hidden sm:inline">Updated {updated}</span>}
      </div>
    </div>
    <div class="reading-progress" data-reading-progress></div>
  </div>

  <!-- DOC LAYOUT: sticky chapter rail + main column -->
  <div class="grid lg:grid-cols-[220px_minmax(0,1fr)] xl:grid-cols-[240px_minmax(0,1fr)]">

    <!-- LEFT RAIL -->
    <aside class="hidden lg:block border-r border-[color:var(--border)] bg-[color:var(--surface-2)]/40">
      <div class="sticky top-[6.25rem] max-h-[calc(100vh-6.25rem)] overflow-y-auto py-8 px-6 flex flex-col gap-7">
        <!-- On this page: filled by the chapter script, no placeholder flash -->
        <div data-chapter-block hidden>
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-4">On this page</div>
          <ol class="learn-chapter-rail space-y-px text-[13px]" data-chapter-rail></ol>
        </div>

        <!-- All articles in the library, with current one highlighted -->
        <div data-essays-block class="pt-6 border-t border-[color:var(--border)]">
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-4 flex items-center justify-between">
            <span>All essays</span>
            <span class="font-mono text-[10.5px] text-muted-foreground/70">{learnArticles.length}</span>
          </div>
          <ol class="space-y-px text-[13px]">
            {learnArticles.map((a, i) => {
              const isCurrent = a.href === path;
              return (
                <li>
                  <a
                    href={a.href}
                    aria-current={isCurrent ? 'page' : undefined}
                    class={`group flex items-baseline gap-3 py-1.5 px-2 -mx-2 rounded-md transition-colors duration-300 ease-out ${
                      isCurrent
                        ? 'text-[#0369a1] font-semibold'
                        : 'text-foreground/60 hover:text-[#0369a1]'
                    }`}
                  >
                    <span class={`font-mono text-[10.5px] w-5 shrink-0 transition-colors duration-300 ${isCurrent ? 'text-[#0284c7]' : 'text-muted-foreground/55'}`}>{String(i + 1).padStart(2, '0')}</span>
                    <span class="leading-snug flex-1 line-clamp-2">{a.title}</span>
                    {isCurrent ? (
                      <span class="w-1.5 h-1.5 rounded-full bg-[#0284c7] shrink-0"></span>
                    ) : (
                      <span class="font-mono text-[10px] text-muted-foreground/55 shrink-0">{a.read}m</span>
                    )}
                  </a>
                </li>
              );
            })}
          </ol>
          <div class="mt-4 flex items-center gap-4">
            <a href={glossaryHref} class={`inline-flex items-center gap-1.5 text-[11.5px] font-mono ${path === glossaryHref ? 'text-[#0369a1] font-semibold' : 'text-muted-foreground hover:text-[#0369a1]'}`}>
              Glossary
            </a>
            <a href="/learn/" class="inline-flex items-center gap-1.5 text-[11.5px] font-mono text-[#0369a1] hover:text-[#075985]">
              Library home
              <Icon name="arrowRight" size={10} />
            </a>
          </div>
        </div>
      </div>
    </aside>

    <!-- MAIN COLUMN -->
    <main class="bg-white learn-main">
      <!-- Page header -->
      <header class="border-b border-[color:var(--border)] px-6 md:px-10 lg:px-14 py-10 md:py-14">
        <div class="flex items-center gap-3 flex-wrap mb-3">
          <span class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-[#0284c7]">{eyebrow}</span>
          {current && tone && (
            <span class={`inline-flex items-center gap-1.5 h-5 px-2 rounded-full text-[10.5px] font-mono font-semibold uppercase tracking-[0.1em] ${tone.chip}`}>
              <span class={`w-1 h-1 rounded-full ${tone.dot}`}></span>
              {current.level}
            </span>
          )}
          {current && (
            <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground">{current.topic}</span>
          )}
        </div>
        <h1 class="text-[36px] md:text-[52px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading max-w-3xl">{headline}</h1>
        {description && (
          <p class="mt-4 text-[16px] md:text-[17px] text-foreground/70 max-w-2xl leading-relaxed">{description}</p>
        )}

        <!-- Mobile TOC: filled by the chapter script -->
        <details class="lg:hidden mt-6 rounded-[12px] bg-[color:var(--surface-2)]/60 ring-1 ring-[color:var(--border)] open:bg-white" data-mobile-toc hidden>
          <summary class="cursor-pointer select-none list-none px-4 py-3 flex items-center justify-between text-[11px] uppercase tracking-[0.18em] font-mono text-muted-foreground">
            On this page
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="toc-caret transition-transform" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <ol class="px-4 pb-4 space-y-1 text-[13.5px]" data-mobile-toc-list></ol>
        </details>
      </header>

      <!-- Prose body -->
      <div class="article-prose learn-prose px-6 md:px-10 lg:px-14 py-12 md:py-16 max-w-[760px]">
        <slot />
      </div>

      <!-- Previously / up next -->
      <footer class="px-6 md:px-10 lg:px-14 py-12 border-t border-[color:var(--border)]">
        <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-5">Continue reading</div>
        <div class="grid sm:grid-cols-2 gap-3">
          {neighbors.map(({ label, article }) => (
            <a href={article.href} class="group flex items-center justify-between p-5 rounded-[12px] bg-[color:var(--surface-2)] ring-1 ring-[color:var(--border)] hover:ring-[#0284c7]/40 hover:bg-white transition-all">
              <div class="min-w-0">
                <div class="text-[10.5px] font-mono text-muted-foreground">{label} · {article.read} min read</div>
                <div class="mt-1 text-[15px] font-semibold text-heading group-hover:text-[#0369a1] transition-colors leading-snug">{article.title}</div>
              </div>
              <Icon name="arrowRight" size={14} class="shrink-0 ml-4 text-muted-foreground group-hover:text-[#0369a1] group-hover:translate-x-0.5 transition-all" />
            </a>
          ))}
        </div>
      </footer>
    </main>
  </div>

  <script is:inline>
    // Chapter rail + mobile TOC from H2s, scroll-spy, hover anchors,
    // reading progress. Articles author plain HTML, so ids are assigned here.
    (function () {
      var rail = document.querySelector('[data-chapter-rail]');
      var railBlock = document.querySelector('[data-chapter-block]');
      var mobileToc = document.querySelector('[data-mobile-toc]');
      var mobileTocList = document.querySelector('[data-mobile-toc-list]');
      var main = document.querySelector('.learn-prose');
      var bar = document.querySelector('[data-reading-progress]');
      if (!main) return;

      var slug = function (s) { return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); };
      var h2s = Array.prototype.slice.call(main.querySelectorAll('h2'));

      // Reading progress works even on pages without chapters.
      if (bar) {
        var raf = 0;
        var update = function () {
          var rect = main.getBoundingClientRect();
          var total = rect.height - window.innerHeight;
          var read = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
          bar.style.width = (total > 0 ? (read / total) * 100 : 100) + '%';
        };
        update();
        window.addEventListener('scroll', function () {
          if (raf) return;
          raf = requestAnimationFrame(function () { raf = 0; update(); });
        }, { passive: true });
      }

      if (!h2s.length) return;

      var baseClass = 'group flex items-baseline gap-3 py-1.5 px-2 -mx-2 rounded-md transition-colors duration-300 ease-out';
      var inactiveClass = ' text-foreground/60 hover:text-[#0369a1]';
      var activeClass = ' text-[#0369a1] font-semibold';

      var links = [];
      h2s.forEach(function (h2, i) {
        var label = h2.textContent || 'Section ' + (i + 1);
        if (!h2.id) h2.id = slug(label);

        // Hover anchor for deep links.
        var anchor = document.createElement('a');
        anchor.href = '#' + h2.id;
        anchor.className = 'heading-anchor';
        anchor.textContent = '#';
        anchor.setAttribute('aria-label', 'Link to this section');
        h2.appendChild(anchor);

        if (rail) {
          var li = document.createElement('li');
          var a = document.createElement('a');
          a.href = '#' + h2.id;
          a.className = baseClass + inactiveClass;
          a.innerHTML = '<span class="font-mono text-[10.5px] text-muted-foreground/70 w-5 shrink-0 chapter-num">' + String(i + 1).padStart(2, '0') + '</span><span class="leading-snug"></span>';
          a.lastChild.textContent = label;
          li.appendChild(a);
          rail.appendChild(li);
          links.push({ id: h2.id, el: a });
        }

        if (mobileTocList) {
          var mli = document.createElement('li');
          var ma = document.createElement('a');
          ma.href = '#' + h2.id;
          ma.className = 'flex items-baseline gap-2.5 py-1 text-foreground/70 hover:text-[#0369a1]';
          ma.innerHTML = '<span class="font-mono text-[10.5px] text-muted-foreground/60">' + String(i + 1).padStart(2, '0') + '</span><span></span>';
          ma.lastChild.textContent = label;
          mli.appendChild(ma);
          mobileTocList.appendChild(mli);
        }
      });

      if (railBlock) railBlock.hidden = false;
      if (mobileToc) mobileToc.hidden = false;

      // Scroll-spy: highlight closest H2 above viewport mid-line.
      var currentId = null;
      function setActive(id) {
        if (id === currentId) return;
        currentId = id;
        links.forEach(function (l) {
          l.el.className = baseClass + (l.id === id ? activeClass : inactiveClass);
        });
      }
      function onScroll() {
        var probe = window.innerHeight * 0.35;
        var active = h2s[0].id;
        for (var i = 0; i < h2s.length; i++) {
          var rect = h2s[i].getBoundingClientRect();
          if (rect.top - probe <= 0) active = h2s[i].id; else break;
        }
        setActive(active);
      }
      if (links.length) {
        onScroll();
        var raf2 = 0;
        window.addEventListener('scroll', function () {
          if (raf2) return;
          raf2 = requestAnimationFrame(function () { raf2 = 0; onScroll(); });
        }, { passive: true });
      }
    })();
  </script>

  <style>
    details[data-mobile-toc] summary::-webkit-details-marker { display: none; }
    details[data-mobile-toc][open] .toc-caret { transform: rotate(180deg); }
  </style>
</Layout>
