---
import Layout from './Layout.astro';
import Cloud from '../components/Cloud.astro';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  reading?: string;
  updated?: string;
}
const {
  title,
  description,
  eyebrow = 'Learn',
  reading = '6 min read',
  updated,
} = Astro.props;

const sidebar: { title: string; links: { label: string; href: string }[] }[] = [
  {
    title: 'Foundations',
    links: [
      { label: 'Email warmup',            href: '/learn/email-warmup/' },
      { label: 'Deliverability handbook', href: '/learn/deliverability/' },
      { label: 'SPF, DKIM, DMARC',        href: '/learn/spf-dkim-dmarc/' },
      { label: 'Inbox placement',         href: '/learn/inbox-placement/' },
    ],
  },
  {
    title: 'Sending well',
    links: [
      { label: 'Cold email rules',        href: '/learn/cold-email-rules/' },
      { label: 'Warmup pools',            href: '/learn/warmup-pools/' },
      { label: 'Reputation recovery',     href: '/learn/reputation-recovery/' },
    ],
  },
  {
    title: 'Reference',
    links: [
      { label: 'Glossary',                href: '/learn/glossary/' },
    ],
  },
];

const path = Astro.url.pathname;
---
<Layout title={title} description={description ?? title}>
  <!-- Slim sky header for learn articles -->
  <section class="relative isolate overflow-hidden text-white" style="background: radial-gradient(ellipse 130% 140% at 72% 28%, #0284c7 0%, #0369a1 25%, #075985 50%, #0c4a6e 80%, #0a3d5c 100%);">
    <div class="absolute top-0 right-0 w-[360px] opacity-25 pointer-events-none cloud-drift cloud-1" style="mix-blend-mode: screen;">
      <Cloud variant={4} opacity={1} />
    </div>
    <div class="container-page relative pt-14 pb-14">
      <a href="/learn/" class="inline-flex items-center gap-1.5 text-[12px] text-white/65 hover:text-white">
        <Icon name="arrowRight" size={12} class="rotate-180" />
        {eyebrow}
      </a>
      <h1 class="mt-4 text-[32px] md:text-[44px] font-semibold tracking-[-0.025em] leading-[1.06] text-white max-w-3xl">{title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-[11.5px] font-mono text-white/55">
        <span>{reading}</span>
        {updated && <span>· Updated {updated}</span>}
      </div>
    </div>
  </section>

  <div class="container-page py-12 md:py-16 grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10 lg:gap-16">
    <aside class="lg:sticky lg:top-20 self-start">
      {sidebar.map((g) => (
        <div class="mb-6">
          <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-muted-foreground mb-2">{g.title}</div>
          <ul class="space-y-0.5">
            {g.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class={
                    'block text-[13.5px] -mx-2 px-2 py-1.5 rounded-md transition-colors ' +
                    (path === l.href
                      ? 'bg-[color:var(--surface-2)] text-foreground font-medium'
                      : 'text-muted-foreground hover:text-foreground hover:bg-[color:var(--surface-2)]/60')
                  }
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </aside>

    <article class="max-w-3xl">
      {description && <p class="text-[17px] text-foreground/80 leading-relaxed mb-8">{description}</p>}
      <div class="space-y-6 [&_h2]:text-[22px] [&_h2]:md:text-[26px] [&_h2]:font-semibold [&_h2]:tracking-[-0.02em] [&_h2]:mt-12 [&_h2]:mb-3 [&_h2]:text-heading [&_h3]:text-[16px] [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-2 [&_h3]:text-heading [&_p]:text-[15.5px] [&_p]:leading-relaxed [&_p]:text-foreground/85 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ul]:text-[15px] [&_ul]:text-foreground/85 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-1.5 [&_ol]:text-[15px] [&_ol]:text-foreground/85 [&_a]:text-[color:var(--brand)] [&_a:hover]:text-[color:var(--brand-strong)] [&_code]:font-mono [&_code]:text-[0.92em] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:bg-[color:var(--surface-2)] [&_code]:ring-1 [&_code]:ring-[color:var(--border)] [&_blockquote]:border-l-2 [&_blockquote]:border-[color:var(--brand)] [&_blockquote]:pl-4 [&_blockquote]:text-foreground/70 [&_blockquote]:text-[15.5px] [&_pre]:bg-[#0c1224] [&_pre]:text-white/90 [&_pre]:p-4 [&_pre]:rounded-[8px] [&_pre]:overflow-x-auto [&_pre]:text-[13px]">
        <slot />
      </div>
    </article>
  </div>
</Layout>
