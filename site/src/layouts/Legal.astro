---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  effective?: string;
}
const { title, description, effective = '2026-05-01' } = Astro.props;

const docs = [
  { label: 'Terms of Service',    href: '/terms/' },
  { label: 'Privacy Policy',      href: '/privacy/' },
  { label: 'Data Processing Addendum', href: '/dpa/' },
  { label: 'Acceptable Use',      href: '/acceptable-use/' },
  { label: 'Subprocessors',       href: '/subprocessors/' },
  { label: 'Cookies',             href: '/cookies/' },
];

const path = Astro.url.pathname;
---
<Layout title={title} description={description ?? title}>
  <div class="container-page py-10 md:py-14 grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10 lg:gap-14">
    <aside class="lg:sticky lg:top-20 self-start">
      <div class="text-[12px] uppercase tracking-wider font-semibold text-muted-foreground mb-4">Legal</div>
      <ul class="space-y-1">
        {docs.map((d) => (
          <li>
            <a
              href={d.href}
              class={
                'block text-[13.5px] -mx-2 px-2 py-1.5 rounded-md transition-colors ' +
                (path === d.href
                  ? 'bg-surface-2 text-foreground font-medium'
                  : 'text-muted-foreground hover:text-foreground hover:bg-surface-2/60')
              }
            >
              {d.label}
            </a>
          </li>
        ))}
      </ul>
    </aside>

    <article class="max-w-3xl prose-warmbly">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">{title}</h1>
      <div class="mt-3 text-[12.5px] text-muted-foreground">Effective {effective}</div>
      <div class="mt-8 space-y-6 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:tracking-tight [&_h2]:mt-12 [&_h2]:mb-3 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-2 [&_p]:text-[15px] [&_p]:leading-relaxed [&_p]:text-foreground/85 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ul]:text-[14.5px] [&_ul]:text-foreground/85 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:space-y-1.5 [&_ol]:text-[14.5px] [&_ol]:text-foreground/85 [&_a]:text-brand [&_a:hover]:text-brand-strong [&_code]:font-mono [&_code]:text-[0.92em] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:bg-surface-2 [&_code]:border [&_code]:border-border">
        <slot />
      </div>
      <div class="mt-16 text-[12.5px] text-muted-foreground border-t border-border pt-6">
        Questions about this document? Email <a class="text-brand hover:text-brand-strong" href="mailto:legal@warmbly.com">legal@warmbly.com</a>.
      </div>
    </article>
  </div>
</Layout>
