---
import Layout from '../../layouts/Layout.astro';
import HeroAtmosphere from '../../components/HeroAtmosphere.astro';
import Icon from '../../components/Icon.astro';
import CTA from '../../components/CTA.astro';

// Six fake-but-realistic client workspaces for the workspace switcher mock.
// Volume numbers tie back to platform defaults: 50/day cold cap, premium pool warmup.
const workspaces = [
  { code: 'NW', name: 'Northwind Co.',       industry: 'B2B SaaS · ops',          mailboxes: 8,  deals: 23, weekly: 1820, status: 'healthy',  tone: 'emerald', plan: 'Grow' },
  { code: 'LR', name: 'Lumen Robotics',      industry: 'Industrial · robotics',   mailboxes: 6,  deals: 14, weekly: 1340, status: 'healthy',  tone: 'emerald', plan: 'Starter', active: true },
  { code: 'GH', name: 'Glasshouse Labs',     industry: 'Dev tooling',             mailboxes: 4,  deals: 9,  weekly:  870, status: 'watch',    tone: 'amber',   plan: 'Starter' },
  { code: 'PH', name: 'Penna Health',        industry: 'Healthtech',              mailboxes: 5,  deals: 18, weekly: 1110, status: 'healthy',  tone: 'emerald', plan: 'Grow' },
  { code: 'VL', name: 'Vela Logistics',      industry: 'Freight · logistics',     mailboxes: 3,  deals: 6,  weekly:  640, status: 'paused',   tone: 'slate',   plan: 'Starter' },
  { code: 'ST', name: 'Stratech',            industry: 'Enterprise platform',     mailboxes: 9,  deals: 31, weekly: 2040, status: 'healthy',  tone: 'emerald', plan: 'Business' },
];

const statusTone = (t: string) => {
  if (t === 'emerald') return { dot: 'bg-emerald-500', chip: 'bg-emerald-50 text-emerald-700', text: 'text-emerald-700' };
  if (t === 'amber')   return { dot: 'bg-amber-500',   chip: 'bg-amber-50 text-amber-700',     text: 'text-amber-700' };
  return                       { dot: 'bg-slate-400',  chip: 'bg-slate-100 text-slate-600',    text: 'text-slate-600' };
};

// Hoist comparisons that JSX cannot inline (the `<` character is awkward in Astro JSX).
const totalMailboxes = workspaces.reduce((n, w) => n + w.mailboxes, 0);
const totalDeals     = workspaces.reduce((n, w) => n + w.deals, 0);
const totalWeekly    = workspaces.reduce((n, w) => n + w.weekly, 0);
const healthyCount   = workspaces.filter((w) => w.status === 'healthy').length;
const watchCount     = workspaces.filter((w) => w.status === 'watch').length;
const pausedCount    = workspaces.filter((w) => w.status === 'paused').length;

// The three pillars of per-client isolation, mapped to actual Warmbly terms.
const guarantees = [
  {
    term: 'Sender pool',
    body: 'Each workspace owns its own mailboxes, warmup pool membership and worker assignment. One client landing in quarantine never touches another client\'s reputation.',
    proof: 'Per-workspace warmup pool isolation',
    icon: 'shield',
  },
  {
    term: 'Analytics scope',
    body: 'Sends, replies, placement and complaint rate are scoped to the workspace. The agency owner gets a roll-up view, but reporting hands off cleanly per client.',
    proof: 'Per-workspace analytics + roll-up',
    icon: 'chart',
  },
  {
    term: 'Suppression list',
    body: 'Bounce, complaint and unsubscribe state lives inside the workspace. One client\'s do-not-contact list never accidentally blocks another client\'s sequence.',
    proof: 'Per-workspace suppression',
    icon: 'lock',
  },
];

// Monthly white-label report contents. Numbers are platform fields, not invented metrics.
const reportRows = [
  { metric: 'Volume sent',         field: 'campaigns.sends',             notes: 'Per mailbox, per sequence, per day' },
  { metric: 'Inbox placement',     field: 'warmup.placement_rate',       notes: 'From warmup token classification' },
  { metric: 'Reply rate',          field: 'campaigns.reply_rate',        notes: 'Positive / neutral / negative split' },
  { metric: 'Complaint rate',      field: 'deliverability.complaints',   notes: 'Tracked against Google 0.1% / 0.3% bands' },
  { metric: 'Bounce rate',         field: 'deliverability.bounces',      notes: 'Hard bounces auto-suppressed' },
  { metric: 'Top replying contacts', field: 'contacts.top_repliers',     notes: 'Sorted by positive reply count' },
  { metric: 'Mailbox health band', field: 'warmup.band',                 notes: 'Healthy · Watch · Quarantined · Blocked' },
  { metric: 'Suppression growth',  field: 'suppression.delta_30d',       notes: 'Adds and removes in the period' },
];

// Pricing math: per-workspace, per-plan, no per-seat charge.
// Numbers below come straight from /pricing/ — kept as ranges or "per plan" labels rather than invented dollar figures.
const pricingFacts = [
  { k: 'Billing unit',         v: 'per workspace',          why: 'One subscription per client. Agency owner pays, marks up however they want.' },
  { k: 'Seat charge',          v: 'none',                   why: 'Add the BDR, the AE, the QA reviewer. Seat count never changes the bill.' },
  { k: 'Mailbox limit',        v: 'per plan',               why: 'Plan defines mailbox count. Stack workspaces to scale capacity across clients.' },
  { k: 'Warmup access',        v: 'premium pool',           why: 'Every paid workspace runs on the premium warmup pool. Same quarantine bands across the roster.' },
  { k: 'Whitelabel reporting', v: 'PDF · CSV',              why: 'Strip the Warmbly mark, drop in the agency logo, hand to the client.' },
  { k: 'Markup model',         v: 'whatever you want',      why: 'You bill the client. We bill you per workspace. The delta is yours.' },
];

const faq = [
  ['Can one client\'s bad mailbox affect another client?',
   'No. Workspaces are sender-pool isolated. A mailbox that hits the quarantine band drops into recovery inside its own workspace and never participates in warmup pairs against mailboxes from a different client workspace.'],
  ['Do I have to manage billing for every client?',
   'You own every workspace subscription as the agency. Clients do not see a Warmbly invoice unless you transfer ownership. Mark up whatever you want at the agency level.'],
  ['Can clients log in to see their own data?',
   'Yes, on Grow and Business. Roles let you invite the client read-only or scope them to just their workspace, while keeping billing and worker config on your side.'],
];
---
<Layout
  title="Outbound for Agencies & Clients | Warmbly"
  description="Run outbound for many clients on many domains. Workspace-per-client isolation, per-client deliverability reporting and per-workspace billing."
>
  <!-- ============================================================
       HERO · HeroAtmosphere (shared pattern)
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-44 md:pb-56 text-center">
      <div class="inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white" style="color:#0369a1;">
          Agencies
        </span>
        Outbound for many clients, no spreadsheet triage
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        One platform for<br/>every client domain.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        A workspace per client. Isolated sender pools, isolated analytics, isolated suppression. Whitelabel reports your account managers can hand off without screenshot edits.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Start free trial</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="#workspaces" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          See the workspace switcher
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WORKSPACE SWITCHER MOCK · floats up into the hero
  ============================================================ -->
  <section id="workspaces" class="relative -mt-36 md:-mt-44 pb-16 md:pb-24 z-10 scroll-mt-4">
    <div class="container-page">
      <div class="rounded-[16px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden shadow-[0_40px_90px_-30px_rgba(2,32,71,0.35),0_12px_30px_-12px_rgba(15,23,42,0.12)]">
        <!-- App-frame chrome -->
        <div class="px-5 py-2.5 border-b border-[color:var(--border)] bg-[color:var(--surface-1)]/70 flex items-center gap-3">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]/80"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]/80"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]/80"></span>
          </div>
          <div class="flex-1 text-center">
            <span class="text-[11.5px] font-mono text-muted-foreground">app.warmbly.com / workspaces</span>
          </div>
          <div class="text-[11px] font-mono text-muted-foreground">agency-owner view</div>
        </div>

        <!-- Switcher header: agency context + roll-up totals -->
        <div class="px-7 py-5 border-b border-[color:var(--border)] grid lg:grid-cols-[1fr_auto] gap-6 items-center">
          <div>
            <div class="flex items-center gap-3 flex-wrap">
              <span class="inline-flex w-10 h-10 rounded-[10px] bg-gradient-to-br from-[#0284c7] to-[#075985] text-white items-center justify-center text-[14px] font-semibold tracking-[-0.02em]">CC</span>
              <div>
                <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">Agency</div>
                <div class="text-[17px] font-semibold tracking-[-0.02em] text-heading">Cole &amp; Co. Outbound</div>
              </div>
            </div>
          </div>
          <div class="grid grid-cols-4 gap-x-7 text-right">
            <div>
              <div class="text-[10px] uppercase tracking-[0.18em] font-mono text-muted-foreground">Workspaces</div>
              <div class="mt-1 text-[20px] font-semibold tracking-[-0.02em] text-heading font-mono">{workspaces.length}</div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-[0.18em] font-mono text-muted-foreground">Mailboxes</div>
              <div class="mt-1 text-[20px] font-semibold tracking-[-0.02em] text-heading font-mono">{totalMailboxes}</div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-[0.18em] font-mono text-muted-foreground">Deals</div>
              <div class="mt-1 text-[20px] font-semibold tracking-[-0.02em] text-heading font-mono">{totalDeals}</div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-[0.18em] font-mono text-muted-foreground">Weekly sends</div>
              <div class="mt-1 text-[20px] font-semibold tracking-[-0.02em] text-heading font-mono">{totalWeekly.toLocaleString()}</div>
            </div>
          </div>
        </div>

        <!-- Filter / toolbar strip -->
        <div class="px-7 py-3 border-b border-[color:var(--border)] bg-[color:var(--surface-1)]/30 flex items-center gap-2.5 flex-wrap">
          <span class="inline-flex items-center gap-1.5 h-6 px-2 rounded-full text-[10.5px] font-mono font-medium bg-foreground text-background">
            All clients · {workspaces.length}
          </span>
          <span class="inline-flex items-center gap-1.5 h-6 px-2 rounded-full text-[10.5px] font-mono font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/70">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Healthy · {healthyCount}
          </span>
          <span class="inline-flex items-center gap-1.5 h-6 px-2 rounded-full text-[10.5px] font-mono font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/70">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            Watch · {watchCount}
          </span>
          <span class="inline-flex items-center gap-1.5 h-6 px-2 rounded-full text-[10.5px] font-mono font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/70">
            <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
            Paused · {pausedCount}
          </span>
          <div class="flex-1"></div>
          <button type="button" class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[6px] text-[11.5px] font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/75 hover:bg-[color:var(--surface-2)] transition-colors">
            <Icon name="filter" size={11} />
            Sort by volume
          </button>
          <button type="button" class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-[6px] text-[11.5px] font-medium bg-[#0284c7] text-white hover:bg-[#0369a1] transition-colors">
            <Icon name="users" size={11} />
            New workspace
          </button>
        </div>

        <!-- Column headers -->
        <div class="grid grid-cols-[1.7fr_0.7fr_0.7fr_0.9fr_0.7fr_0.5fr] gap-4 px-7 py-2.5 bg-[color:var(--surface-1)]/40 border-b border-[color:var(--border)] text-[10px] font-mono uppercase tracking-[0.16em] text-muted-foreground">
          <div>Client</div>
          <div class="text-right">Mailboxes</div>
          <div class="text-right">Deals</div>
          <div class="text-right">Weekly volume</div>
          <div>Status</div>
          <div class="text-right">Plan</div>
        </div>

        <!-- Workspace rows -->
        <div class="divide-y divide-[color:var(--border)]">
          {workspaces.map((w) => {
            const t = statusTone(w.tone);
            return (
              <div class={`grid grid-cols-[1.7fr_0.7fr_0.7fr_0.9fr_0.7fr_0.5fr] gap-4 px-7 py-3.5 items-center transition-colors ${w.active ? 'bg-[color:var(--sky-1)]/40 ring-1 ring-inset ring-[#0284c7]/15' : 'hover:bg-[color:var(--surface-1)]/40'}`}>
                <div class="flex items-center gap-3 min-w-0">
                  <span class="inline-flex w-9 h-9 shrink-0 rounded-[8px] bg-gradient-to-br from-slate-100 to-slate-200 ring-1 ring-[color:var(--border)] text-foreground/75 items-center justify-center text-[12px] font-semibold tracking-[-0.01em]">{w.code}</span>
                  <div class="min-w-0">
                    <div class="text-[13.5px] font-semibold text-heading truncate flex items-center gap-2">
                      {w.name}
                      {w.active && <span class="inline-flex items-center h-4 px-1.5 rounded text-[9.5px] font-semibold font-mono uppercase tracking-[0.1em] bg-[#0284c7] text-white">Active</span>}
                    </div>
                    <div class="text-[11px] text-muted-foreground truncate">{w.industry}</div>
                  </div>
                </div>
                <div class="text-right text-[13px] font-mono text-foreground/80">{w.mailboxes}</div>
                <div class="text-right text-[13px] font-mono text-foreground/80">{w.deals}</div>
                <div class="text-right text-[13px] font-mono text-foreground/80">{w.weekly.toLocaleString()}</div>
                <div>
                  <span class={`inline-flex items-center gap-1.5 h-5 px-1.5 rounded text-[10.5px] font-medium font-mono uppercase tracking-[0.08em] ${t.chip}`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${t.dot}`}></span>
                    {w.status}
                  </span>
                </div>
                <div class="text-right text-[11px] font-mono text-foreground/65">{w.plan}</div>
              </div>
            );
          })}
        </div>

        <!-- Footer strip -->
        <div class="px-7 py-3 border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/60 flex items-center justify-between text-[11px] font-mono text-muted-foreground">
          <span>Switch workspaces with <kbd class="inline-flex items-center h-4 px-1 rounded bg-white ring-1 ring-[color:var(--border)] text-[10px] text-foreground/70 font-mono">{'⌘'}</kbd> <kbd class="inline-flex items-center h-4 px-1 rounded bg-white ring-1 ring-[color:var(--border)] text-[10px] text-foreground/70 font-mono">K</kbd></span>
          <span>Per-workspace billing · agency owner pays</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PER-CLIENT GUARANTEE · 3 isolation cards with real terms
  ============================================================ -->
  <section class="border-y border-[color:var(--border)] py-20 md:py-24">
    <div class="container-page">
      <div class="max-w-2xl mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-3">Per-client guarantee</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
          One client never touches another.
        </h2>
        <p class="mt-4 text-[15.5px] text-foreground/70 leading-relaxed">
          Workspace isolation is not a UI filter. Sender pool, analytics scope and suppression list are three separate boundaries the platform enforces below the surface.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-4 lg:gap-5">
        {guarantees.map((g, i) => (
          <div class="relative rounded-[14px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden">
            <div class="h-1 bg-gradient-to-r from-[#0284c7] to-[#075985]"></div>
            <div class="p-7">
              <div class="flex items-start justify-between gap-3 mb-5">
                <span class="inline-flex w-9 h-9 rounded-[8px] bg-[color:var(--sky-1)] text-[#0369a1] items-center justify-center">
                  <Icon name={g.icon} size={16} />
                </span>
                <span class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-1.5">Warmbly term</div>
              <div class="text-[20px] font-semibold tracking-[-0.02em] text-heading">{g.term}</div>
              <p class="mt-3 text-[13.5px] text-foreground/70 leading-relaxed">{g.body}</p>
              <div class="mt-5 pt-4 border-t border-[color:var(--border)] flex items-center gap-2 text-[11.5px] font-mono text-muted-foreground">
                <Icon name="check" size={12} class="text-emerald-600 shrink-0" />
                <span>{g.proof}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       PER-CLIENT REPORTING · whitelabel monthly PDF spec
  ============================================================ -->
  <section class="bg-[color:var(--surface-1)]/40 py-20 md:py-28">
    <div class="container-page grid lg:grid-cols-[1fr_1.3fr] gap-12 lg:gap-16 items-start">
      <div class="lg:sticky lg:top-24" style="align-self: start;">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-3">Per-client reporting</div>
        <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.025em] leading-[1.06] text-heading">
          A monthly report the PM can hand off.
        </h2>
        <p class="mt-5 text-[15px] text-foreground/70 leading-relaxed max-w-md">
          Every workspace produces the same report shape on the same cadence. Strip the Warmbly mark, drop in the agency logo, send. Account managers stop building decks from screenshots.
        </p>

        <div class="mt-7 space-y-2 text-[13px]">
          <div class="flex items-center gap-2 text-foreground/75">
            <Icon name="check" size={12} class="text-emerald-600" />
            <span>Whitelabel branding · agency logo and colour</span>
          </div>
          <div class="flex items-center gap-2 text-foreground/75">
            <Icon name="check" size={12} class="text-emerald-600" />
            <span>PDF and CSV export · same fields, both shapes</span>
          </div>
          <div class="flex items-center gap-2 text-foreground/75">
            <Icon name="check" size={12} class="text-emerald-600" />
            <span>Monthly cron or on-demand from the workspace</span>
          </div>
          <div class="flex items-center gap-2 text-foreground/75">
            <Icon name="check" size={12} class="text-emerald-600" />
            <span>Webhook delivery to client portal if you prefer</span>
          </div>
        </div>
      </div>

      <!-- The report spec table -->
      <div class="rounded-[14px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden">
        <!-- Report header bar (looks like a PDF cover) -->
        <div class="px-7 py-5 bg-gradient-to-br from-[#0284c7] to-[#075985] text-white">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <div>
              <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-white/70">Monthly deliverability report</div>
              <div class="mt-1 text-[18px] font-semibold tracking-[-0.02em]">Lumen Robotics · April 2026</div>
            </div>
            <div class="text-right">
              <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-white/70">Prepared by</div>
              <div class="mt-1 text-[13px] font-mono text-white/90">Cole &amp; Co. Outbound</div>
            </div>
          </div>
        </div>

        <!-- Column headers -->
        <div class="grid grid-cols-[1.2fr_1fr_1.4fr] gap-4 px-7 py-3 border-b border-[color:var(--border)] bg-[color:var(--surface-1)]/40 text-[10px] uppercase tracking-[0.16em] font-mono text-muted-foreground">
          <div>Metric</div>
          <div>Source field</div>
          <div>Description</div>
        </div>

        <!-- Report rows -->
        <div class="divide-y divide-[color:var(--border)]">
          {reportRows.map((r, i) => (
            <div class="grid grid-cols-[1.2fr_1fr_1.4fr] gap-4 px-7 py-3 items-baseline">
              <div class="flex items-baseline gap-2">
                <span class="text-[10px] font-mono text-muted-foreground/70 tracking-[0.12em]">{String(i + 1).padStart(2, '0')}</span>
                <span class="text-[13px] font-medium text-heading">{r.metric}</span>
              </div>
              <div class="text-[11.5px] font-mono text-[#0369a1]">{r.field}</div>
              <div class="text-[12.5px] text-foreground/65 leading-snug">{r.notes}</div>
            </div>
          ))}
        </div>

        <!-- Report footer -->
        <div class="px-7 py-3 border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/60 flex items-center justify-between text-[11px] font-mono text-muted-foreground">
          <span>Export · PDF · CSV · webhook</span>
          <span class="inline-flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Ready for handoff
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRICING MATH · spec sheet for agency-shaped billing
  ============================================================ -->
  <section class="border-y border-[color:var(--border)] py-20 md:py-28">
    <div class="container-page">
      <div class="max-w-2xl mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-3">Pricing math</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
          Per workspace. Not per seat.
        </h2>
        <p class="mt-4 text-[15.5px] text-foreground/70 leading-relaxed">
          The agency model is workspace-priced and seat-free, so adding a BDR, an AE or a QA reviewer never changes the bill. You set the markup on the client side. We invoice you per workspace.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-x-12 gap-y-px">
        {pricingFacts.map((p, i) => (
          <div class="group grid grid-cols-[1fr_auto] gap-6 py-6 border-b border-[color:var(--border)] items-baseline transition-colors hover:bg-[color:var(--surface-1)]/40 -mx-3 px-3 rounded-[6px]">
            <div>
              <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">
                {String(i + 1).padStart(2, '0')} · {p.k}
              </div>
              <p class="mt-2 text-[13.5px] text-foreground/65 leading-relaxed max-w-md">{p.why}</p>
            </div>
            <div class="text-right">
              <div class="text-[20px] md:text-[24px] font-semibold tracking-[-0.02em] text-heading font-mono whitespace-nowrap">{p.v}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 rounded-[12px] bg-[color:var(--sky-1)]/50 ring-1 ring-[#0284c7]/15 p-6 md:p-7 grid md:grid-cols-[1fr_auto] gap-5 items-center">
        <div>
          <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-2">How it shakes out</div>
          <p class="text-[14px] text-foreground/80 leading-relaxed max-w-2xl">
            Agency owner subscribes to N workspaces on the plans the client roster needs. Workspaces stack. Mark up the per-client number however your contract reads. The platform does not care.
          </p>
        </div>
        <a href="/pricing/" class="inline-flex h-10 px-4 items-center gap-2 rounded-[10px] text-[13px] font-medium bg-foreground text-background hover:bg-[#1f2937] transition-colors whitespace-nowrap">
          See pricing
          <Icon name="arrowRight" size={12} />
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ · grid-rows accordion (shared pattern)
  ============================================================ -->
  <section class="bg-[color:var(--surface-1)]/40 py-20 md:py-24">
    <div class="container-page grid lg:grid-cols-[1fr_1.8fr] gap-12 lg:gap-20 items-start">
      <div class="lg:sticky lg:top-24" style="align-self: start;">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-muted-foreground mb-3">Agency FAQ</div>
        <h2 class="text-[28px] md:text-[36px] font-semibold tracking-[-0.025em] leading-[1.08] text-heading">
          Three questions agencies ask first.
        </h2>
        <p class="mt-4 text-[14.5px] text-foreground/70 leading-relaxed">
          Need a deeper dive? Talk to <a class="text-[#0369a1] hover:text-[#075985] font-medium" href="/contact/">our team</a> about the agency rollout.
        </p>
      </div>
      <div class="divide-y divide-[color:var(--border)]" data-faq>
        {faq.map(([q, a]) => (
          <div class="faq-row py-2">
            <button type="button" class="faq-trigger group w-full flex items-start justify-between gap-4 py-3 text-left" aria-expanded="false">
              <span class="text-[15.5px] font-medium text-heading group-hover:text-[#0369a1] transition-colors">{q}</span>
              <span class="faq-icon shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-white ring-1 ring-[color:var(--border)] text-foreground/60 transition-transform duration-300 ease-out">
                <Icon name="plus" size={12} />
              </span>
            </button>
            <div class="faq-panel grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out">
              <div class="overflow-hidden">
                <p class="pb-4 pr-12 text-[14px] text-foreground/75 leading-relaxed max-w-2xl">{a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <script is:inline>
        (function () {
          const faq = document.querySelector('[data-faq]');
          if (!faq) return;
          faq.querySelectorAll('.faq-trigger').forEach(function (btn) {
            btn.addEventListener('click', function () {
              const row   = btn.closest('.faq-row');
              const panel = row.querySelector('.faq-panel');
              const icon  = btn.querySelector('.faq-icon');
              const open  = btn.getAttribute('aria-expanded') === 'true';
              btn.setAttribute('aria-expanded', String(!open));
              panel.style.gridTemplateRows = open ? '0fr' : '1fr';
              if (icon) icon.style.transform = open ? 'rotate(0deg)' : 'rotate(45deg)';
            });
          });
        })();
      </script>
    </div>
  </section>

  <CTA
    title="Run outbound for many clients without losing your mind."
    primaryLabel="Start free trial"
  />
</Layout>
