---
import Layout from '../../layouts/Layout.astro';
import HeroAtmosphere from '../../components/HeroAtmosphere.astro';
import Cloud from '../../components/Cloud.astro';
import Icon from '../../components/Icon.astro';
import { learnArticles, levelTone, numberWord } from '../../lib/learn';

// Single source of truth for the library lives in src/lib/learn.ts.
const featured = learnArticles.find((a) => a.featured)!;
const rest     = learnArticles.filter((a) => !a.featured);
---
<Layout
  title="Cold Email & Deliverability Guides | Warmbly"
  description="Long-form guides on email warmup, deliverability, authentication, cold email rules and reputation recovery. Written by the team."
>
  <!-- ============================================================
       HERO — HeroAtmosphere, editorial framing.
              Featured article overlaps into the white below.
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-44 md:pb-56 text-center">
      <div class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white !text-[#0369a1]" style="color:#0369a1;">
          Learn
        </span>
        Plain-English guides, no jargon
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        The cold-email handbook<br/>we wished existed.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Long-form essays on warmup, deliverability, authentication and reputation. Written by the people who built our quarantine logic.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FEATURED ARTICLE — overlaps the sky, big magazine-style card
  ============================================================ -->
  <section class="relative -mt-36 md:-mt-44 pb-16 md:pb-24 z-10">
    <div class="container-page">
      <a href={featured.href} class="group block rounded-[20px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden shadow-[0_40px_90px_-30px_rgba(2,32,71,0.35),0_12px_30px_-12px_rgba(15,23,42,0.12)] hover:shadow-[0_50px_100px_-30px_rgba(2,32,71,0.4),0_18px_40px_-12px_rgba(15,23,42,0.18)] transition-shadow">
        <div class="grid lg:grid-cols-[1.4fr_1fr]">
          <!-- Text side -->
          <div class="p-8 md:p-12 lg:p-14 flex flex-col">
            <div class="flex items-center gap-3 flex-wrap">
              <span class="inline-flex items-center gap-1.5 h-6 px-2.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.12em] font-mono bg-amber-50 text-amber-700">
                <span class="w-1 h-1 rounded-full bg-amber-500"></span>
                {featured.level} · featured
              </span>
              <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground">{featured.topic}</span>
              <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground">{featured.read} min read</span>
            </div>

            <h2 class="mt-6 text-[32px] md:text-[44px] lg:text-[52px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading group-hover:text-[#0369a1] transition-colors">
              {featured.title}
            </h2>
            <p class="mt-5 text-[15.5px] md:text-[17px] text-foreground/75 leading-relaxed max-w-xl">
              {featured.body}
            </p>

            <div class="mt-auto pt-8">
              <span class="inline-flex items-center gap-2 h-11 px-5 rounded-[10px] text-[14px] font-semibold bg-foreground text-background group-hover:bg-[#1f2937] group-hover:-translate-y-0.5 transition-all shadow-[0_4px_14px_-2px_rgba(15,23,42,0.2)]">
                Read the handbook <Icon name="arrowRight" size={13} />
              </span>
            </div>
          </div>

          <!-- Visual side: layered sky with reading-time tile -->
          <div class="relative min-h-[280px] lg:min-h-full overflow-hidden" style="background: radial-gradient(ellipse 130% 100% at 50% 0%, #38bdf8 0%, #0284c7 50%, #075985 100%);">
            <div class="absolute -top-6 right-[-40px] w-[280px] opacity-65 pointer-events-none cloud-drift cloud-1" style="mix-blend-mode: screen;">
              <Cloud variant={5} opacity={0.95} />
            </div>
            <div class="absolute bottom-[-40px] left-[-30px] w-[240px] opacity-55 pointer-events-none cloud-drift cloud-2" style="mix-blend-mode: screen;">
              <Cloud variant={3} opacity={0.85} />
            </div>

            <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
              <div class="w-16 h-16 rounded-[16px] bg-white/20 backdrop-blur ring-1 ring-white/30 inline-flex items-center justify-center mb-5">
                <Icon name={featured.icon} size={26} class="text-white" />
              </div>
              <div class="text-[60px] md:text-[80px] font-semibold text-white tracking-[-0.04em] leading-none drop-shadow-[0_2px_8px_rgba(2,32,71,0.3)]">{featured.read}</div>
              <div class="mt-1 text-[10.5px] uppercase tracking-[0.2em] font-mono text-white/75">minutes</div>
              <div class="mt-5 text-[12.5px] font-mono text-white/85">{featured.topic} · the place to start</div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ============================================================
       LIBRARY + REFERENCE — single inline section, no sky bg.
       Articles left, glossary preview right as a reference panel.
  ============================================================ -->
  <section class="bg-white py-20 md:py-28">
    <div class="container-page">
      <div class="mb-12 max-w-3xl">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">The library</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
          {numberWord(rest.length)} essays and a reference.
        </h2>
      </div>

      <div class="grid lg:grid-cols-[1.7fr_1fr] gap-10 lg:gap-14 items-start">
        <!-- Library: article rows -->
        <div>
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-4 flex items-center gap-3">
            <span>Essays</span>
            <span class="flex-1 h-px bg-[color:var(--border)]"></span>
            <span class="text-[10.5px] font-mono text-muted-foreground/70">{rest.length}</span>
          </div>
          <div class="divide-y divide-[color:var(--border)]">
            {rest.map((a, i) => {
              const tone = levelTone(a.level);
              return (
                <a href={a.href} class="article-row group grid grid-cols-[36px_1fr_auto] gap-4 py-5 items-baseline hover:bg-[color:var(--surface-2)]/60 -mx-3 px-3 rounded-[8px] transition-colors">
                  <span class="text-[11px] font-mono text-muted-foreground tracking-[0.06em] pt-1">{String(i + 1).padStart(2, '0')}</span>
                  <div class="min-w-0">
                    <h3 class="text-[17px] md:text-[19px] font-semibold tracking-[-0.015em] leading-[1.25] text-heading group-hover:text-[#0369a1] transition-colors">
                      {a.title}
                    </h3>
                    <p class="mt-1.5 text-[13px] text-foreground/65 leading-relaxed max-w-xl">{a.body}</p>
                    <div class="mt-2 flex items-center gap-3 text-[11.5px] font-mono text-muted-foreground">
                      <span class={`inline-flex items-center gap-1.5 h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.1em] ${tone.chip}`}>
                        <span class={`w-1 h-1 rounded-full ${tone.dot}`}></span>
                        {a.level}
                      </span>
                      <span class="uppercase tracking-[0.12em]">{a.topic}</span>
                      <span class="w-1 h-1 rounded-full bg-[color:var(--border)]"></span>
                      <span>{a.read} min</span>
                    </div>
                  </div>
                  <Icon name="arrowRight" size={13} class="text-muted-foreground group-hover:text-[#0369a1] group-hover:translate-x-1 transition-all self-center" />
                </a>
              );
            })}
          </div>
        </div>

        <!-- Reference: inline glossary panel -->
        <aside class="lg:sticky lg:top-24 self-start" style="align-self: start;">
          <div class="rounded-[14px] bg-[color:var(--surface-2)] ring-1 ring-[color:var(--border)] p-6 md:p-7">
            <div class="flex items-baseline justify-between mb-4">
              <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">Reference</div>
              <a href="/learn/glossary/" class="text-[11.5px] font-medium text-[#0369a1] hover:text-[#075985]">Open all →</a>
            </div>
            <h3 class="text-[20px] font-semibold tracking-[-0.02em] text-heading">Glossary</h3>
            <p class="mt-1.5 text-[13px] text-foreground/65 leading-relaxed">
              Deliverability vocabulary, defined plainly.
            </p>

            <div class="mt-5 pt-5 border-t border-[color:var(--border)] divide-y divide-[color:var(--border)]">
              {[
                { term: 'SPF',            defn: 'Authorises which servers can send for a domain.' },
                { term: 'DKIM',           defn: 'Signature proving a message was not altered.' },
                { term: 'DMARC',          defn: 'Tells receivers what to do when SPF/DKIM fails.' },
                { term: 'Placement',      defn: 'Inbox, Promotions, or spam after acceptance.' },
                { term: 'Complaint rate', defn: 'Share of recipients marking mail as spam.' },
                { term: 'ARF',            defn: 'Standard feedback-loop format from providers.' },
              ].map((t) => (
                <div class="py-3 first:pt-0 last:pb-0">
                  <div class="flex items-baseline gap-2 mb-0.5">
                    <span class="inline-flex items-center h-5 px-1.5 rounded text-[11px] font-mono font-semibold bg-white text-[#075985] ring-1 ring-[color:var(--sky-2)]">{t.term}</span>
                  </div>
                  <p class="text-[12.5px] text-foreground/70 leading-snug">{t.defn}</p>
                </div>
              ))}
            </div>

            <div class="mt-5 pt-5 border-t border-[color:var(--border)] flex items-center justify-between text-[11.5px] font-mono text-muted-foreground">
              <span>Plain definitions, A to Z</span>
              <span>5 min read</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA — deep sky, distinct from hero
  ============================================================ -->
  <section class="relative isolate overflow-hidden text-white">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 140% 90% at 50% 0%, #0ea5e9 0%, #0284c7 35%, #075985 70%, #0c4a6e 100%);"></div>
    <div class="absolute top-[30%] left-1/2 -translate-x-1/2 w-[720px] h-[400px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0) 65%);"></div>
    <div class="absolute top-[10%] left-[-100px] w-[380px] opacity-50 pointer-events-none cloud-drift cloud-1" style="mix-blend-mode: screen;">
      <Cloud variant={5} opacity={0.85} />
    </div>
    <div class="absolute top-[14%] right-[-90px] w-[340px] opacity-45 pointer-events-none cloud-drift cloud-2" style="mix-blend-mode: screen;">
      <Cloud variant={2} opacity={0.8} />
    </div>
    <div class="absolute bottom-[-60px] left-[12%] w-[260px] opacity-35 pointer-events-none cloud-drift cloud-3" style="mix-blend-mode: screen;">
      <Cloud variant={3} opacity={0.7} />
    </div>
    <div class="absolute bottom-[-40px] right-[8%] w-[300px] opacity-35 pointer-events-none cloud-drift cloud-1" style="mix-blend-mode: screen;">
      <Cloud variant={4} opacity={0.7} />
    </div>

    <div class="container-page relative py-24 md:py-32 text-center">
      <h2 class="text-[36px] md:text-[56px] font-semibold tracking-[-0.03em] leading-[1.04] text-white mx-auto max-w-2xl">
        Now put it into practice.
      </h2>
      <p class="mt-5 text-[15.5px] md:text-[17px] text-white/80 max-w-md mx-auto">
        Start a 14-day free trial. Two mailboxes. Real warmup pool.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Start free trial</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="/pricing/" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          See pricing
        </a>
      </div>
    </div>
  </section>

</Layout>
