---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

const chapters = [
  { num: '01', id: 'definition',    title: 'What deliverability actually means' },
  { num: '02', id: 'signals',       title: 'The signals that decide placement' },
  { num: '03', id: 'thresholds',    title: 'The thresholds you must respect' },
  { num: '04', id: 'mailbox-first', title: 'Why mailbox-first beats worker-first' },
  { num: '05', id: 'recipe',        title: 'The cold-email send recipe' },
  { num: '06', id: 'measure',       title: 'What to measure' },
  { num: '07', id: 'noise',         title: 'What not to measure' },
  { num: '08', id: 'problem',       title: 'When you spot a problem' },
];
---
<Layout
  title="The deliverability handbook · Warmbly"
  description="A full mental model for getting cold mail into the inbox, and keeping it there. Authentication, warmup, volume, reputation."
>
  <!-- ============================================================
       MASTHEAD — newspaper-style title block, wide and quiet
  ============================================================ -->
  <section class="border-b border-foreground/15 bg-white">
    <div class="container-page py-8">
      <div class="flex items-center justify-between text-[10.5px] uppercase tracking-[0.22em] font-mono text-foreground/55">
        <a href="/learn/" class="hover:text-foreground inline-flex items-center gap-1.5">
          <Icon name="arrowRight" size={10} class="rotate-180" />
          Learn
        </a>
        <div class="hidden md:block">Warmbly Handbook · Volume 1</div>
        <div>Updated 2026-05-08</div>
      </div>
    </div>
    <div class="container-page pt-10 md:pt-16 pb-12 md:pb-20">
      <div class="text-[11px] uppercase tracking-[0.22em] font-mono text-[#0284c7] mb-5">Chapter 1 · Foundations</div>
      <h1 class="font-semibold tracking-[-0.045em] leading-[0.92] text-heading text-[64px] sm:text-[88px] md:text-[120px] lg:text-[152px] max-w-[1100px]">
        The deliverability handbook.
      </h1>
      <div class="mt-10 grid lg:grid-cols-[1fr_auto] gap-8 items-end">
        <p class="text-[18px] md:text-[22px] text-foreground/70 leading-[1.4] max-w-2xl">
          A full mental model for getting cold mail into the inbox, and keeping it there.
        </p>
        <div class="flex items-center gap-8 text-[11px] uppercase tracking-[0.18em] font-mono text-foreground/55">
          <div><span class="block text-[18px] font-semibold text-heading tracking-[-0.02em] font-mono">14</span>min read</div>
          <div><span class="block text-[18px] font-semibold text-heading tracking-[-0.02em] font-mono">08</span>chapters</div>
          <div><span class="block text-[18px] font-semibold text-heading tracking-[-0.02em] font-mono">06</span>cross-links</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INDEX — full-width chapter list, no sidebar
  ============================================================ -->
  <section class="bg-[color:var(--surface-1)] border-b border-[color:var(--border)]">
    <div class="container-page py-8">
      <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-5">Chapters</div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-2">
        {chapters.map((c) => (
          <a href={`#${c.id}`} class="group flex items-baseline gap-3 py-2 text-foreground/75 hover:text-[#0369a1] transition-colors border-b border-[color:var(--border)]">
            <span class="text-[11px] font-mono text-muted-foreground w-6">{c.num}</span>
            <span class="text-[13.5px] leading-snug">{c.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       BODY — single wide reading column, no sidebar
       Drop-cap, generous typography, ornamental section dividers
  ============================================================ -->
  <article class="bg-white">
    <div class="container-page py-16 md:py-24 max-w-[820px] !mx-auto">

      <!-- Chapter 01 -->
      <section id="definition" class="scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">01</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          What deliverability actually means.
        </h2>
        <p class="first-letter:text-[80px] first-letter:font-semibold first-letter:tracking-[-0.04em] first-letter:leading-[0.85] first-letter:float-left first-letter:mr-3 first-letter:mt-1 first-letter:text-[#0369a1] text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Deliverability is whether your message lands in the recipient's primary inbox, not whether the SMTP transaction returned 250. The latter is delivery. The former is placement. Almost every conversation about deliverability conflates the two.
        </p>
        <p class="mt-5 text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          A mailbox provider can accept your message (delivery) and then immediately drop it into the Spam folder, the Promotions tab, or filter it out of the inbox entirely. None of that fails the SMTP transaction. Most cold-mail tools only see the green check.
        </p>
      </section>

      <!-- Chapter 02 -->
      <section id="signals" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">02</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          The signals that decide placement.
        </h2>

        <h3 class="text-[20px] font-semibold tracking-[-0.015em] text-heading mt-8 mb-3">Authentication</h3>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          SPF, DKIM and DMARC are not extras. They are the baseline. A misaligned DMARC record can cap an otherwise healthy mailbox at 60% inbox placement. See our <a href="/learn/spf-dkim-dmarc/" class="text-[#0369a1] hover:text-[#075985] underline underline-offset-2 decoration-[#0284c7]/30">SPF, DKIM, DMARC guide</a>.
        </p>

        <h3 class="text-[20px] font-semibold tracking-[-0.015em] text-heading mt-8 mb-3">Sender reputation</h3>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Mailbox providers maintain a moving reputation score per sending IP, per sending domain, and per "from" mailbox. Three vectors, all watched. A clean domain on a bad shared IP still suffers.
        </p>

        <h3 class="text-[20px] font-semibold tracking-[-0.015em] text-heading mt-8 mb-3">Recipient engagement</h3>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Did the recipient open? Reply? Move to Inbox from Spam? Add to address book? Each of those is a positive signal. Delete-without-reading and mark-as-spam are the negative ones.
        </p>

        <h3 class="text-[20px] font-semibold tracking-[-0.015em] text-heading mt-8 mb-3">Content</h3>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Cold mail with link-heavy HTML, image-only bodies, suspicious link patterns (bit.ly to a .top domain), or aggressive personalisation tokens raises flags. Plain text is the safest medium.
        </p>

        <h3 class="text-[20px] font-semibold tracking-[-0.015em] text-heading mt-8 mb-3">Volume and pattern</h3>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Sudden bursts. Big day-over-day spikes. Mail outside business hours from a mailbox that historically only sends 9 to 5. Mailbox providers model "normal" and flag deviation.
        </p>
      </section>

      <!-- Chapter 03 -->
      <section id="thresholds" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">03</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          The thresholds you must respect.
        </h2>
        <ul class="space-y-4 text-[17px] md:text-[18px] leading-[1.6] text-foreground/85">
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-[#0284c7] font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Google bulk sender guidance.</strong> Keep spam rate below 0.10%. Never reach 0.30%.</span>
          </li>
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-[#0284c7] font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Amazon SES complaints.</strong> Below 0.10% for best results. At 0.10% the account is auto-reviewed; at 0.50% it can be paused.</span>
          </li>
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-[#0284c7] font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Amazon SES bounces.</strong> Below 5%. At 5% the account is reviewed; at 10% sending may pause.</span>
          </li>
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-[#0284c7] font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Microsoft Exchange Online.</strong> Their own documentation says to use a specialised bulk provider for legitimate bulk commercial email.</span>
          </li>
        </ul>
      </section>

      <!-- Chapter 04 -->
      <section id="mailbox-first" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">04</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          Why mailbox-first beats worker-first.
        </h2>
        <p class="text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          Plenty of cold-email platforms reason about volume as a worker-level number (worker X can do 5,000 sends per day). That breaks the moment you scale, because reputation lives at the mailbox and IP level.
        </p>
        <p class="mt-5 text-[17px] md:text-[18px] leading-[1.75] text-foreground/85">
          The correct framing: each mailbox has a safe budget (the platform default is 100 per day for cold). A worker's safe outbound volume is the sum of its mailboxes' budgets. Never an independent ceiling. To send more, add more healthy mailboxes, not more pressure to existing ones.
        </p>
      </section>

      <!-- Chapter 05 -->
      <section id="recipe" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">05</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          The cold-email send recipe.
        </h2>
        <ol class="space-y-4">
          {[
            'Use a sub-domain for cold sending (outreach.acme.com). Reputation issues stay scoped.',
            'Configure SPF, DKIM and DMARC on the sub-domain. Start at p=none; move to p=quarantine after you have watched DMARC reports for two weeks.',
            'Warm every cold sending mailbox for at least 3 weeks before campaigns start.',
            'Cap each mailbox at the platform default: 100 cold emails per day with a 10-minute minimum gap.',
            'Spread campaign sends across multiple mailboxes. Do not concentrate volume.',
            'Plain text by default. No tracking pixels unless you absolutely need opens. No image-only bodies.',
            'Two or three follow-ups, not eight. Each follow-up below the previous reply rate.',
            'Suppression-aware. Bounces, complaints and unsubscribes suppress across all sequences.',
            'Monitor placement weekly. Act on the watch band, not the catastrophic band.',
            'Keep warmup running in parallel with cold campaigns.',
          ].map((step, i) => (
            <li class="grid grid-cols-[40px_1fr] gap-4 items-baseline text-[17px] md:text-[18px] leading-[1.7] text-foreground/85">
              <span class="text-[13px] font-mono text-[#0284c7] font-semibold">{String(i + 1).padStart(2, '0')}.</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </section>

      <!-- Chapter 06 -->
      <section id="measure" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">06</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          What to measure.
        </h2>
        <ul class="space-y-3 text-[17px] md:text-[18px] leading-[1.6] text-foreground/85">
          {[
            ['Inbox placement rate',  'per mailbox, probed via warmup partners and seed lists.'],
            ['Complaint rate',        'per mailbox and per workspace.'],
            ['Bounce rate',           'per mailbox, broken into hard versus soft.'],
            ['Reply rate',            'per sequence, per step, per variant.'],
            ['Positive-reply rate.',  'Replies classified as positive vs OOO, negative, unsubscribe.'],
            ['Suppression growth',    'as a percentage of contacted recipients.'],
          ].map(([k, v]) => (
            <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
              <span class="text-[12px] font-mono text-[#0284c7] font-semibold">·</span>
              <span><strong class="text-heading font-semibold">{k}</strong> {v}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Chapter 07 -->
      <section id="noise" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">07</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          What not to measure.
        </h2>
        <ul class="space-y-3 text-[17px] md:text-[18px] leading-[1.6] text-foreground/85">
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-rose-500 font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Open rate.</strong> Apple Mail Privacy proxies opens, Gmail caches images. The number is noise.</span>
          </li>
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-rose-500 font-semibold">·</span>
            <span><strong class="text-heading font-semibold">Click-through on cold first-touch.</strong> Most cold mail has no links, and "click anything" is itself a spam-folder signal.</span>
          </li>
          <li class="grid grid-cols-[28px_1fr] gap-3 items-baseline">
            <span class="text-[12px] font-mono text-rose-500 font-semibold">·</span>
            <span><strong class="text-heading font-semibold">"Deliverability score"</strong> from vendors who will not tell you the formula.</span>
          </li>
        </ul>
      </section>

      <!-- Chapter 08 -->
      <section id="problem" class="scroll-mt-24 mt-20">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-[12px] font-mono text-[#0284c7] font-semibold">08</span>
          <div class="flex-1 h-px bg-[color:var(--border)]"></div>
        </div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading mb-8">
          When you spot a problem.
        </h2>
        <ol class="space-y-4">
          {[
            'Pause campaigns from the affected mailbox immediately.',
            'Check the mailbox health band. If "watch" or worse, do not resume yet.',
            'Verify SPF, DKIM, DMARC alignment has not drifted.',
            'Drop warmup volume on the mailbox back to 5 or 10 per day for a week.',
            'If quarantined, expect a 7-day cooldown. If blocked, expect 30 days plus manual review.',
          ].map((step, i) => (
            <li class="grid grid-cols-[40px_1fr] gap-4 items-baseline text-[17px] md:text-[18px] leading-[1.7] text-foreground/85">
              <span class="text-[13px] font-mono text-[#0284c7] font-semibold">{String(i + 1).padStart(2, '0')}.</span>
              <span>{step}</span>
            </li>
          ))}
          <li class="grid grid-cols-[40px_1fr] gap-4 items-baseline text-[17px] md:text-[18px] leading-[1.7] text-foreground/85">
            <span class="text-[13px] font-mono text-[#0284c7] font-semibold">06.</span>
            <span>Run <a href="/learn/reputation-recovery/" class="text-[#0369a1] hover:text-[#075985] underline underline-offset-2 decoration-[#0284c7]/30">the recovery playbook</a>.</span>
          </li>
        </ol>
      </section>

      <!-- Closing pull-quote, full-bleed feel -->
      <div class="mt-24 mb-10">
        <div class="text-center text-[32px] font-mono text-[#0284c7]/40">§</div>
      </div>
      <blockquote class="border-y border-foreground/15 py-10 px-2">
        <p class="text-[24px] md:text-[30px] font-semibold tracking-[-0.02em] leading-[1.3] text-heading text-center">
          The right time to fix deliverability is before you have a deliverability problem. The next-best time is the day the watch band trips, not the week you notice replies dropped.
        </p>
      </blockquote>

      <!-- End-of-chapter footer -->
      <div class="mt-16 pt-10 border-t border-[color:var(--border)]">
        <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-5">Continue reading</div>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            { href: '/learn/email-warmup/',   title: 'Email warmup, properly explained', read: '11 min' },
            { href: '/learn/spf-dkim-dmarc/', title: 'SPF, DKIM and DMARC, end to end', read: '12 min' },
          ].map((n) => (
            <a href={n.href} class="group flex items-center justify-between p-5 rounded-[12px] bg-[color:var(--surface-1)] ring-1 ring-[color:var(--border)] hover:ring-[color:var(--sky-3)] hover:bg-white transition-all">
              <div>
                <div class="text-[10.5px] font-mono text-muted-foreground">{n.read} read</div>
                <div class="mt-1 text-[15px] font-semibold text-heading group-hover:text-[#0369a1] transition-colors">{n.title}</div>
              </div>
              <Icon name="arrowRight" size={14} class="text-muted-foreground group-hover:text-[#0369a1] group-hover:translate-x-0.5 transition-all" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </article>
</Layout>
