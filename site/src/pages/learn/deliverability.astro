---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

const chapters = [
  { num: '01', id: 'definition',    title: 'Definition' },
  { num: '02', id: 'signals',       title: 'Signals' },
  { num: '03', id: 'thresholds',    title: 'Thresholds' },
  { num: '04', id: 'mailbox-first', title: 'Framing' },
  { num: '05', id: 'recipe',        title: 'Send recipe' },
  { num: '06', id: 'measure',       title: 'Measure' },
  { num: '07', id: 'noise',         title: 'Ignore' },
  { num: '08', id: 'problem',       title: 'Incident' },
];

// All learn essays (kept in sync with Learn.astro)
const related = [
  { href: '/learn/email-warmup/',         title: 'Email warmup, properly explained',         read: '11 min' },
  { href: '/learn/deliverability/',       title: 'The deliverability handbook',              read: '14 min' },
  { href: '/learn/spf-dkim-dmarc/',       title: 'SPF, DKIM and DMARC, end to end',          read: '12 min' },
  { href: '/learn/inbox-placement/',      title: 'Inbox placement, not just delivery',       read: '8 min' },
  { href: '/learn/cold-email-rules/',     title: 'Cold email rules across regions',          read: '10 min' },
  { href: '/learn/warmup-pools/',         title: 'Warmup pools: free, premium, dedicated',   read: '7 min' },
  { href: '/learn/reputation-recovery/',  title: 'Recovering a burned mailbox',              read: '9 min' },
];
const path = Astro.url.pathname;
---
<Layout
  title="The deliverability handbook · Warmbly"
  description="A full mental model for getting cold mail into the inbox, and keeping it there. Authentication, warmup, volume, reputation."
>
  <!-- ============================================================
       TOP BAR — minimal nav
  ============================================================ -->
  <div class="bg-white border-b border-[color:var(--border)]">
    <div class="container-page py-3 flex items-center justify-between text-[11.5px] font-mono">
      <a href="/learn/" class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors">
        <Icon name="arrowRight" size={11} class="rotate-180" />
        Library
      </a>
      <div class="hidden md:flex items-center gap-4 text-muted-foreground">
        <span>Handbook v2.4</span>
        <span class="w-1 h-1 rounded-full bg-[color:var(--border)]"></span>
        <span>14 min</span>
        <span class="w-1 h-1 rounded-full bg-[color:var(--border)]"></span>
        <span>Updated 2026-05-08</span>
      </div>
    </div>
  </div>

  <!-- ============================================================
       DOC LAYOUT — sticky chapter rail · prose left · examples right
  ============================================================ -->
  <div class="grid lg:grid-cols-[200px_minmax(0,1fr)] xl:grid-cols-[220px_minmax(0,1fr)]">

    <!-- LEFT RAIL: chapter nav + article switcher -->
    <aside class="hidden lg:block border-r border-[color:var(--border)] bg-[color:var(--surface-1)]/40">
      <div class="sticky top-0 max-h-screen overflow-y-auto py-8 px-6 flex flex-col gap-7">
        <!-- On this page -->
        <div>
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-4">On this page</div>
          <ol class="space-y-px text-[13px]" data-chapter-rail>
            {chapters.map((c) => (
              <li>
                <a href={`#${c.id}`} data-target-id={c.id} class="chapter-link group flex items-baseline gap-3 py-1.5 px-2 -mx-2 rounded-md text-foreground/60 hover:text-[#0369a1] transition-colors duration-300 ease-out">
                  <span class="font-mono text-[10.5px] text-muted-foreground/55 w-5 shrink-0 chapter-num transition-colors duration-300">{c.num}</span>
                  <span class="leading-snug">{c.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>

        <!-- All essays -->
        <div class="pt-6 border-t border-[color:var(--border)]">
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground mb-4 flex items-center justify-between">
            <span>All essays</span>
            <span class="font-mono text-[10.5px] text-muted-foreground/70">{related.length}</span>
          </div>
          <ol class="space-y-px text-[13px]">
            {related.map((r, i) => {
              const isCurrent = r.href === path;
              return (
                <li>
                  <a
                    href={r.href}
                    aria-current={isCurrent ? 'page' : undefined}
                    class={`group flex items-baseline gap-3 py-1.5 px-2 -mx-2 rounded-md transition-colors duration-300 ease-out ${
                      isCurrent
                        ? 'text-[#0369a1] font-semibold'
                        : 'text-foreground/60 hover:text-[#0369a1]'
                    }`}
                  >
                    <span class={`font-mono text-[10.5px] w-5 shrink-0 transition-colors duration-300 ${isCurrent ? 'text-[#0284c7]' : 'text-muted-foreground/55'}`}>{String(i + 1).padStart(2, '0')}</span>
                    <span class="leading-snug flex-1 truncate">{r.title}</span>
                    {isCurrent ? (
                      <span class="w-1.5 h-1.5 rounded-full bg-[#0284c7] shrink-0"></span>
                    ) : (
                      <span class="font-mono text-[10px] text-muted-foreground/55 shrink-0">{r.read.replace(' min', 'm')}</span>
                    )}
                  </a>
                </li>
              );
            })}
          </ol>
          <a href="/learn/" class="mt-4 inline-flex items-center gap-1.5 text-[11.5px] font-mono text-[#0369a1] hover:text-[#075985]">
            Library home
            <Icon name="arrowRight" size={10} />
          </a>
        </div>
      </div>
    </aside>

    <script is:inline>
      // Scroll-spy for the handbook chapter rail
      (function () {
        const links = Array.from(document.querySelectorAll('.chapter-link'));
        if (!links.length) return;
        const sections = links
          .map((a) => ({ link: a, el: document.getElementById(a.getAttribute('data-target-id')) }))
          .filter((s) => s.el);
        if (!sections.length) return;

        const inactiveText = 'text-foreground/60 hover:text-[#0369a1]';
        const activeText   = 'text-[#0369a1] font-semibold';
        const inactiveNum  = 'text-muted-foreground/55';
        const activeNum    = 'text-[#0284c7]';

        let currentId = null;
        function setActive(id) {
          if (id === currentId) return;
          currentId = id;
          sections.forEach(({ link, el }) => {
            const num = link.querySelector('.chapter-num');
            if (el.id === id) {
              link.classList.remove(...inactiveText.split(' '));
              link.classList.add(...activeText.split(' '));
              num && num.classList.remove(...inactiveNum.split(' '));
              num && num.classList.add(...activeNum.split(' '));
            } else {
              link.classList.remove(...activeText.split(' '));
              link.classList.add(...inactiveText.split(' '));
              num && num.classList.remove(...activeNum.split(' '));
              num && num.classList.add(...inactiveNum.split(' '));
            }
          });
        }

        function onScroll() {
          const probe = window.innerHeight * 0.35;
          let active = sections[0].el.id;
          for (const { el } of sections) {
            const rect = el.getBoundingClientRect();
            if (rect.top - probe <= 0) active = el.id; else break;
          }
          setActive(active);
        }

        onScroll();
        let raf = 0;
        window.addEventListener('scroll', () => {
          if (raf) return;
          raf = requestAnimationFrame(() => { raf = 0; onScroll(); });
        }, { passive: true });
      })();
    </script>

    <!-- RIGHT: page header + 2-col doc rows -->
    <main class="bg-white">
      <!-- Page header -->
      <header class="border-b border-[color:var(--border)] px-6 md:px-10 lg:px-14 py-10 md:py-14">
        <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-[#0284c7] mb-3">Foundations · Essential</div>
        <h1 class="text-[40px] md:text-[52px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading max-w-3xl">
          The deliverability handbook.
        </h1>
        <p class="mt-4 text-[16px] md:text-[17px] text-foreground/70 max-w-2xl leading-relaxed">
          A full mental model for getting cold mail into the inbox, and keeping it there.
        </p>
      </header>

      <!-- ========== Chapter 01 ========== -->
      <section id="definition" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">01 · DEFINITION</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              What deliverability actually means.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              A message goes through three gates after you hand it to a mailbox provider. <strong>Acceptance</strong>: the SMTP server returns 250 and writes a queue ID. <strong>Filtering</strong>: spam scoring decides whether to deliver, defer, or reject. <strong>Placement</strong>: the surviving message lands in Inbox, Promotions, Spam, or a user-defined folder.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              "Delivery rate" almost always reports gate one only. A Gmail or Microsoft endpoint will accept 99% of validly-formed mail and then quietly route it to Spam if reputation is poor. The SMTP transaction never tells you that happened. Postfix logs the 250. Your tool shows a green check.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              The only way to know placement after the fact is to probe it: warmup pool partners reporting where mail landed (<code>X-Warmbly-Seed: probe</code>), Gmail Postmaster Tools showing the IP and domain reputation buckets, or a seed-list service like GlockApps/MailGenius. None of those are inferable from the SMTP response.
            </p>
          </div>
          <div class="xl:pl-4">
            <div class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-[color:var(--surface-1)] overflow-hidden">
              <div class="px-4 py-2.5 border-b border-[color:var(--border)] text-[10.5px] uppercase tracking-[0.18em] font-mono text-muted-foreground">
                The three gates
              </div>
              <div class="divide-y divide-[color:var(--border)]">
                <div class="px-4 py-3.5">
                  <div class="flex items-center justify-between mb-1">
                    <div class="text-[11px] font-mono text-emerald-700">acceptance</div>
                    <div class="text-[10.5px] font-mono text-muted-foreground">SMTP 250</div>
                  </div>
                  <div class="text-[13px] text-foreground/80">RFC validity, rate limit, basic IP block.</div>
                </div>
                <div class="px-4 py-3.5">
                  <div class="flex items-center justify-between mb-1">
                    <div class="text-[11px] font-mono text-amber-700">filtering</div>
                    <div class="text-[10.5px] font-mono text-muted-foreground">spam score</div>
                  </div>
                  <div class="text-[13px] text-foreground/80">Auth alignment, content scan, reputation lookup.</div>
                </div>
                <div class="px-4 py-3.5">
                  <div class="flex items-center justify-between mb-1">
                    <div class="text-[11px] font-mono text-[#0284c7]">placement</div>
                    <div class="text-[10.5px] font-mono text-muted-foreground">user-visible</div>
                  </div>
                  <div class="text-[13px] text-foreground/80">Inbox · Promotions · Spam · user rule.</div>
                </div>
              </div>
            </div>
            <div class="mt-4 rounded-[10px] bg-[color:var(--sky-1)]/60 ring-1 ring-[color:var(--sky-2)] p-4">
              <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-[#075985] mb-1.5">Working definition</div>
              <div class="text-[13px] text-foreground/85 leading-snug">
                <strong>Deliverability = P(placement = Inbox | acceptance).</strong> Everything in this handbook moves that conditional probability.
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 02 ========== -->
      <section id="signals" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">02 · SIGNALS</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              The signals that decide placement.
            </h2>
            <h3 class="text-[16px] font-semibold text-heading mt-6 mb-2">Authentication alignment</h3>
            <p class="text-[15px] leading-[1.7] text-foreground/85">
              DMARC asks: does the domain in the visible From header match either the SPF Return-Path domain OR the DKIM <code>d=</code> tag? Strict alignment requires an exact match; relaxed (the default) allows organisational-domain match. A DMARC <code>p=none</code> with passing alignment is treated very differently from <code>p=reject</code> with passing alignment. Both are different from a misalignment that DMARC allows through but Gmail still penalises. See the <a href="/learn/spf-dkim-dmarc/" class="text-[#0369a1] hover:text-[#075985] underline underline-offset-2 decoration-[#0284c7]/30">SPF/DKIM/DMARC guide</a>.
            </p>
            <h3 class="text-[16px] font-semibold text-heading mt-6 mb-2">Sender reputation, three vectors</h3>
            <p class="text-[15px] leading-[1.7] text-foreground/85">
              Providers score three independent reputations: sending IP, From domain, and increasingly, the d= signing domain. Gmail Postmaster Tools surfaces them as four buckets each: <em>High</em>, <em>Medium</em>, <em>Low</em>, <em>Bad</em>. A clean domain on a poisoned shared IP can still drop to Spam; a clean IP on a poisoned domain can also. The unbalanced case (clean domain, dirty IP) is the most common silent failure for cold-mail tools that pool customers onto shared infrastructure.
            </p>
            <h3 class="text-[16px] font-semibold text-heading mt-6 mb-2">Engagement signals, weighted</h3>
            <p class="text-[15px] leading-[1.7] text-foreground/85">
              Not all engagement weighs equally. A reply within 24 hours is the strongest positive signal a recipient can give. Moving a message from Spam to Inbox is second. Adding the sender to contacts is third. Reading and not replying is weakly positive. Mark-as-spam is the worst negative; delete-without-reading is mildly negative. Bulk-archive of unread mail at the message level is read by Gmail as "this is noise", and that pattern propagates across the sender for that recipient.
            </p>
            <h3 class="text-[16px] font-semibold text-heading mt-6 mb-2">Content fingerprints</h3>
            <p class="text-[15px] leading-[1.7] text-foreground/85">
              Filters score plain-text mail more leniently than HTML for cold first-touch. Specific patterns spike the score: link domains different from the sending domain, URL shorteners (bit.ly, t.co), TLDs in <code>.top</code> / <code>.click</code> / <code>.zip</code>, image-to-text ratios above 60%, fonts other than system stacks, hidden Unicode, and unsubscribe footers added by sending tools but absent from the visible body. The fastest way to drop a healthy mailbox into Spam is to change its content fingerprint suddenly: a sender that has only ever sent plain text and then drops in a Mailchimp-style template gets re-scored as a different sender.
            </p>
            <h3 class="text-[16px] font-semibold text-heading mt-6 mb-2">Volume cadence as anomaly detection</h3>
            <p class="text-[15px] leading-[1.7] text-foreground/85">
              Gmail and Microsoft both model "normal" per mailbox: typical hourly send rate, typical daily volume, typical recipient overlap. Deviations more than 2–3 standard deviations trip volume-anomaly heuristics. The common failure is a mailbox that ramped warmup nicely to 40/day and then suddenly sends 200 cold sends in one hour: the absolute number is small, but the rate-of-change is huge, and that is what gets flagged.
            </p>
          </div>
          <div class="xl:pl-4">
            <div class="xl:sticky xl:top-6">
              <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-muted-foreground mb-3">Signal weight</div>
              <div class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden">
                {[
                  ['Authentication', 'Mandatory', 'rose'],
                  ['Sender reputation', 'High', 'rose'],
                  ['Recipient engagement', 'High', 'amber'],
                  ['Content', 'Medium', 'amber'],
                  ['Volume and pattern', 'High', 'rose'],
                ].map(([name, weight, tone]) => (
                  <div class="grid grid-cols-[1fr_auto] gap-3 px-4 py-3 border-b border-[color:var(--border)] last:border-b-0 items-center text-[13.5px]">
                    <span class="text-foreground/85">{name}</span>
                    <span class={`inline-flex items-center px-1.5 py-0.5 rounded font-mono text-[11px] ${tone === 'rose' ? 'bg-rose-50 text-rose-700' : 'bg-amber-50 text-amber-700'}`}>{weight}</span>
                  </div>
                ))}
              </div>
              <p class="mt-3 text-[12px] text-muted-foreground italic">
                Weights are directional, not absolute. Providers do not publish formulas.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 03 ========== -->
      <section id="thresholds" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">03 · THRESHOLDS</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              The thresholds you must respect.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              The numbers below are not estimates. They come from each provider's own published guidance: Google's "Email sender guidelines" (the Feb 2024 bulk-sender update), Amazon SES's Account-Level Reputation documentation, and Microsoft's Exchange Online sending policy.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              The complaint rate that matters for Gmail is the <em>user-reported</em> rate that surfaces in Postmaster Tools, not the ARF feedback-loop rate. ARF complaints from Yahoo/Comcast/etc. arrive as MIME message/feedback-report parts and are a separate, more reliable signal. Both should stay below 0.1%.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              SES bounces split into hard and soft. Hard bounces (5.x.x) count immediately; soft bounces (4.x.x) only count if persistent. SES specifically excludes soft bounces from rate calculations after the first 48 hours.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Microsoft does not publish a complaint threshold; their position is that Exchange Online is not a bulk-commercial-email service. The Exchange Online Protection limits (e.g. 30 messages/min per connection, 10,000 recipients/day) apply to the sending tenant, not to the bulk-mail use case.
            </p>
          </div>
          <div class="xl:pl-4">
            <div class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden">
              <div class="grid grid-cols-[1.4fr_1fr_1fr] px-4 py-2.5 bg-[color:var(--surface-1)] border-b border-[color:var(--border)] text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground">
                <div>Provider · metric</div>
                <div>Warning</div>
                <div>Killswitch</div>
              </div>
              {[
                { provider: 'Google · spam rate',          warn: '0.10%',  kill: '0.30%' },
                { provider: 'Amazon SES · complaints',     warn: '0.10%',  kill: '0.50%' },
                { provider: 'Amazon SES · bounces',        warn: '5.0%',   kill: '10%' },
                { provider: 'Microsoft Exchange Online',   warn: 'disc.',  kill: 'bulk = specialist' },
              ].map((t) => (
                <div class="grid grid-cols-[1.4fr_1fr_1fr] px-4 py-3 border-b border-[color:var(--border)] last:border-b-0 items-center text-[13px]">
                  <div class="font-medium text-heading">{t.provider}</div>
                  <div><span class="inline-flex items-center px-1.5 py-0.5 rounded font-mono text-[11.5px] bg-amber-50 text-amber-700">{t.warn}</span></div>
                  <div><span class="inline-flex items-center px-1.5 py-0.5 rounded font-mono text-[11.5px] bg-rose-50 text-rose-700">{t.kill}</span></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 04 ========== -->
      <section id="mailbox-first" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">04 · FRAMING</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              Why mailbox-first beats worker-first.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              Reputation does not live at the worker. It lives at the IP, the domain, and the From mailbox. A worker that holds 200 mailboxes is 200 reputations, not one. Reasoning about a worker as a unit (worker.cap = 5000) ignores where the actual reputation signal accrues.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Warmbly's defaults reflect this: the cold-send cap is per mailbox (100/day) and the per-send gap is per mailbox (600 seconds). A worker's outbound budget is computed as <code>Σ mailbox.coldBudget</code> over its assigned mailboxes. The system surfaces a concentration warning when a shared worker holds more than ~10 actively-sending cold mailboxes at default settings (~1,000 cold sends/day), because past that point a single bad mailbox poisons the worker's IP for everyone else on it.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Scaling volume up means adding mailboxes, not raising per-mailbox caps. A campaign that wants 5,000 cold sends/day should be assigned to 50+ healthy mailboxes at the 100/day default, not 5 mailboxes pushed to 1,000/day. The first plan is invisible to any anomaly heuristic; the second is the textbook example.
            </p>
          </div>
          <div class="xl:pl-4 space-y-3">
            <div class="rounded-[10px] ring-1 ring-rose-100 bg-rose-50/40 p-5">
              <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-rose-700 mb-2">Wrong framing</div>
              <pre class="text-[13px] font-mono text-foreground/85 leading-[1.6] overflow-x-auto"><code>worker.cap = 5000</code></pre>
              <p class="mt-3 text-[12.5px] text-foreground/65">Flat per-worker ceilings ignore where reputation lives.</p>
            </div>
            <div class="rounded-[10px] ring-1 ring-emerald-100 bg-emerald-50/40 p-5">
              <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-emerald-700 mb-2">Right framing</div>
              <pre class="text-[13px] font-mono text-foreground/85 leading-[1.6] overflow-x-auto"><code>worker.cap = Σ mailbox.coldBudget</code></pre>
              <p class="mt-3 text-[12.5px] text-foreground/65">Volume scales by adding healthy mailboxes, not cranking existing ones.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 05 ========== -->
      <section id="recipe" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">05 · THE RECIPE</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              The cold-email send recipe.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              The sub-domain isolation matters because reputation cascades up the organisational domain. A blown <code>outreach.acme.com</code> does not poison <code>acme.com</code> transactional mail in the short term, but a blown bare <code>acme.com</code> does. Run cold mail on a sub-domain whose only purpose is cold mail.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              The DMARC ramp matters: start at <code>p=none; rua=mailto:dmarc@yourdomain</code>, watch reports for 14 days to confirm no third-party services were quietly relying on your domain (this is the most common surprise), then move to <code>p=quarantine; pct=10</code> for a week, then increase pct to 100, then <code>p=reject</code>. Skipping <code>pct</code> ramping is how legitimate mail gets quarantined by an aggressive DMARC change.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              The 100/day per-mailbox cap and 600-second gap are not magic numbers. They are derived from observing that mailboxes which send a new message every 10+ minutes look indistinguishable from human typing cadence to the receiver, and from the empirical observation that Gmail's anomaly model starts flagging mailboxes sending more than ~150/day from a previously low baseline.
            </p>
          </div>
          <div class="xl:pl-4">
            <ol class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden">
              {[
                'Use a sub-domain for cold sending (outreach.acme.com). Reputation issues stay scoped.',
                'Configure SPF, DKIM and DMARC on the sub-domain. Start at p=none, then quarantine after 2 weeks.',
                'Warm every cold sending mailbox for at least 3 weeks before campaigns start.',
                'Cap each mailbox at 100 cold emails per day with a 10-minute minimum gap.',
                'Spread campaign sends across multiple mailboxes. Do not concentrate volume.',
                'Plain text by default. No tracking pixels unless you need opens.',
                'Two or three follow-ups, not eight.',
                'Suppression aware. Bounces, complaints and unsubscribes propagate.',
                'Monitor placement weekly. Act on watch band, not catastrophe.',
                'Keep warmup running in parallel with cold campaigns.',
              ].map((step, i) => (
                <li class="grid grid-cols-[44px_1fr] gap-3 px-4 py-3 border-b border-[color:var(--border)] last:border-b-0 items-baseline">
                  <span class="text-[11px] font-mono text-[#0284c7] font-semibold">{String(i + 1).padStart(2, '0')}</span>
                  <span class="text-[13.5px] text-foreground/85 leading-[1.55]">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 06 ========== -->
      <section id="measure" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">06 · MEASURE</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              What to measure.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              Per-mailbox first, then aggregated. Workspace averages hide failures: a workspace with 0.05% complaint rate could have one mailbox at 0.4% and nine at 0.01%, and the 0.4% mailbox is the one Gmail will flag and reputation-debit.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Inbox placement is the headline metric but the hardest to measure without probes. Warmbly's warmup pool double-serves here: when a partner mailbox in the pool receives a warmup message, it reports the folder (Inbox/Spam/Promotions) along with a verification token, which feeds the placement signal for the sending mailbox. The probe sample size matters: act on the <strong>watch</strong> band only after at least 20 deliveries to the same sender in the past 7 days, otherwise you over-react to noise.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Complaint rate has two sources: ARF feedback loops (Yahoo, Comcast, AOL, Apple) arrive as RFC 5965 messages, and Google's "Spam-Marked" rate which is only visible through Postmaster Tools at the domain or IP level. Warmbly aggregates both into a single per-mailbox complaint score.
            </p>
          </div>
          <div class="xl:pl-4">
            <div class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden divide-y divide-[color:var(--border)]">
              {[
                ['Inbox placement rate', 'Probed via warmup partners and seed lists.'],
                ['Complaint rate',       'Per mailbox and per workspace.'],
                ['Bounce rate',          'Hard vs soft split.'],
                ['Reply rate',           'Per sequence, per step, per variant.'],
                ['Positive-reply rate',  'Strips OOO, unsubscribe, negative noise.'],
                ['Suppression growth',   'As a share of contacted recipients.'],
              ].map(([k, v]) => (
                <div class="grid grid-cols-[160px_1fr] gap-4 px-4 py-3 items-baseline">
                  <div class="text-[13px] font-semibold text-heading">{k}</div>
                  <div class="text-[13px] text-foreground/70 leading-snug">{v}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ========== Chapter 07 ========== -->
      <section id="noise" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">07 · IGNORE</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              What not to measure.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              Open rate is the metric that survives in cold-email tools because it produces a number that looks like a result. It is not. Apple Mail Privacy Protection (iOS 15.4+, macOS 12.3+) prefetches all tracking pixels through Apple-hosted proxies regardless of whether the user opens the message. The reported open rate from any Apple Mail recipient is functionally 100% within minutes of "delivery", and the share of Apple Mail in B2B inboxes ranges 25–45%. Pixel opens were never a great signal; today they are noise dominated.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Click-through on cold first-touch is bad in a different way. Most well-written cold mail has zero links: a link is a tracking pixel's bigger sibling, and a recipient who clicks "anything" in an unsolicited message is rare. Optimising for clicks on cold first-touch incentivises link-heavy content, which is itself a spam-folder signal.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              Vendor "deliverability scores" without a published formula are unauditable and gameable. If you cannot reproduce the number from your own data, do not let it drive operational decisions.
            </p>
          </div>
          <div class="xl:pl-4 space-y-3">
            {[
              { k: 'Open rate',                  v: 'Apple Mail Privacy proxies opens, Gmail caches images. The number is noise.' },
              { k: 'Click-through (cold first-touch)', v: 'Most cold mail has no links, and "click anything" is itself a spam-folder signal.' },
              { k: '"Deliverability score"',     v: 'From vendors who will not tell you the formula.' },
            ].map((n) => (
              <div class="rounded-[10px] ring-1 ring-rose-100 bg-rose-50/30 p-4 flex items-start gap-3">
                <Icon name="warning" size={14} class="text-rose-500 shrink-0 mt-1" />
                <div>
                  <div class="text-[13.5px] font-semibold text-heading">{n.k}</div>
                  <p class="mt-1 text-[12.5px] text-foreground/70 leading-relaxed">{n.v}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ========== Chapter 08 ========== -->
      <section id="problem" class="scroll-mt-4 px-6 md:px-10 lg:px-14 py-14 md:py-16 border-b border-[color:var(--border)]">
        <div class="grid xl:grid-cols-[1fr_1fr] gap-10 xl:gap-16">
          <div>
            <div class="flex items-baseline gap-3 mb-3">
              <span class="text-[10.5px] font-mono text-[#0284c7] tracking-[0.18em]">08 · INCIDENT</span>
            </div>
            <h2 class="text-[24px] md:text-[28px] font-semibold tracking-[-0.02em] leading-[1.15] text-heading mb-5">
              When you spot a problem.
            </h2>
            <p class="text-[15.5px] leading-[1.7] text-foreground/85">
              The trigger to run this playbook is any one of: spam placement above 10% on a 20-delivery rolling window, complaint rate above 0.03% on at least 100 delivered messages, hard bounce rate above 1%, or three or more invalid warmup-token attempts in 24 hours (Warmbly's specific tripwire for token forgery).
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              The DMARC alignment check on step three is the one most often skipped. A common silent failure: someone adds a new sending service (Stripe, Notion, support tool) that uses your domain in the From address but does not have its DKIM key added to your DNS. DMARC starts failing for that sub-population, the reputation lookup pulls a "this domain is sending unaligned mail" signal, and your unrelated cold mailboxes suffer.
            </p>
            <p class="mt-4 text-[15.5px] leading-[1.7] text-foreground/85">
              For the full recovery workflow once a mailbox has hit the quarantine or block band, read <a href="/learn/reputation-recovery/" class="text-[#0369a1] hover:text-[#075985] underline underline-offset-2 decoration-[#0284c7]/30">the recovery playbook</a>.
            </p>
          </div>
          <div class="xl:pl-4">
            <ol class="rounded-[10px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden">
              {[
                'Pause campaigns from the affected mailbox immediately.',
                'Check the mailbox health band. If "watch" or worse, do not resume yet.',
                'Verify SPF, DKIM, DMARC alignment has not drifted.',
                'Drop warmup volume on the mailbox to 5 or 10 per day for a week.',
                'If quarantined, expect a 7-day cooldown. If blocked, expect 30 days plus manual review.',
                'Run the recovery playbook.',
              ].map((step, i) => (
                <li class="grid grid-cols-[44px_1fr] gap-3 px-4 py-3 border-b border-[color:var(--border)] last:border-b-0 items-baseline">
                  <span class="text-[11px] font-mono text-[#0284c7] font-semibold">{String(i + 1).padStart(2, '0')}</span>
                  <span class="text-[13.5px] text-foreground/85 leading-[1.55]">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>

