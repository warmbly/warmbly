---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import SectionSky from '../components/SectionSky.astro';

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];

const plans = [
  {
    name: 'Free',
    price: '$0',
    cadence: 'forever',
    summary: 'For founders kicking the tires.',
    cta: 'Start free',
    href: 'https://app.warmbly.com/register?plan=free',
    highlight: false,
    features: [
      '1 connected mailbox',
      'Free warmup pool',
      '1 active sequence',
      '500 contacts',
      'Community support',
    ],
  },
  {
    name: 'Starter',
    price: '$39',
    cadence: '/ mailbox · mo',
    summary: 'Small teams sending 1–3k cold a month.',
    cta: 'Start trial',
    href: 'https://app.warmbly.com/register?plan=starter',
    highlight: false,
    features: [
      'Unlimited mailboxes',
      'Premium warmup pool',
      'Unified inbox',
      'Sequences with branching',
      '10,000 contacts',
    ],
  },
  {
    name: 'Growth',
    price: '$79',
    cadence: '/ mailbox · mo',
    summary: 'Sales teams running multi-sender campaigns.',
    cta: 'Start Growth trial',
    href: 'https://app.warmbly.com/register?plan=growth',
    highlight: true,
    features: [
      'Everything in Starter',
      'CRM · pipelines · deals · tasks',
      'API & signed webhooks',
      'Team roles & assignment',
      '100,000 contacts',
      'Priority support',
    ],
  },
  {
    name: 'Business',
    price: 'Custom',
    cadence: 'volume-based',
    summary: 'Agencies and high-volume teams.',
    cta: 'Talk to sales',
    href: '/contact/?topic=sales',
    highlight: false,
    features: [
      'Dedicated workers + IPs',
      'Up to 15,000 sends / day',
      'BYOK encryption',
      'SSO / SAML / SCIM',
      'Dedicated CSM',
    ],
  },
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — deep sky with drifting clouds, white text,
              dashboard mockup overlaps down into the white section
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-8 md:pb-12 text-center">
      <a href="/changelog/" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur border border-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white text-[color:var(--sky-6)]">New</span>
        Per-mailbox health bands &amp; auto-quarantine
        <Icon name="arrowRight" size={12} class="text-white/80 group-hover:translate-x-0.5 transition-transform" />
      </a>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[76px] lg:text-[88px] font-semibold tracking-[-0.04em] leading-[0.96] text-white max-w-5xl mx-auto">
        Cold email that <span class="italic font-medium text-sky-200">actually</span> lands in the inbox.
      </h1>

      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-[color:var(--sky-6)] bg-white hover:bg-white/95 transition-colors shadow-[0_10px_24px_-10px_rgba(8,47,73,0.55)]">
          Start free
          <Icon name="arrowRight" size={14} />
        </a>
        <a href="/product/"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-white bg-white/10 backdrop-blur border-2 border-white/40 hover:bg-white/20 transition-colors">
          Tour the product
          <Icon name="arrowUpRight" size={13} />
        </a>
      </div>
      <p class="mt-4 text-[12.5px] text-white/65">
        Free forever for one mailbox · 14-day Growth trial · no credit card.
      </p>
    </div>

    <!-- Dashboard mock — full width inside container, overlaps down -->
    <div class="container-page relative pt-6 md:pt-10 -mb-[140px] md:-mb-[200px] lg:-mb-[240px]">
      <div
        class="relative rounded-[14px] overflow-hidden ring-1 ring-black/[0.08]"
        style="box-shadow: var(--shadow-xl);"
      >
        <DashboardMock />

        <!-- Floating live notification on top of the mock -->
        <div class="hidden md:block absolute bottom-5 right-5 w-[280px] rounded-[10px] bg-white shadow-[0_10px_30px_-10px_rgba(15,23,42,0.35)] ring-1 ring-slate-200 p-3 animate-toast-in" style="animation-delay: 1.2s; animation-fill-mode: backwards;">
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 grid place-items-center shrink-0">
              <Icon name="reply" size={14} class="text-white" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <span class="text-[11.5px] font-semibold text-slate-900">Positive reply</span>
                <span class="text-[10px] text-slate-400 font-mono">just now</span>
              </div>
              <p class="text-[11.5px] text-slate-500 truncate mt-0.5">jenna@northwind.dev — Thursday 10am works for me…</p>
              <div class="mt-1.5 flex items-center gap-1">
                <span class="inline-flex items-center h-4 px-1.5 rounded text-[9px] font-semibold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">positive</span>
                <span class="text-[10px] text-slate-400 font-mono">· assigned to AE</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Spacer for the overlap, then sections
  ============================================================ -->
  <div class="bg-white" style="padding-top: 160px;">

    <!-- ============================================================
         LIVE METRICS STRIP — animated numbers, no fake reviews
    ============================================================ -->
    <section class="container-page pt-4 pb-16 md:pb-24">
      <div class="grid grid-cols-2 md:grid-cols-4 rounded-[14px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden"
           style="box-shadow: var(--shadow-sm);">
        {[
          { eyebrow: 'Today', value: '5,420', counter: { from: 5380, to: 6400 }, label: 'Sends · all workers', tone: 'bg-[color:var(--brand)]' },
          { eyebrow: 'Warming now', value: '12,418', counter: { from: 12390, to: 12480 }, label: 'Mailboxes in premium pool', tone: 'bg-emerald-500' },
          { eyebrow: 'Mean placement', value: '96.4%', label: 'Inbox · last 14 days', tone: 'bg-emerald-500' },
          { eyebrow: 'Mean complaint', value: '0.02%', label: 'Below Google’s 0.10% threshold', tone: 'bg-emerald-500' },
        ].map((s, i) => (
          <div class={`px-5 py-5 md:px-6 md:py-6 ${i < 3 ? 'md:border-r border-[color:var(--border)]' : ''} ${i < 2 ? 'border-b md:border-b-0 border-[color:var(--border)]' : ''}`}>
            <div class="flex items-center gap-1.5">
              <span class={`relative inline-flex w-1.5 h-1.5 rounded-full ${s.tone}`}>
                <span class={`absolute inset-0 rounded-full ${s.tone} animate-ping opacity-40`}></span>
              </span>
              <span class="text-[10.5px] uppercase tracking-[0.14em] text-muted-foreground font-semibold">{s.eyebrow}</span>
            </div>
            <div class="mt-3 text-[28px] md:text-[34px] font-semibold tracking-[-0.025em] text-heading leading-none">
              {s.counter ? (
                <span data-live-counter
                      data-from={s.counter.from}
                      data-to={s.counter.to}
                      data-tick-min="900"
                      data-tick-max="2400"
                      data-step-min="1"
                      data-step-max="3">{s.value}</span>
              ) : s.value}
            </div>
            <div class="mt-2 text-[12px] text-muted-foreground">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS — 4 numbered steps, connected flow
    ============================================================ -->
    <section class="border-t border-[color:var(--border)]" style="background: var(--surface-2);">
      <div class="container-page py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold mb-4">How it works</div>
          <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
            From connected mailbox to a campaign that lands — in an afternoon.
          </h2>
        </div>

        <div class="mt-14 grid md:grid-cols-4 gap-4 relative">
          <!-- Connecting line behind the steps -->
          <div class="hidden md:block absolute top-7 left-[12%] right-[12%] h-px" style="background: linear-gradient(to right, transparent, var(--brand) 20%, var(--brand) 80%, transparent);"></div>

          {[
            { n: '01', title: 'Connect',  body: 'OAuth a mailbox in seconds — Google, Microsoft, or any SMTP/IMAP.', icon: 'mail' },
            { n: '02', title: 'Warm up',  body: 'Pool selects vetted partners, ramps your volume +1/day, watches reputation.', icon: 'flame' },
            { n: '03', title: 'Sequence', body: 'Build steps with branching, A/B variants, business-hour delays.', icon: 'workflow' },
            { n: '04', title: 'Send & reply', body: 'Distribute across workers, classify every reply, route to the right human.', icon: 'send' },
          ].map((s) => (
            <div class="relative bg-white rounded-[14px] p-6 ring-1 ring-[color:var(--border)] lift-on-hover" style="box-shadow: var(--shadow-sm);">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-14 h-14 rounded-full bg-[color:var(--brand)] text-white grid place-items-center text-[16px] font-semibold tracking-tight ring-4 ring-white">
                  {s.n}
                </div>
                <Icon name={s.icon} class="text-[color:var(--brand)] ml-auto" size={18} />
              </div>
              <h3 class="text-[17px] font-semibold tracking-[-0.01em] text-heading">{s.title}</h3>
              <p class="mt-1.5 text-[13.5px] text-foreground/70 leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE — Warmup (text left, mock right with sky backdrop)
    ============================================================ -->
    <section class="container-page py-20 md:py-28">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-5">
          <div class="inline-flex items-center gap-1.5 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)] animate-pulse-soft"></span>
            <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Warmup</span>
          </div>
          <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
            A warmup pool that quarantines before mailbox providers do.
          </h2>
          <p class="mt-5 text-[16px] text-foreground/75 leading-relaxed">
            Free and premium pools never mix. Spam-score tracking, verification tokens and recent-partner avoidance keep traffic natural. Anything past the watch band gets pulled.
          </p>
          <ul class="mt-7 space-y-3 text-[14.5px]">
            {[
              'Start 10/day, ramp +1/day, ceiling 40/day',
              '≥ 3 invalid tokens / 24h → auto-block',
              'Spam score > 50 → recovery pool',
              'Re-entry requires fresh probation',
            ].map((l) => (
              <li class="flex items-start gap-2.5">
                <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-[color:var(--brand)] hover:text-[color:var(--brand-strong)] group">
            See how warmup works
            <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>

        <div class="lg:col-span-7">
          <div class="relative rounded-[20px] overflow-hidden p-5 md:p-8">
            <SectionSky variant="morning" />
            <div class="relative rounded-[12px] overflow-hidden ring-1 ring-black/[0.06] lift-on-hover"
                 style="box-shadow: var(--shadow-md);">
              <WarmupMock />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE — Inbox (mock left, text right)
    ============================================================ -->
    <section class="border-t border-[color:var(--border)]" style="background: var(--surface-2);">
      <div class="container-page py-20 md:py-28">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <div class="relative rounded-[20px] overflow-hidden p-5 md:p-8">
              <SectionSky variant="dusk" />
              <div class="relative rounded-[12px] overflow-hidden ring-1 ring-black/[0.06] lift-on-hover"
                   style="box-shadow: var(--shadow-md);">
                <InboxMock />
              </div>
            </div>
          </div>
          <div class="lg:col-span-5 order-1 lg:order-2">
            <div class="inline-flex items-center gap-1.5 mb-4">
              <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)] animate-pulse-soft"></span>
              <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Unified inbox</span>
            </div>
            <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
              One inbox for every mailbox you send from.
            </h2>
            <p class="mt-5 text-[16px] text-foreground/75 leading-relaxed">
              No more bouncing between Gmail tabs to handle replies from your eight cold mailboxes. Reply detection survives quoted text. OOO and unsubscribe auto-suppress.
            </p>
            <ul class="mt-7 space-y-3 text-[14.5px]">
              {[
                'Positive / negative / OOO / unsub / bounce classification',
                'Cross-mailbox search and saved views',
                'Round-robin or domain-aware assignment',
                'Realtime push for replies, not for opens',
              ].map((l) => (
                <li class="flex items-start gap-2.5">
                  <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
                  <span>{l}</span>
                </li>
              ))}
            </ul>
            <a href="/inbox/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-[color:var(--brand)] hover:text-[color:var(--brand-strong)] group">
              Explore the inbox <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE — Sending (text left, mock right with sky)
    ============================================================ -->
    <section class="container-page py-20 md:py-28">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-5">
          <div class="inline-flex items-center gap-1.5 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)] animate-pulse-soft"></span>
            <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Sending engine</span>
          </div>
          <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
            A distributed send plane, not a glorified SMTP relay.
          </h2>
          <p class="mt-5 text-[16px] text-foreground/75 leading-relaxed">
            One worker per machine. Each with its own IP. We add workers before we make any single one carry more weight.
          </p>
          <ul class="mt-7 space-y-3 text-[14.5px]">
            {[
              'Default 50/day cold cap per mailbox',
              'Minimum 10-minute gap between sends',
              'Worker volume = sum of mailbox budgets',
              'Native Gmail · Outlook · SMTP/IMAP',
            ].map((l) => (
              <li class="flex items-start gap-2.5">
                <Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="lg:col-span-7">
          <div class="relative rounded-[20px] overflow-hidden p-5 md:p-8">
            <SectionSky variant="noon" />
            <div class="relative bg-white rounded-[12px] overflow-hidden ring-1 ring-black/[0.06] lift-on-hover"
                 style="box-shadow: var(--shadow-md);">
              <div class="h-12 px-5 border-b border-[color:var(--border)] flex items-center gap-3">
                <span class="text-[10px] uppercase tracking-[0.14em] text-muted-foreground font-medium">Workers</span>
                <div class="h-4 w-px bg-[color:var(--border)]"></div>
                <span class="text-[12.5px] text-foreground/70">4 workers · 128 mailboxes ·
                  <span data-live-counter data-from="5380" data-to="6400" data-tick-min="900" data-tick-max="2200" data-step-min="1" data-step-max="3">5,420</span>
                  sent today</span>
              </div>
              <div class="divide-y divide-[color:var(--border)]">
                {[
                  { name: 'eu-worker-3', region: 'eu-west-1', mb: 38, ip: '52.18.214.91' },
                  { name: 'us-worker-7', region: 'us-east-1', mb: 32, ip: '54.221.190.17' },
                  { name: 'eu-worker-1', region: 'eu-west-1', mb: 30, ip: '52.18.220.44' },
                  { name: 'us-worker-2', region: 'us-east-1', mb: 28, ip: '54.221.196.21' },
                ].map((w) => (
                  <div class="px-5 py-3 grid grid-cols-12 items-center text-[12.5px] gap-3">
                    <div class="col-span-4 flex items-center gap-2">
                      <span class="relative inline-flex">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        <span class="absolute inset-0 rounded-full bg-emerald-500/40 animate-ping"></span>
                      </span>
                      <span class="font-mono text-foreground font-medium">{w.name}</span>
                      <span class="text-muted-foreground font-mono text-[11px]">· {w.region}</span>
                    </div>
                    <div class="col-span-2 text-muted-foreground font-mono text-[11.5px]">{w.ip}</div>
                    <div class="col-span-2 text-muted-foreground tabular-nums">{w.mb} mailboxes</div>
                    <div class="col-span-4">
                      <div class="h-1.5 rounded-full bg-[color:var(--surface-2)] overflow-hidden">
                        <div class="h-full rounded-full bg-[color:var(--brand)] animate-bar-grow" style={`--target:${(w.mb / 50) * 100}%`}></div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         COMPARE
    ============================================================ -->
    <section class="border-y border-[color:var(--border)]" style="background: var(--surface-2);">
      <div class="container-page py-20 md:py-24">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-1.5 mb-4">
            <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Why we’re different</span>
          </div>
          <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
            We refuse to be the reason your domain ends up on a blocklist.
          </h2>
          <p class="mt-4 text-foreground/75 leading-relaxed max-w-2xl">
            Most cold-email platforms reward you for sending more. We reward you for sending well.
          </p>
        </div>

        <div class="mt-10 rounded-[14px] bg-white overflow-hidden ring-1 ring-[color:var(--border)]"
             style="box-shadow: var(--shadow-sm);">
          <div class="grid grid-cols-12 px-5 md:px-8 h-12 items-center text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground border-b border-[color:var(--border)] bg-[color:var(--surface-2)]/40">
            <div class="col-span-4">Setting</div>
            <div class="col-span-4">Warmbly</div>
            <div class="col-span-4">Other cold-email tools</div>
          </div>
          {compare.map(([k, ours, theirs]) => (
            <div class="grid grid-cols-12 px-5 md:px-8 py-4 items-start border-b border-[color:var(--border)] last:border-b-0 text-[14px]">
              <div class="col-span-4 font-medium text-heading">{k}</div>
              <div class="col-span-4 text-foreground flex items-start gap-2"><Icon name="check" size={14} class="text-[color:var(--brand)] mt-1 shrink-0" /><span>{ours}</span></div>
              <div class="col-span-4 text-muted-foreground flex items-start gap-2"><Icon name="warning" size={14} class="text-muted-foreground mt-1 shrink-0" /><span>{theirs}</span></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         BENTO
    ============================================================ -->
    <section class="container-page py-24 md:py-28">
      <div class="max-w-3xl">
        <div class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold mb-4">One platform</div>
        <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
          Warmup, sending, inbox — engineered together.
        </h2>
        <p class="mt-4 text-foreground/75 leading-relaxed max-w-2xl">
          The signal one part collects is the signal the next part acts on.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-6 gap-3">
        <div class="md:col-span-2 rounded-[14px] bg-white ring-1 ring-[color:var(--border)] p-6 flex flex-col lift-on-hover" style="box-shadow: var(--shadow-sm);">
          <Icon name="shield" class="text-[color:var(--brand)]" />
          <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Quarantines on warning, not catastrophe</h3>
          <p class="mt-2 text-[13.5px] text-foreground/70 leading-relaxed">
            Watch band kicks in at 10% spam placement — months before mailbox providers act.
          </p>
          <div class="mt-auto pt-5 grid grid-cols-4 gap-1.5">
            {['Healthy','Watch','Quarantined','Blocked'].map((b, i) => (
              <div class={`rounded-md px-1.5 py-1 text-center text-[10px] font-semibold tracking-wider ring-1 ${
                i === 0 ? 'ring-emerald-200 text-emerald-700 bg-emerald-50' :
                i === 1 ? 'ring-amber-200 text-amber-700 bg-amber-50' :
                i === 2 ? 'ring-orange-200 text-orange-700 bg-orange-50' :
                          'ring-rose-200 text-rose-700 bg-rose-50'}`}>{b}</div>
            ))}
