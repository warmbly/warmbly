---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import PaintedSky from '../components/PaintedSky.astro';
import AppFrame from '../components/AppFrame.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';

const logos = ['Loop', 'Northwind', 'Spruce', 'Heliogen', 'Foundry', 'Quanto', 'Cinder', 'Vellum', 'Atlas', 'Mosaic'];

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — clean white, left-aligned, dense
  ============================================================ -->
  <section class="container-page pt-14 md:pt-20 pb-10 md:pb-16">
    <a href="/changelog/" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white border border-border text-[12px] text-foreground/80 shadow-sm">
      <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-wider bg-foreground text-background">New</span>
      Per-mailbox health bands &amp; auto-quarantine recovery
      <Icon name="arrowRight" size={12} class="text-muted-foreground group-hover:translate-x-0.5 transition-transform" />
    </a>

    <h1 class="mt-7 md:mt-9 text-[44px] sm:text-6xl md:text-[72px] lg:text-[88px] font-extrabold tracking-[-0.04em] leading-[0.95] text-foreground max-w-5xl">
      Cold email that actually lands in the inbox.
    </h1>

    <p class="mt-6 text-[17px] md:text-[19px] text-muted-foreground max-w-2xl leading-relaxed">
      Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a href="https://app.warmbly.com/register"
         class="inline-flex h-11 px-5 items-center gap-2 rounded-md text-[15px] font-medium bg-foreground text-background hover:bg-foreground/85 transition-colors">
        Start free
        <Icon name="arrowRight" size={15} />
      </a>
      <a href="/product/"
         class="inline-flex h-11 px-5 items-center gap-2 rounded-md text-[15px] font-medium border border-border bg-white hover:bg-surface transition-colors">
        Tour the product <Icon name="arrowUpRight" size={14} />
      </a>
    </div>

    <p class="mt-4 text-[13px] text-muted-foreground">
      Free forever for one mailbox · 14-day Growth trial · no credit card.
    </p>
  </section>

  <!-- ============================================================
       HERO MOCK — app screenshot on a painted-sky backdrop
  ============================================================ -->
  <section class="container-page pb-20 md:pb-28">
    <div class="relative rounded-[28px] overflow-hidden p-6 md:p-12 lg:p-16">
      <PaintedSky flavor="dawn" />
      <div class="relative">
        <AppFrame url="app.warmbly.com / accounts">
          <DashboardMock />
        </AppFrame>
      </div>
    </div>
  </section>

  <!-- ============================================================
       LOGOS
  ============================================================ -->
  <section class="border-y border-border bg-white">
    <div class="container-page py-9">
      <p class="text-center text-[12px] font-medium text-muted-foreground mb-6">
        Trusted every day by teams that build cold outbound at scale
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-y-4 gap-x-6 items-center">
        {logos.slice(0, 5).map((l) => (
          <span class="text-center text-[17px] font-semibold tracking-tight text-foreground/55">{l}</span>
        ))}
      </div>
      <div class="mt-3 grid grid-cols-2 sm:grid-cols-5 gap-y-4 gap-x-6 items-center">
        {logos.slice(5).map((l) => (
          <span class="text-center text-[17px] font-semibold tracking-tight text-foreground/55">{l}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 1 — Warmup (text left, mock right, painted backdrop)
  ============================================================ -->
  <section class="container-page py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-5">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-5">Warmup</span>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
          A warmup pool that quarantines before mailbox providers do.
        </h2>
        <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
          Free and premium pools never mix. Spam-score tracking, verification tokens and recent-partner avoidance keep traffic natural. Anything past the watch band gets pulled.
        </p>
        <ul class="mt-7 space-y-3 text-[14.5px]">
          {[
            'Start 10/day, ramp +1/day, ceiling 40/day',
            '≥ 3 invalid tokens / 24h → auto-block',
            'Spam score > 50 → recovery pool',
            'Re-entry requires fresh probation',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-emerald-600 mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
        <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-foreground hover:text-foreground/70 group">
          See how warmup works
          <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>

      <div class="lg:col-span-7">
        <div class="relative rounded-[24px] overflow-hidden p-6 md:p-10">
          <PaintedSky flavor="bright" />
          <div class="relative">
            <AppFrame url="warmbly.com / warmup / premium">
              <WarmupMock />
            </AppFrame>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 2 — Inbox (mock left, text right)
  ============================================================ -->
  <section class="bg-surface border-y border-border">
    <div class="container-page py-24 md:py-32">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div class="relative rounded-[24px] overflow-hidden p-6 md:p-10">
            <PaintedSky flavor="dusk" />
            <div class="relative">
              <AppFrame url="warmbly.com / inbox">
                <InboxMock />
              </AppFrame>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 order-1 lg:order-2">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-5">Unified inbox</span>
          <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
            One inbox for every mailbox you send from.
          </h2>
          <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
            No more bouncing between Gmail tabs to handle replies from your eight cold mailboxes. Reply detection survives quoted text. OOO and unsubscribe auto-suppress.
          </p>
          <ul class="mt-7 space-y-3 text-[14.5px]">
            {[
              'Positive / negative / OOO / unsub / bounce classification',
              'Cross-mailbox search and saved views',
              'Round-robin or domain-aware assignment',
              'Realtime push for replies, not for opens',
            ].map((l) => (
              <li class="flex items-start gap-2.5">
                <Icon name="check" size={14} class="text-emerald-600 mt-1 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <a href="/inbox/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-foreground hover:text-foreground/70 group">
            Explore the inbox <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 3 — Sending (text left, mock right with diff backdrop)
  ============================================================ -->
  <section class="container-page py-24 md:py-32">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-5">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-5">Sending engine</span>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
          A distributed send plane, not a glorified SMTP relay.
        </h2>
        <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
          One worker per machine. Each with its own IP. We add workers before we make any single one carry more weight.
        </p>
        <ul class="mt-7 space-y-3 text-[14.5px]">
          {[
            'Default 50/day cold cap per mailbox',
            'Minimum 10-minute gap between sends',
            'Worker volume = sum of mailbox budgets',
            'Native Gmail · Outlook · SMTP/IMAP',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-emerald-600 mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-7">
        <div class="relative rounded-[24px] overflow-hidden p-6 md:p-10">
          <PaintedSky flavor="dawn" />
          <div class="relative">
            <div class="app-window bg-white">
              <div class="flex items-center gap-2 px-3.5 h-9 border-b border-slate-200/80 bg-[#f8f9fb]">
                <div class="flex items-center gap-1.5">
                  <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
                  <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
                  <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
                </div>
                <div class="mx-auto inline-flex items-center gap-2 h-6 px-3 rounded-md bg-white border border-slate-200/80 text-[11.5px] text-slate-500 font-mono">
                  warmbly.com / workers
                </div>
                <div class="w-12"></div>
              </div>
              <div class="bg-white">
                <div class="h-12 px-5 border-b border-slate-200 flex items-center gap-3">
                  <span class="text-[10px] uppercase tracking-[0.14em] text-slate-400 font-medium">Workers</span>
                  <div class="h-4 w-px bg-slate-200"></div>
                  <span class="text-[12.5px] text-slate-600">4 workers · 128 mailboxes · 5,420 sent today</span>
                </div>
                <div class="divide-y divide-slate-200/60">
                  {[
                    { name: 'eu-worker-3', region: 'eu-west-1', mb: 38, sent: 1842, ip: '52.18.214.91' },
                    { name: 'us-worker-7', region: 'us-east-1', mb: 32, sent: 1456, ip: '54.221.190.17' },
                    { name: 'eu-worker-1', region: 'eu-west-1', mb: 30, sent: 1210, ip: '52.18.220.44' },
                    { name: 'us-worker-2', region: 'us-east-1', mb: 28, sent:  912, ip: '54.221.196.21' },
                  ].map((w) => (
                    <div class="px-5 py-3 grid grid-cols-12 items-center text-[12.5px] gap-3">
                      <div class="col-span-4 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                        <span class="font-mono text-slate-900 font-medium">{w.name}</span>
                        <span class="text-slate-400 font-mono text-[11px]">· {w.region}</span>
                      </div>
                      <div class="col-span-2 text-slate-500 font-mono text-[11.5px]">{w.ip}</div>
                      <div class="col-span-2 text-slate-500 tabular-nums">{w.mb} mailboxes</div>
                      <div class="col-span-2 text-slate-500 tabular-nums">{w.sent.toLocaleString()} today</div>
                      <div class="col-span-2">
                        <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
                          <div class="h-full rounded-full bg-sky-500" style={`width:${(w.mb / 50) * 100}%`}></div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMPARE STRIP — "Warmbly vs other tools"
  ============================================================ -->
  <section class="bg-surface border-y border-border">
    <div class="container-page py-20 md:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-4">Why we’re different</span>
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
          We refuse to be the reason your domain ends up on a blocklist.
        </h2>
        <p class="mt-4 text-muted-foreground leading-relaxed max-w-2xl">
          Most cold-email platforms reward you for sending more. We reward you for sending well. Defaults that keep you safe even if you never touch them.
        </p>
      </div>

      <div class="mt-10 rounded-2xl border border-border bg-card overflow-hidden">
        <div class="grid grid-cols-12 px-5 md:px-8 h-12 items-center text-[11px] font-semibold uppercase tracking-wider text-muted-foreground border-b border-border bg-surface/60">
          <div class="col-span-4">Setting</div>
          <div class="col-span-4">Warmbly</div>
          <div class="col-span-4">Other cold-email tools</div>
        </div>
        {compare.map(([k, ours, theirs]) => (
          <div class="grid grid-cols-12 px-5 md:px-8 py-4 items-start border-b border-border last:border-b-0 text-[14px]">
            <div class="col-span-4 font-semibold">{k}</div>
            <div class="col-span-4 text-foreground/90 flex items-start gap-2"><Icon name="check" size={14} class="text-emerald-600 mt-1 shrink-0" /><span>{ours}</span></div>
            <div class="col-span-4 text-muted-foreground flex items-start gap-2"><Icon name="warning" size={14} class="text-amber-600 mt-1 shrink-0" /><span>{theirs}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       BENTO — six dense cards
  ============================================================ -->
  <section class="container-page py-24 md:py-28">
    <div class="max-w-3xl">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-4">One platform</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
        Warmup, sending, inbox — engineered together.
      </h2>
      <p class="mt-4 text-muted-foreground leading-relaxed max-w-2xl">
        The signal one part collects is the signal the next part acts on. Nothing exists in a vacuum.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-6 gap-4">
      <!-- Spam shield -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6 flex flex-col">
        <Icon name="shield" class="text-brand" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-tight">Quarantines on warning, not catastrophe</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Watch band kicks in at 10% spam placement — months before mailbox providers act.
        </p>
        <div class="mt-auto pt-5 grid grid-cols-4 gap-1.5">
          {['Healthy','Watch','Quarantined','Blocked'].map((b, i) => (
            <div class={`rounded-md px-1.5 py-1 text-center text-[10px] font-semibold tracking-wider ${
              i === 0 ? 'bg-emerald-50 text-emerald-700' :
              i === 1 ? 'bg-amber-50 text-amber-700' :
              i === 2 ? 'bg-orange-50 text-orange-700' :
                        'bg-rose-50 text-rose-700'}`}>
              {b}
            </div>
          ))}
        </div>
      </div>

      <!-- Placement ring -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6 flex flex-col">
        <Icon name="chart" class="text-brand" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-tight">Placement, not open rate</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          We probe inbox placement through the pool, then act on it.
        </p>
        <div class="mt-auto pt-5 flex items-center justify-center">
          <div class="relative w-28 h-28">
            <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="oklch(0.94 0.005 260)" stroke-width="2.6"></circle>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#0ea5e9" stroke-width="2.6" stroke-dasharray="96 100" stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-xl font-extrabold tracking-tight">96%</span>
              <span class="text-[9.5px] uppercase tracking-wider text-muted-foreground">inbox</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Worker distribution -->
      <div class="md:col-span-2 rounded-2xl border border-border bg-card p-6 flex flex-col">
        <Icon name="cpu" class="text-brand" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-tight">Distributed across workers &amp; IPs</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          One worker per machine. Each with its own IP. Migrable on the fly.
        </p>
        <div class="mt-auto pt-5 space-y-2">
          {[
            { name: 'eu-worker-3', pct: 78 },
            { name: 'us-worker-7', pct: 56 },
            { name: 'eu-worker-1', pct: 41 },
          ].map((w) => (
            <div>
              <div class="flex items-center justify-between text-[11.5px] font-mono text-muted-foreground mb-1">
                <span>{w.name}</span><span>{w.pct}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-surface-2 overflow-hidden">
                <div class="h-full rounded-full bg-sky-500" style={`width:${w.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Sequence -->
      <div class="md:col-span-3 rounded-2xl border border-border bg-card p-6">
        <Icon name="workflow" class="text-brand" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-tight">Sequences with branching, A/B and TZ-aware delays</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Up to 12 steps. Variants per step. Business-hour delays by recipient time zone. Branch on reply, open, click, bounce.
        </p>
        <div class="mt-5 grid grid-cols-4 gap-2">
          {[
            { n: 'Step 1', t: 'Intro · plain text',         m: '2 variants' },
            { n: 'Step 2', t: 'Wait 3 biz days',            m: 'if no reply' },
            { n: 'Step 3', t: 'Follow-up · context',        m: '4 variants' },
            { n: 'Step 4', t: 'Soft break · 7 biz days',    m: 'if no open' },
          ].map((s) => (
            <div class="rounded-lg border border-border bg-surface/60 p-2.5">
              <div class="flex items-center justify-between text-[9.5px] font-mono text-muted-foreground uppercase tracking-wider">
                <span>{s.n}</span>
                <span class="text-foreground/60">{s.m}</span>
              </div>
              <div class="mt-1.5 text-[12px] font-medium leading-snug">{s.t}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Pool diversity -->
      <div class="md:col-span-3 rounded-2xl border border-border bg-card p-6">
        <Icon name="users" class="text-brand" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-tight">Vetted pool, real reputation surface</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Premium pool diversity across Gmail, Outlook, iCloud, Yahoo and self-hosted IMAP — proportional to the receiver landscape.
        </p>
        <div class="mt-5 grid grid-cols-5 gap-2">
          {[
            { name: 'Gmail',     pct: 46, color: 'bg-rose-500' },
            { name: 'Outlook',   pct: 24, color: 'bg-sky-500' },
            { name: 'Yahoo',     pct: 12, color: 'bg-violet-500' },
            { name: 'iCloud',    pct:  9, color: 'bg-zinc-500' },
            { name: 'Self-IMAP', pct:  9, color: 'bg-emerald-500' },
          ].map((p) => (
            <div class="rounded-lg border border-border bg-surface/60 p-2.5">
              <div class={`w-1.5 h-1.5 rounded-full ${p.color}`}></div>
              <div class="mt-1 text-[11px] font-medium">{p.name}</div>
              <div class="text-[11px] text-muted-foreground font-mono">{p.pct}%</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       QUOTE BAND
  ============================================================ -->
  <section class="bg-surface border-y border-border">
    <div class="container-page py-20 md:py-24">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <Icon name="star" size={20} class="text-amber-500 mb-4" />
          <blockquote class="text-2xl md:text-[34px] font-medium tracking-[-0.015em] leading-snug text-foreground">
            “We had eight mailboxes burning out a week with our old tool. Switched to Warmbly, rebuilt pool placement, dropped to one mailbox a quarter. Reply rate doubled because half our mail used to land in spam.”
          </blockquote>
          <div class="mt-6 inline-flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-400 to-indigo-500"></div>
            <div>
              <div class="text-sm font-semibold">Maya Okonkwo</div>
              <div class="text-[12.5px] text-muted-foreground">Head of GTM · Northwind</div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 grid grid-cols-2 gap-3">
          {[
            ['2.4 → 5.1%', 'Reply rate'],
            ['1 / quarter', 'Mailbox burnouts'],
            ['98.4%',      'Inbox placement'],
            ['6 hrs / wk', 'Saved per BDR'],
          ].map(([v, k]) => (
            <div class="rounded-xl border border-border bg-card p-5">
              <div class="text-2xl font-extrabold tracking-[-0.02em]">{v}</div>
              <div class="text-[12.5px] text-muted-foreground mt-1">{k}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRICING TEASER
  ============================================================ -->
  <section class="container-page py-24 md:py-28">
    <div class="max-w-3xl">
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold uppercase tracking-wider text-brand bg-brand-soft border border-brand/15 mb-4">Pricing</span>
      <h2 class="text-3xl md:text-5xl font-extrabold tracking-[-0.03em] leading-[1.04]">
        Per mailbox. Predictable. No deliverability paywall.
      </h2>
