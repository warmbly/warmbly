---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import SectionSky from '../components/SectionSky.astro';

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];

// Mirrors web/src/lib/plans.ts — single source of truth.
const plans = [
  {
    name: 'Starter',
    price: '$29',
    annual: '$23',
    cadence: '/ month',
    summary: 'Great for small businesses with a small budget.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=starter',
    highlight: false,
    sendsPerDay: 150,
    features: [
      'Unlimited warmup',
      'Unlimited mailboxes',
      '150 emails / day',
      'Unified inbox + reply detection',
      'Sequences with branching',
    ],
  },
  {
    name: 'Grow',
    price: '$89',
    annual: '$71',
    cadence: '/ month',
    summary: 'Ideal for growing businesses scaling their outreach.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=grow',
    highlight: false,
    sendsPerDay: 3000,
    features: [
      'Unlimited warmup',
      'Unlimited mailboxes',
      '3,000 emails / day',
      'CRM · pipelines · deals · tasks',
      'API & HMAC-signed webhooks',
    ],
  },
  {
    name: 'Business',
    price: '$329',
    annual: '$263',
    cadence: '/ month',
    summary: 'For established teams that need higher limits and advanced features.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=business',
    highlight: true,
    sendsPerDay: 15000,
    features: [
      'Everything in Grow',
      '15,000 emails / day',
      'Dedicated IPs',
      'Team roles + audit log',
      'Priority support',
    ],
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    annual: 'Custom',
    cadence: 'volume-based',
    summary: 'Large orgs with custom volume and dedicated support.',
    cta: 'Talk to sales',
    href: '/contact/?topic=sales',
    highlight: false,
    sendsPerDay: Infinity,
    features: [
      'Everything in Business',
      '15,000+ emails / day',
      'BYOK encryption · SSO / SAML',
      'Custom data residency',
      'Dedicated CSM',
    ],
  },
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — deep sky with drifting clouds, white text,
              dashboard mockup overlaps down into the white section
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-8 md:pb-12 text-center">
      <a href="https://github.com/warmbly/warmbly" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur border border-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white text-[color:var(--sky-6)]">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" class="mr-1"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5 4.6-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
          Open
        </span>
        The biggest open-source cold-email platform on GitHub
        <Icon name="arrowUpRight" size={12} class="text-white/80 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" />
      </a>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[76px] lg:text-[88px] font-semibold tracking-[-0.04em] leading-[0.96] text-white max-w-5xl mx-auto">
        Cold email that <span class="italic font-medium text-sky-200">actually</span> lands in the inbox.
      </h1>

      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-[color:var(--sky-6)] bg-white hover:bg-white/95 transition-colors shadow-[0_10px_24px_-10px_rgba(8,47,73,0.55)]">
          Start free
          <Icon name="arrowRight" size={14} />
        </a>
        <a href="/product/"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-white bg-white/10 backdrop-blur border-2 border-white/40 hover:bg-white/20 transition-colors">
          Tour the product
          <Icon name="arrowUpRight" size={13} />
        </a>
      </div>
      <p class="mt-4 text-[12.5px] text-white/65">
        Free forever for one mailbox · 14-day Growth trial · no credit card.
      </p>
    </div>

    <!-- Dashboard mock — full width inside container, overlaps down -->
    <div class="container-page relative pt-6 md:pt-10 -mb-[140px] md:-mb-[200px] lg:-mb-[240px]">
      <div
        class="relative rounded-[14px] overflow-hidden ring-1 ring-black/[0.08]"
        style="box-shadow: var(--shadow-xl);"
      >
        <DashboardMock />

        <!-- Floating live notification on top of the mock -->
        <div class="hidden md:block absolute bottom-5 right-5 w-[280px] rounded-[10px] bg-white shadow-[0_10px_30px_-10px_rgba(15,23,42,0.35)] ring-1 ring-slate-200 p-3 animate-toast-in" style="animation-delay: 1.2s; animation-fill-mode: backwards;">
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 grid place-items-center shrink-0">
              <Icon name="reply" size={14} class="text-white" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <span class="text-[11.5px] font-semibold text-slate-900">Positive reply</span>
                <span class="text-[10px] text-slate-400 font-mono">just now</span>
              </div>
              <p class="text-[11.5px] text-slate-500 truncate mt-0.5">jenna@northwind.dev — Thursday 10am works for me…</p>
              <div class="mt-1.5 flex items-center gap-1">
                <span class="inline-flex items-center h-4 px-1.5 rounded text-[9px] font-semibold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">positive</span>
                <span class="text-[10px] text-slate-400 font-mono">· assigned to AE</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Spacer for the overlap, then sections
  ============================================================ -->
  <div class="bg-white" style="padding-top: 160px;">

    <!-- ============================================================
         ACTIVITY RIBBON — continuous, scrolling forever
    ============================================================ -->
    <section class="relative overflow-hidden bg-white border-y border-[color:var(--border)]">
      <div class="marquee-mask py-4">
        <div class="marquee-track inline-flex items-center gap-12 whitespace-nowrap">
          {Array.from({ length: 2 }).map(() => (
            <>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="relative inline-flex w-1.5 h-1.5"><span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-60"></span><span class="relative inline-block w-1.5 h-1.5 rounded-full bg-emerald-500"></span></span>
                <span class="font-mono text-foreground/60">12,420</span> mailboxes warming
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)]"></span>
                <span class="font-mono text-foreground/60">142</span> orgs sending now
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                <span class="font-mono text-foreground/60">0.02%</span> mean complaint rate
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)]"></span>
                <span class="font-mono text-foreground/60">96.4%</span> mean inbox placement
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                <span class="font-mono text-foreground/60">99.99%</span> tracking edge uptime
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
              <span class="inline-flex items-center gap-2 text-[12.5px] text-foreground/80">
                <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--brand)]"></span>
                <span class="font-mono text-foreground/60">8</span> dedicated worker regions
              </span>
              <span class="text-[color:var(--border-strong)]">·</span>
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         WARMUP — full-bleed dark panel with continuously
         animating ramp chart (loops forever)
    ============================================================ -->
    <section class="relative isolate overflow-hidden text-white" style="background: linear-gradient(180deg, #0c4a6e 0%, #075985 50%, #0c4a6e 100%);">
      <!-- decorative clouds in the panel -->
      <img src="/backdrops/cloud-3.webp" alt="" aria-hidden="true" class="absolute -top-10 -left-10 w-[420px] opacity-30 pointer-events-none select-none cloud-drift cloud-1" loading="lazy" decoding="async"/>
      <img src="/backdrops/cloud-4.webp" alt="" aria-hidden="true" class="absolute -bottom-10 right-0 w-[360px] opacity-25 pointer-events-none select-none cloud-drift cloud-2" loading="lazy" decoding="async"/>

      <div class="container-page py-24 md:py-32 relative">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-5 feature-card">
            <div class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-white/10 backdrop-blur border border-white/20 mb-6">
              <span class="relative inline-flex w-1.5 h-1.5">
                <span class="absolute inset-0 rounded-full bg-white animate-ping opacity-70"></span>
                <span class="relative inline-block w-1.5 h-1.5 rounded-full bg-white"></span>
              </span>
              <span class="text-[11px] uppercase tracking-[0.16em] text-white/90 font-semibold">Live · warmup</span>
            </div>
            <h2 class="text-[36px] md:text-[56px] font-semibold tracking-[-0.035em] leading-[1.02]">
              Warmup that <span class="italic text-sky-200">never sleeps</span>.
            </h2>
            <p class="mt-6 text-[16.5px] text-white/75 leading-relaxed max-w-md">
              Every mailbox in the premium pool ramps independently, 24/7. Pool selects new partners every cycle; spam-score tracking, verification tokens and recent-partner avoidance keep traffic looking human.
            </p>
            <div class="mt-8 grid grid-cols-2 gap-3 max-w-md">
              {[
                { v: '10 → 40', l: 'Per-day ramp / mailbox' },
                { v: '< 0.03%',  l: 'Premium pool complaints' },
                { v: '7 days',  l: 'Quarantine cooldown' },
                { v: '24 / 7',  l: 'Pool active, always' },
              ].map((s) => (
                <div class="rounded-[10px] bg-white/8 backdrop-blur ring-1 ring-white/15 px-4 py-3.5">
                  <div class="text-[19px] font-semibold tracking-[-0.02em] text-white leading-none">{s.v}</div>
                  <div class="text-[11.5px] text-white/65 mt-1.5">{s.l}</div>
                </div>
              ))}
            </div>
            <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-white hover:text-white/80 group">
              See how warmup works
              <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
            </a>
          </div>

          <div class="lg:col-span-7 feature-card">
            <!-- Animated ramp chart with continuously traveling spark -->
            <div class="relative rounded-[16px] bg-white/[0.04] ring-1 ring-white/12 backdrop-blur p-6 md:p-8">
              <div class="flex items-center justify-between mb-5">
                <div>
                  <div class="text-[10.5px] uppercase tracking-[0.14em] text-white/55 font-medium">Live volume · all premium-pool mailboxes</div>
                  <div class="mt-1 text-[26px] font-semibold tracking-[-0.025em] text-white">
                    <span data-live-counter data-from="487122" data-to="999999" data-tick-min="700" data-tick-max="1800" data-step-min="2" data-step-max="6">487,122</span>
                    <span class="text-[14px] text-white/55 font-normal ml-1">sent today</span>
                  </div>
                </div>
                <div class="inline-flex items-center gap-1.5 px-2.5 h-6 rounded-full text-[10.5px] font-semibold bg-emerald-400/20 text-emerald-300 border border-emerald-400/30">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse-soft"></span>healthy
                </div>
              </div>
              <!-- The chart -->
              <svg viewBox="0 0 720 220" class="w-full h-52" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="warmup-area-dark" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%"   stop-color="rgba(125,211,252,0.55)"/>
                    <stop offset="100%" stop-color="rgba(125,211,252,0)"/>
                  </linearGradient>
                  <linearGradient id="warmup-stroke" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%"   stop-color="#7dd3fc"/>
                    <stop offset="100%" stop-color="#ffffff"/>
                  </linearGradient>
                </defs>
                <!-- gridlines -->
                {[44, 88, 132, 176].map((y) => (
                  <line x1="0" x2="720" y1={y} y2={y} stroke="rgba(255,255,255,0.08)" stroke-dasharray="3 4"/>
                ))}
                {(() => {
                  // Generate a smooth wavy ramp curve
                  const N = 36;
                  const series = Array.from({ length: N }, (_, i) => {
                    const t = i / (N - 1);
                    const base = 15 + t * 75;
                    const wiggle = Math.sin(i * 0.6) * 4 + Math.sin(i * 0.21) * 6;
                    return Math.max(8, Math.min(100, base + wiggle));
                  });
                  const pts = series.map((v, i) => [
                    Math.round((i / (series.length - 1)) * 720),
                    Math.round(220 - ((v - 0) / 110) * 200),
                  ]);
                  const line = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p[0]} ${p[1]}`).join(' ');
                  const area = `${line} L 720 220 L 0 220 Z`;
                  return (
                    <>
                      <path d={area} fill="url(#warmup-area-dark)"/>
                      <path id="warmup-curve" d={line} fill="none" stroke="url(#warmup-stroke)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
                      <!-- continuously traveling spark along the curve -->
                      <circle r="5" fill="#fff" filter="drop-shadow(0 0 8px #7dd3fc)">
                        <animateMotion dur="6s" repeatCount="indefinite">
                          <mpath href="#warmup-curve"/>
                        </animateMotion>
                      </circle>
                    </>
                  );
                })()}
              </svg>
              <!-- Health bands row -->
              <div class="mt-6 grid grid-cols-4 gap-2">
                {[
                  { name: 'Healthy',     v: '12,308', c: 'text-emerald-300', dot: 'bg-emerald-400' },
                  { name: 'Watch',       v: '92',     c: 'text-amber-300',   dot: 'bg-amber-400' },
                  { name: 'Quarantined', v: '14',     c: 'text-orange-300',  dot: 'bg-orange-400' },
                  { name: 'Blocked',     v: '4',      c: 'text-rose-300',    dot: 'bg-rose-400' },
                ].map((b) => (
                  <div class="rounded-[8px] bg-white/5 ring-1 ring-white/10 px-3 py-2.5">
                    <div class="flex items-center gap-1.5">
                      <span class={`w-1.5 h-1.5 rounded-full ${b.dot}`}></span>
                      <span class={`text-[10.5px] uppercase tracking-[0.14em] font-medium ${b.c}`}>{b.name}</span>
                    </div>
                    <div class={`mt-1 text-[16px] font-semibold tabular-nums text-white`}>{b.v}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         INBOX — continuously streaming replies feed
    ============================================================ -->
    <section class="relative bg-white border-t border-[color:var(--border)] overflow-hidden">
      <div class="container-page py-24 md:py-32">
        <div class="grid lg:grid-cols-12 gap-14 items-center">
          <div class="lg:col-span-7 order-2 lg:order-1 feature-card">
            <!-- Continuously scrolling reply stream -->
            <div class="relative rounded-[18px] bg-gradient-to-br from-[color:var(--surface-2)] to-white ring-1 ring-[color:var(--border)] overflow-hidden h-[480px]"
                 style="box-shadow: var(--shadow-xl);">
              <!-- header bar -->
              <div class="px-5 h-12 border-b border-[color:var(--border)] flex items-center gap-3 bg-white">
                <span class="text-[10px] uppercase tracking-[0.14em] text-muted-foreground font-medium">Inbox · live stream</span>
                <div class="h-4 w-px bg-[color:var(--border)]"></div>
                <span class="text-[12.5px] text-foreground/70">12 unread · cross-mailbox</span>
                <div class="ml-auto inline-flex items-center gap-1.5 px-2 h-5 rounded-full text-[10.5px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-soft"></span>connected
                </div>
              </div>

              <!-- Continuously scrolling reply track -->
              <div class="absolute inset-x-0 top-12 bottom-0 overflow-hidden">
                <div class="reply-track flex flex-col gap-3 px-5 py-4 absolute inset-x-0 top-0">
                  {Array.from({ length: 2 }).map(() => (
                    <>
                      {[
                        { who: 'Jenna · Northwind',  domain: 'jenna@northwind.dev', sub: 'Re: quick question on outbound',  body: 'Sure — happy to chat. Thursday 10am ET works for me, send a calendar invite to this address.', tag: 'positive', time: '2s', avatar: 'from-rose-400 to-amber-400' },
                        { who: 'Aman · Spruce',      domain: 'aman@spruce.bio',     sub: 'Re: intro from Maya',             body: 'Maya mentioned you might reach out — let’s set up a call next week.', tag: 'positive', time: '18s', avatar: 'from-violet-400 to-fuchsia-500' },
                        { who: 'Out of office',      domain: 'auto-reply@helia.co', sub: 'OOO until Monday',                body: 'I’m away until Monday. For urgent items contact ops@helia.co.', tag: 'OOO', time: '34s', avatar: 'from-slate-400 to-slate-600' },
                        { who: 'Karim · Foundry',    domain: 'karim@foundry.io',    sub: 'Re: not the right time',          body: 'Thanks for reaching out, not a fit right now. Try us in Q2.', tag: 'negative', time: '1m', avatar: 'from-rose-500 to-pink-600' },
                        { who: 'Lina · Cinder',      domain: 'lina@cinder.app',     sub: 'Re: pricing tier?',               body: 'What does the Grow plan get me on warmup pool size? Quick numbers please.', tag: 'positive', time: '2m', avatar: 'from-emerald-400 to-teal-500' },
                        { who: 'unsubscribe',        domain: 'sam@mosaic.co',       sub: 'Remove me',                       body: 'Please take me off this list — auto-suppressed.', tag: 'unsub', time: '3m', avatar: 'from-zinc-400 to-zinc-600' },
                      ].map((r) => (
                        <div class="rounded-[12px] bg-white ring-1 ring-[color:var(--border)] p-4" style="box-shadow: var(--shadow-sm);">
                          <div class="flex items-start gap-3">
                            <div class={`w-8 h-8 rounded-full bg-gradient-to-br ${r.avatar} shrink-0`}></div>
                            <div class="flex-1 min-w-0">
                              <div class="flex items-center justify-between gap-2">
                                <span class="text-[13px] font-semibold text-heading truncate">{r.who}</span>
                                <span class="text-[10.5px] text-muted-foreground font-mono shrink-0">{r.time}</span>
                              </div>
                              <div class="text-[11.5px] font-mono text-muted-foreground truncate">{r.domain}</div>
                              <div class="mt-1 text-[12.5px] text-foreground truncate"><span class="font-medium">{r.sub}</span></div>
                              <div class="mt-1 text-[12px] text-foreground/70 line-clamp-2">{r.body}</div>
                              <div class="mt-2">
                                <span class={`inline-flex items-center px-1.5 py-0.5 rounded text-[9.5px] font-semibold uppercase tracking-[0.08em] border ${
                                  r.tag === 'positive' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' :
                                  r.tag === 'negative' ? 'bg-rose-50 text-rose-700 border-rose-200' :
                                  r.tag === 'OOO'      ? 'bg-amber-50 text-amber-700 border-amber-200' :
                                                          'bg-slate-100 text-slate-500 border-slate-200'
                                }`}>{r.tag}</span>
                              </div>
                            </div>
                          </div>
                        </div>
                      ))}
                    </>
                  ))}
                </div>
              </div>

              <!-- Fade overlays at top + bottom -->
              <div class="pointer-events-none absolute inset-x-0 top-12 h-12 bg-gradient-to-b from-white to-transparent"></div>
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
            </div>
          </div>

          <div class="lg:col-span-5 order-1 lg:order-2 feature-card">
            <div class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-[color:var(--brand-soft)] ring-1 ring-[color:var(--brand)]/15 mb-6">
              <span class="relative inline-flex w-1.5 h-1.5">
