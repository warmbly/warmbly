---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — parchment base, big ink headline, filled-ink primary
  ============================================================ -->
  <section class="container-page pt-16 md:pt-24 pb-10 md:pb-14">
    <a href="/changelog/" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white border border-border text-[12px] text-foreground/80 shadow-[0_1px_0_rgba(0,0,0,0.04)]">
      <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-foreground text-background">New</span>
      Per-mailbox health bands &amp; auto-quarantine recovery
      <Icon name="arrowRight" size={12} class="text-muted-foreground group-hover:translate-x-0.5 transition-transform" />
    </a>

    <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.035em] leading-[0.98] text-heading max-w-5xl">
      Cold email that actually lands in the inbox.
    </h1>

    <p class="mt-6 text-[17px] md:text-[19px] text-muted-foreground max-w-2xl leading-relaxed">
      Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a href="https://app.warmbly.com/register"
         class="inline-flex h-10 px-4 items-center gap-2 rounded-[8px] text-[14px] font-medium text-background bg-foreground hover:bg-foreground/85 transition-colors">
        Start free
        <Icon name="arrowRight" size={14} />
      </a>
      <a href="/product/"
         class="inline-flex h-10 px-4 items-center gap-2 rounded-[8px] text-[14px] font-medium text-foreground bg-surface-2 hover:bg-surface-3 transition-colors">
        Tour the product
        <Icon name="arrowUpRight" size={13} />
      </a>
    </div>
  </section>

  <!-- ============================================================
       HERO MOCK — wide, short app shell on warm backdrop
  ============================================================ -->
  <section class="container-page pb-20 md:pb-28">
    <div class="relative rounded-[14px] overflow-hidden p-4 sm:p-6 md:p-8 lg:p-10">
      <img
        src="/backdrops/hero.svg"
        alt=""
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none"
      />
      <div
        class="relative rounded-[10px] overflow-hidden ring-1 ring-black/[0.08] max-w-[1180px] mx-auto"
        style="box-shadow: var(--shadow-xl);"
      >
        <DashboardMock />
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 1 — Warmup (text left, mock right, parchment bg)
  ============================================================ -->
  <section class="container-page py-20 md:py-28 border-t border-border">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5">
        <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">Warmup</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.025em] leading-[1.04] text-heading">
          A warmup pool that quarantines before mailbox providers do.
        </h2>
        <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
          Free and premium pools never mix. Spam-score tracking, verification tokens and recent-partner avoidance keep traffic natural. Anything past the watch band gets pulled.
        </p>
        <ul class="mt-7 space-y-3 text-[14.5px]">
          {[
            'Start 10/day, ramp +1/day, ceiling 40/day',
            '≥ 3 invalid tokens / 24h → auto-block',
            'Spam score > 50 → recovery pool',
            'Re-entry requires fresh probation',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-foreground mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
        <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-foreground group">
          See how warmup works
          <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>

      <div class="lg:col-span-7">
        <div class="relative bg-white rounded-[10px] overflow-hidden ring-1 ring-black/[0.06]"
             style="box-shadow: var(--shadow-md);">
          <WarmupMock />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 2 — Inbox (mock left, text right)
  ============================================================ -->
  <section class="border-y border-border">
    <div class="container-page py-20 md:py-28">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-7 order-2 lg:order-1">
          <div class="relative bg-white rounded-[10px] overflow-hidden ring-1 ring-black/[0.06]"
               style="box-shadow: var(--shadow-md);">
            <InboxMock />
          </div>
        </div>
        <div class="lg:col-span-5 order-1 lg:order-2">
          <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">Unified inbox</div>
          <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.025em] leading-[1.04] text-heading">
            One inbox for every mailbox you send from.
          </h2>
          <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
            No more bouncing between Gmail tabs to handle replies from your eight cold mailboxes. Reply detection survives quoted text. OOO and unsubscribe auto-suppress.
          </p>
          <ul class="mt-7 space-y-3 text-[14.5px]">
            {[
              'Positive / negative / OOO / unsub / bounce classification',
              'Cross-mailbox search and saved views',
              'Round-robin or domain-aware assignment',
              'Realtime push for replies, not for opens',
            ].map((l) => (
              <li class="flex items-start gap-2.5">
                <Icon name="check" size={14} class="text-foreground mt-1 shrink-0" />
                <span>{l}</span>
              </li>
            ))}
          </ul>
          <a href="/inbox/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-foreground group">
            Explore the inbox <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURE 3 — Sending engine (text left, mock right)
  ============================================================ -->
  <section class="container-page py-20 md:py-28">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5">
        <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">Sending engine</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.025em] leading-[1.04] text-heading">
          A distributed send plane, not a glorified SMTP relay.
        </h2>
        <p class="mt-5 text-[16px] text-muted-foreground leading-relaxed">
          One worker per machine. Each with its own IP. We add workers before we make any single one carry more weight.
        </p>
        <ul class="mt-7 space-y-3 text-[14.5px]">
          {[
            'Default 50/day cold cap per mailbox',
            'Minimum 10-minute gap between sends',
            'Worker volume = sum of mailbox budgets',
            'Native Gmail · Outlook · SMTP/IMAP',
          ].map((l) => (
            <li class="flex items-start gap-2.5">
              <Icon name="check" size={14} class="text-foreground mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-7">
        <div class="relative bg-white rounded-[10px] overflow-hidden ring-1 ring-black/[0.06]"
             style="box-shadow: var(--shadow-md);">
          <div class="h-10 px-4 border-b border-slate-200 flex items-center gap-2 bg-[#fafafa]">
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>
            <span class="mx-auto inline-flex items-center gap-2 h-6 px-3 rounded bg-white border border-slate-200 text-[11.5px] text-slate-500 font-mono">warmbly.com / workers</span>
            <span class="w-12"></span>
          </div>
          <div class="bg-white">
            <div class="h-12 px-5 border-b border-slate-200 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-[0.14em] text-slate-400 font-medium">Workers</span>
              <div class="h-4 w-px bg-slate-200"></div>
              <span class="text-[12.5px] text-slate-600">4 workers · 128 mailboxes · 5,420 sent today</span>
            </div>
            <div class="divide-y divide-slate-200/60">
              {[
                { name: 'eu-worker-3', region: 'eu-west-1', mb: 38, sent: 1842, ip: '52.18.214.91' },
                { name: 'us-worker-7', region: 'us-east-1', mb: 32, sent: 1456, ip: '54.221.190.17' },
                { name: 'eu-worker-1', region: 'eu-west-1', mb: 30, sent: 1210, ip: '52.18.220.44' },
                { name: 'us-worker-2', region: 'us-east-1', mb: 28, sent:  912, ip: '54.221.196.21' },
              ].map((w) => (
                <div class="px-5 py-3 grid grid-cols-12 items-center text-[12.5px] gap-3">
                  <div class="col-span-4 flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    <span class="font-mono text-slate-900 font-medium">{w.name}</span>
                    <span class="text-slate-400 font-mono text-[11px]">· {w.region}</span>
                  </div>
                  <div class="col-span-2 text-slate-500 font-mono text-[11.5px]">{w.ip}</div>
                  <div class="col-span-2 text-slate-500 tabular-nums">{w.mb} mailboxes</div>
                  <div class="col-span-2 text-slate-500 tabular-nums">{w.sent.toLocaleString()} today</div>
                  <div class="col-span-2">
                    <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
                      <div class="h-full rounded-full bg-slate-900" style={`width:${(w.mb / 50) * 100}%`}></div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMPARE STRIP
  ============================================================ -->
  <section class="border-y border-border bg-surface-2/60">
    <div class="container-page py-20 md:py-24">
      <div class="max-w-3xl">
        <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">Why we’re different</div>
        <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
          We refuse to be the reason your domain ends up on a blocklist.
        </h2>
        <p class="mt-4 text-muted-foreground leading-relaxed max-w-2xl">
          Most cold-email platforms reward you for sending more. We reward you for sending well. Defaults that keep you safe even if you never touch them.
        </p>
      </div>

      <div class="mt-10 rounded-[10px] bg-white overflow-hidden ring-1 ring-border"
           style="box-shadow: var(--shadow-md);">
        <div class="grid grid-cols-12 px-5 md:px-8 h-12 items-center text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground border-b border-border bg-surface-2/60">
          <div class="col-span-4">Setting</div>
          <div class="col-span-4">Warmbly</div>
          <div class="col-span-4">Other cold-email tools</div>
        </div>
        {compare.map(([k, ours, theirs]) => (
          <div class="grid grid-cols-12 px-5 md:px-8 py-4 items-start border-b border-border last:border-b-0 text-[14px]">
            <div class="col-span-4 font-medium text-heading">{k}</div>
            <div class="col-span-4 text-foreground flex items-start gap-2"><Icon name="check" size={14} class="text-foreground mt-1 shrink-0" /><span>{ours}</span></div>
            <div class="col-span-4 text-muted-foreground flex items-start gap-2"><Icon name="warning" size={14} class="text-muted-foreground mt-1 shrink-0" /><span>{theirs}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       BENTO — clean white cards on parchment
  ============================================================ -->
  <section class="container-page py-24 md:py-28">
    <div class="max-w-3xl">
      <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">One platform</div>
      <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
        Warmup, sending, inbox — engineered together.
      </h2>
      <p class="mt-4 text-muted-foreground leading-relaxed max-w-2xl">
        The signal one part collects is the signal the next part acts on.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-6 gap-3">
      <div class="md:col-span-2 rounded-[10px] bg-white ring-1 ring-border p-6 flex flex-col">
        <Icon name="shield" class="text-foreground" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Quarantines on warning, not catastrophe</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Watch band kicks in at 10% spam placement — months before mailbox providers act.
        </p>
        <div class="mt-auto pt-5 grid grid-cols-4 gap-1.5">
          {['Healthy','Watch','Quarantined','Blocked'].map((b, i) => (
            <div class={`rounded-[6px] px-1.5 py-1 text-center text-[10px] font-semibold tracking-wider ring-1 ${
              i === 0 ? 'ring-emerald-200 text-emerald-700 bg-emerald-50' :
              i === 1 ? 'ring-amber-200 text-amber-700 bg-amber-50' :
              i === 2 ? 'ring-orange-200 text-orange-700 bg-orange-50' :
                        'ring-rose-200 text-rose-700 bg-rose-50'}`}>{b}</div>
          ))}
        </div>
      </div>

      <div class="md:col-span-2 rounded-[10px] bg-white ring-1 ring-border p-6 flex flex-col">
        <Icon name="chart" class="text-foreground" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Placement, not open rate</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          We probe inbox placement through the pool, then act on it.
        </p>
        <div class="mt-auto pt-5 flex items-center justify-center">
          <div class="relative w-28 h-28">
            <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e6e5e0" stroke-width="2.6"></circle>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1b1b1b" stroke-width="2.6" stroke-dasharray="96 100" stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-xl font-semibold tracking-tight text-heading">96%</span>
              <span class="text-[9.5px] uppercase tracking-wider text-muted-foreground">inbox</span>
            </div>
          </div>
        </div>
      </div>

      <div class="md:col-span-2 rounded-[10px] bg-white ring-1 ring-border p-6 flex flex-col">
        <Icon name="cpu" class="text-foreground" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Distributed across workers &amp; IPs</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          One worker per machine. Each with its own IP. Migrable on the fly.
        </p>
        <div class="mt-auto pt-5 space-y-2">
          {[
            { name: 'eu-worker-3', pct: 78 },
            { name: 'us-worker-7', pct: 56 },
            { name: 'eu-worker-1', pct: 41 },
          ].map((w) => (
            <div>
              <div class="flex items-center justify-between text-[11.5px] font-mono text-muted-foreground mb-1">
                <span>{w.name}</span><span>{w.pct}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-surface-2 overflow-hidden">
                <div class="h-full rounded-full bg-foreground" style={`width:${w.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="md:col-span-3 rounded-[10px] bg-white ring-1 ring-border p-6">
        <Icon name="workflow" class="text-foreground" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Sequences with branching, A/B and TZ-aware delays</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Up to 12 steps. Variants per step. Business-hour delays by recipient time zone.
        </p>
        <div class="mt-5 grid grid-cols-4 gap-2">
          {[
            { n: 'Step 1', t: 'Intro · plain text',  m: '2 variants' },
            { n: 'Step 2', t: 'Wait 3 biz days',     m: 'if no reply' },
            { n: 'Step 3', t: 'Follow-up · context', m: '4 variants' },
            { n: 'Step 4', t: 'Soft break · 7 days', m: 'if no open' },
          ].map((s) => (
            <div class="rounded-[6px] ring-1 ring-border p-2.5">
              <div class="flex items-center justify-between text-[9.5px] font-mono text-muted-foreground uppercase tracking-wider">
                <span>{s.n}</span><span class="text-foreground/60">{s.m}</span>
              </div>
              <div class="mt-1.5 text-[12px] font-medium text-heading leading-snug">{s.t}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="md:col-span-3 rounded-[10px] bg-white ring-1 ring-border p-6">
        <Icon name="users" class="text-foreground" />
        <h3 class="mt-4 text-[16px] font-semibold tracking-[-0.01em] text-heading">Vetted pool, real reputation surface</h3>
        <p class="mt-2 text-[13.5px] text-muted-foreground leading-relaxed">
          Premium pool diversity across Gmail, Outlook, iCloud, Yahoo and self-hosted IMAP.
        </p>
        <div class="mt-5 grid grid-cols-5 gap-2">
          {[
            { name: 'Gmail',     pct: 46 },
            { name: 'Outlook',   pct: 24 },
            { name: 'Yahoo',     pct: 12 },
            { name: 'iCloud',    pct:  9 },
            { name: 'Self-IMAP', pct:  9 },
          ].map((p) => (
            <div class="rounded-[6px] ring-1 ring-border p-2.5">
              <div class="text-[11px] font-medium text-heading">{p.name}</div>
              <div class="text-[11px] text-muted-foreground font-mono">{p.pct}%</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ============================================================
       PRICING TEASER
  ============================================================ -->
  <section class="container-page py-24 md:py-28">
    <div class="max-w-3xl">
      <div class="text-[11px] uppercase tracking-[0.14em] text-muted-foreground font-medium mb-4">Pricing</div>
      <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
        Per mailbox. Predictable. No deliverability paywall.
      </h2>
      <p class="mt-4 text-muted-foreground leading-relaxed max-w-2xl">
        Warmup, sending, the inbox, analytics and CRM are not separate line items. You pay for the mailboxes you connect.
      </p>
    </div>

    <div class="mt-10 grid md:grid-cols-3 gap-3">
      {[
        { name: 'Free',     price: '$0',  per: 'forever',         href: 'https://app.warmbly.com/register?plan=free',    cta: 'Start free',  highlight: false },
        { name: 'Starter',  price: '$39', per: 'mailbox / month', href: 'https://app.warmbly.com/register?plan=starter', cta: 'Start trial', highlight: false },
        { name: 'Growth',   price: '$79', per: 'mailbox / month', href: 'https://app.warmbly.com/register?plan=growth',  cta: 'Start trial', highlight: true  },
      ].map((p) => (
        <div class={`rounded-[10px] bg-white p-6 ring-1 ${p.highlight ? 'ring-foreground' : 'ring-border'}`}>
          <h3 class="text-[15px] font-semibold text-heading">{p.name}</h3>
          <div class="mt-3 flex items-baseline gap-1.5">
            <span class="text-[32px] font-semibold tracking-[-0.02em] text-heading">{p.price}</span>
            <span class="text-[12.5px] text-muted-foreground">{p.per}</span>
          </div>
          <a href={p.href} class={`mt-5 inline-flex h-10 px-4 items-center justify-center w-full rounded-[8px] text-[13.5px] font-medium ${p.highlight ? 'bg-foreground text-background hover:bg-foreground/85' : 'bg-surface-2 text-foreground hover:bg-surface-3'}`}>
            {p.cta}
          </a>
        </div>
      ))}
    </div>
    <div class="mt-6 text-center">
      <a href="/pricing/" class="inline-flex items-center gap-1.5 text-[13.5px] font-medium text-foreground hover:text-foreground/70">
        See the full comparison <Icon name="arrowRight" size={13} />
      </a>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA — ink slab on parchment
  ============================================================ -->
  <section class="container-page pb-20 md:pb-28">
    <div class="rounded-[14px] bg-foreground text-background p-10 md:p-16 lg:p-20">
      <h2 class="text-[36px] md:text-[56px] lg:text-[64px] font-semibold tracking-[-0.03em] leading-[1.02] max-w-3xl">
        Send cold email like you actually want it to land.
      </h2>
      <p class="mt-5 text-[16px] text-background/70 max-w-xl">
        Connect a mailbox in a minute. Warm it up. Send your first sequence in an afternoon.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="https://app.warmbly.com/register"
           class="inline-flex h-10 px-4 items-center gap-2 rounded-[8px] text-[14px] font-medium bg-background text-foreground hover:bg-background/90">
          Download for free <Icon name="arrowRight" size={14} />
        </a>
        <a href="/learn/"
           class="inline-flex h-10 px-4 items-center rounded-[8px] text-[14px] font-medium border border-background/20 text-background hover:bg-background/10">
          Read the deliverability handbook
        </a>
      </div>
    </div>
  </section>
</Layout>
