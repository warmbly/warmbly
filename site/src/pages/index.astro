  <!-- ============================================================
       Realtime: ticking counters + bar grow + toast in
  ============================================================ -->
  <style is:global>
    @keyframes bar-grow {
      from { width: 0%; }
      to   { width: var(--target, 50%); }
    }
    .animate-bar-grow {
      width: var(--target, 50%);
      animation: bar-grow 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes ring-fill {
      from { stroke-dasharray: 0 100; }
    }
    .animate-ring-fill { animation: ring-fill 1.4s cubic-bezier(0.22, 1, 0.36, 1) both; }

    @keyframes toast-in {
      from { opacity: 0; transform: translateY(10px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .animate-toast-in { animation: toast-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) both; }
  </style>

  <script>
    // Tiny live counter — ticks numbers at irregular intervals to fake
    // realtime activity. ~600 bytes.
    const nf = new Intl.NumberFormat();
    document.querySelectorAll('[data-live-counter]').forEach((el) => {
      let v = parseInt(el.getAttribute('data-from') || '0', 10);
      const max = parseInt(el.getAttribute('data-to') || '99999', 10);
      const tMin = parseInt(el.getAttribute('data-tick-min') || '1200', 10);
      const tMax = parseInt(el.getAttribute('data-tick-max') || '3200', 10);
      const sMin = parseInt(el.getAttribute('data-step-min') || '1', 10);
      const sMax = parseInt(el.getAttribute('data-step-max') || '3', 10);
      const tick = () => {
        v = Math.min(max, v + Math.floor(Math.random() * (sMax - sMin + 1)) + sMin);
        el.textContent = nf.format(v);
        if (v < max) setTimeout(tick, Math.random() * (tMax - tMin) + tMin);
      };
      setTimeout(tick, 400);
    });
  </script>
