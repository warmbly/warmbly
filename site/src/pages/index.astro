---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import DashboardMock from '../components/DashboardMock.astro';
import InboxMock from '../components/InboxMock.astro';
import WarmupMock from '../components/WarmupMock.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import SectionSky from '../components/SectionSky.astro';

const compare = [
  ['Per-mailbox cold cap',     '50 / day default',                 '200 / day if you ask for it'],
  ['Warmup pool quality',      'Vetted, monitored, quarantined',   'Shared with trial mailboxes'],
  ['Reputation reaction',      'Acts on the watch band (10%)',     'Acts on the catastrophe band (80%)'],
  ['Worker concentration',     'Capped by sum of mailbox budgets', 'Flat per-worker ceiling'],
];

// Mirrors web/src/lib/plans.ts — single source of truth.
const plans = [
  {
    name: 'Starter',
    price: '$29',
    annual: '$23',
    cadence: '/ month',
    summary: 'Great for small businesses with a small budget.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=starter',
    highlight: false,
    sendsPerDay: 150,
    features: [
      'Unlimited warmup',
      'Unlimited mailboxes',
      '150 emails / day',
      'Unified inbox + reply detection',
      'Sequences with branching',
    ],
  },
  {
    name: 'Grow',
    price: '$89',
    annual: '$71',
    cadence: '/ month',
    summary: 'Ideal for growing businesses scaling their outreach.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=grow',
    highlight: false,
    sendsPerDay: 3000,
    features: [
      'Unlimited warmup',
      'Unlimited mailboxes',
      '3,000 emails / day',
      'CRM · pipelines · deals · tasks',
      'API & HMAC-signed webhooks',
    ],
  },
  {
    name: 'Business',
    price: '$329',
    annual: '$263',
    cadence: '/ month',
    summary: 'For established teams that need higher limits and advanced features.',
    cta: 'Start free trial',
    href: 'https://app.warmbly.com/register?plan=business',
    highlight: true,
    sendsPerDay: 15000,
    features: [
      'Everything in Grow',
      '15,000 emails / day',
      'Dedicated IPs',
      'Team roles + audit log',
      'Priority support',
    ],
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    annual: 'Custom',
    cadence: 'volume-based',
    summary: 'Large orgs with custom volume and dedicated support.',
    cta: 'Talk to sales',
    href: '/contact/?topic=sales',
    highlight: false,
    sendsPerDay: Infinity,
    features: [
      'Everything in Business',
      '15,000+ emails / day',
      'BYOK encryption · SSO / SAML',
      'Custom data residency',
      'Dedicated CSM',
    ],
  },
];
---
<Layout
  title="Warmbly — cold email that actually lands"
  description="Warmbly is the deliverability platform for cold email. Warm your mailboxes, send at scale, keep your reputation clean across hundreds of mailboxes."
>
  <!-- ============================================================
       HERO — deep sky with drifting clouds, white text,
              dashboard mockup overlaps down into the white section
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-8 md:pb-12 text-center">
      <a href="https://github.com/warmbly/warmbly" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur border border-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-2 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white text-[color:var(--sky-6)]">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" class="mr-1"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5 4.6-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
          Open
        </span>
        The biggest open-source cold-email platform on GitHub
        <Icon name="arrowUpRight" size={12} class="text-white/80 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" />
      </a>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[76px] lg:text-[88px] font-semibold tracking-[-0.04em] leading-[0.96] text-white max-w-5xl mx-auto">
        Cold email that <span class="italic font-medium text-sky-200">actually</span> lands in the inbox.
      </h1>

      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Warmbly warms your mailboxes, distributes sending across workers and IPs, and watches reputation in real time — so the cold campaign you run on Monday is still landing on Friday.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-[color:var(--sky-6)] bg-white hover:bg-white/95 transition-colors shadow-[0_10px_24px_-10px_rgba(8,47,73,0.55)]">
          Start free
          <Icon name="arrowRight" size={14} />
        </a>
        <a href="/product/"
           class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-medium text-white bg-white/10 backdrop-blur border-2 border-white/40 hover:bg-white/20 transition-colors">
          Tour the product
          <Icon name="arrowUpRight" size={13} />
        </a>
      </div>
      <p class="mt-4 text-[12.5px] text-white/65">
        Free forever for one mailbox · 14-day Growth trial · no credit card.
      </p>
    </div>

    <!-- Dashboard mock — full width inside container, overlaps down -->
    <div class="container-page relative pt-6 md:pt-10 -mb-[140px] md:-mb-[200px] lg:-mb-[240px]">
      <div
        class="relative rounded-[14px] overflow-hidden ring-1 ring-black/[0.08]"
        style="box-shadow: var(--shadow-xl);"
      >
        <DashboardMock />

        <!-- Floating live notification on top of the mock -->
        <div class="hidden md:block absolute bottom-5 right-5 w-[280px] rounded-[10px] bg-white shadow-[0_10px_30px_-10px_rgba(15,23,42,0.35)] ring-1 ring-slate-200 p-3 animate-toast-in" style="animation-delay: 1.2s; animation-fill-mode: backwards;">
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 grid place-items-center shrink-0">
              <Icon name="reply" size={14} class="text-white" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between">
                <span class="text-[11.5px] font-semibold text-slate-900">Positive reply</span>
                <span class="text-[10px] text-slate-400 font-mono">just now</span>
              </div>
              <p class="text-[11.5px] text-slate-500 truncate mt-0.5">jenna@northwind.dev — Thursday 10am works for me…</p>
              <div class="mt-1.5 flex items-center gap-1">
                <span class="inline-flex items-center h-4 px-1.5 rounded text-[9px] font-semibold uppercase tracking-wider bg-emerald-50 text-emerald-700 border border-emerald-100">positive</span>
                <span class="text-[10px] text-slate-400 font-mono">· assigned to AE</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Spacer for the overlap, then sections
  ============================================================ -->
  <div class="bg-white" style="padding-top: 160px;">

    <!-- ============================================================
         LIVE METRICS STRIP — animated numbers, no fake reviews
    ============================================================ -->
    <section class="container-page pt-4 pb-16 md:pb-24">
      <div class="grid grid-cols-2 md:grid-cols-4 rounded-[14px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden"
           style="box-shadow: var(--shadow-sm);">
        {[
          { eyebrow: 'Today', value: '5,420', counter: { from: 5380, to: 6400 }, label: 'Sends · all workers', tone: 'bg-[color:var(--brand)]' },
          { eyebrow: 'Warming now', value: '12,418', counter: { from: 12390, to: 12480 }, label: 'Mailboxes in premium pool', tone: 'bg-emerald-500' },
          { eyebrow: 'Mean placement', value: '96.4%', label: 'Inbox · last 14 days', tone: 'bg-emerald-500' },
          { eyebrow: 'Mean complaint', value: '0.02%', label: 'Below Google’s 0.10% threshold', tone: 'bg-emerald-500' },
        ].map((s, i) => (
          <div class={`metric-cell px-5 py-5 md:px-6 md:py-6 ${i < 3 ? 'md:border-r border-[color:var(--border)]' : ''} ${i < 2 ? 'border-b md:border-b-0 border-[color:var(--border)]' : ''}`}>
            <div class="flex items-center gap-1.5">
              <span class={`relative inline-flex w-1.5 h-1.5 rounded-full ${s.tone}`}>
                <span class={`absolute inset-0 rounded-full ${s.tone} animate-ping opacity-40`}></span>
              </span>
              <span class="text-[10.5px] uppercase tracking-[0.14em] text-muted-foreground font-semibold">{s.eyebrow}</span>
            </div>
            <div class="mt-3 text-[28px] md:text-[34px] font-semibold tracking-[-0.025em] text-heading leading-none">
              {s.counter ? (
                <span data-live-counter
                      data-from={s.counter.from}
                      data-to={s.counter.to}
                      data-tick-min="900"
                      data-tick-max="2400"
                      data-step-min="1"
                      data-step-max="3">{s.value}</span>
              ) : s.value}
            </div>
            <div class="mt-2 text-[12px] text-muted-foreground">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================
         HOW IT WORKS — 4 numbered steps, connected flow
    ============================================================ -->
    <section class="border-t border-[color:var(--border)]" style="background: var(--surface-2);">
      <div class="container-page py-20 md:py-28">
        <div class="max-w-3xl">
          <div class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold mb-4">How it works</div>
          <h2 class="text-[32px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
            From connected mailbox to a campaign that lands — in an afternoon.
          </h2>
        </div>

        <div class="mt-14 grid md:grid-cols-4 gap-4 relative">
          <!-- Connecting line behind the steps -->
          <div class="hidden md:block absolute top-7 left-[12%] right-[12%] h-px" style="background: linear-gradient(to right, transparent, var(--brand) 20%, var(--brand) 80%, transparent);"></div>

          {[
            { n: '01', title: 'Connect',  body: 'OAuth a mailbox in seconds — Google, Microsoft, or any SMTP/IMAP.', icon: 'mail' },
            { n: '02', title: 'Warm up',  body: 'Pool selects vetted partners, ramps your volume +1/day, watches reputation.', icon: 'flame' },
            { n: '03', title: 'Sequence', body: 'Build steps with branching, A/B variants, business-hour delays.', icon: 'workflow' },
            { n: '04', title: 'Send & reply', body: 'Distribute across workers, classify every reply, route to the right human.', icon: 'send' },
          ].map((s) => (
            <div class="step-card relative bg-white rounded-[14px] p-6 ring-1 ring-[color:var(--border)] lift-on-hover" style="box-shadow: var(--shadow-sm);">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-14 h-14 rounded-full bg-[color:var(--brand)] text-white grid place-items-center text-[16px] font-semibold tracking-tight ring-4 ring-white">
                  {s.n}
                </div>
                <Icon name={s.icon} class="text-[color:var(--brand)] ml-auto" size={18} />
              </div>
              <h3 class="text-[17px] font-semibold tracking-[-0.01em] text-heading">{s.title}</h3>
              <p class="mt-1.5 text-[13.5px] text-foreground/70 leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE — Warmup
         Big two-up: text block + animated ramp chart with
         live KPI badges floating over it
    ============================================================ -->
    <section class="container-page py-20 md:py-28">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-5 lg:sticky lg:top-24 self-start feature-card">
          <div class="inline-flex items-center gap-2 h-6 px-2.5 rounded-full bg-[color:var(--brand-soft)] ring-1 ring-[color:var(--brand)]/15 mb-5">
            <span class="relative inline-flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-[color:var(--brand)] animate-ping opacity-60"></span>
              <span class="relative inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--brand)]"></span>
            </span>
            <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Warmup</span>
          </div>
          <h2 class="text-[34px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
            A warmup pool that quarantines before mailbox providers do.
          </h2>
          <p class="mt-5 text-[16px] text-foreground/75 leading-relaxed">
            Free and premium pools never mix. Spam-score tracking, verification tokens and recent-partner avoidance keep traffic natural. Anything past the watch band gets pulled.
          </p>
          <div class="mt-8 grid grid-cols-2 gap-3">
            {[
              { v: '10 → 40', l: 'Per-day ramp · /mailbox' },
              { v: '< 0.03%',  l: 'Premium pool complaints' },
              { v: '7d',       l: 'Quarantine cooldown' },
              { v: '5 health', l: 'Bands · healthy → blocked' },
            ].map((s) => (
              <div class="rounded-[10px] bg-white ring-1 ring-[color:var(--border)] px-4 py-3.5">
                <div class="text-[20px] font-semibold tracking-[-0.02em] text-heading leading-none">{s.v}</div>
                <div class="text-[11.5px] text-muted-foreground mt-1.5">{s.l}</div>
              </div>
            ))}
          </div>
          <a href="/warmup/" class="mt-8 inline-flex items-center gap-1.5 text-[14px] font-medium text-[color:var(--brand)] hover:text-[color:var(--brand-strong)] group">
            See how warmup works
            <Icon name="arrowRight" size={13} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>

        <div class="lg:col-span-7 feature-card">
          <div class="relative rounded-[20px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden"
               style="box-shadow: var(--shadow-xl);">
            <!-- Header -->
            <div class="px-6 py-5 border-b border-[color:var(--border)] flex items-center gap-3">
              <div class="flex items-center gap-2">
                <span class="text-[10px] uppercase tracking-[0.14em] text-muted-foreground font-medium">Premium pool</span>
                <span class="inline-flex items-center gap-1.5 px-2 h-5 rounded-full text-[10px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse-soft"></span>healthy
                </span>
              </div>
              <div class="ml-auto text-[11px] font-mono text-muted-foreground">
                <span data-live-counter data-from="12418" data-to="12480" data-tick-min="2400" data-tick-max="4800" data-step-min="1" data-step-max="2">12,418</span> mailboxes warming
              </div>
            </div>
            <!-- KPI strip -->
            <div class="grid grid-cols-3 border-b border-[color:var(--border)]">
              {[
                { k: 'Complaint',   v: '0.02%', sub: '< 0.03 warn',   tone: 'text-emerald-700' },
                { k: 'Bounces',     v: '0.7%',  sub: '< 1.0 warn',    tone: 'text-emerald-700' },
                { k: 'Spam place.', v: '3.1%',  sub: '< 10 watch',    tone: 'text-amber-700' },
              ].map((m, i) => (
                <div class={`px-5 py-4 ${i < 2 ? 'border-r border-[color:var(--border)]' : ''}`}>
                  <div class="text-[10.5px] uppercase tracking-[0.14em] text-muted-foreground font-medium">{m.k}</div>
                  <div class={`mt-1.5 text-[24px] font-semibold tracking-[-0.02em] leading-none ${m.tone}`}>{m.v}</div>
                  <div class="mt-1.5 text-[10.5px] font-mono text-muted-foreground">{m.sub}</div>
                </div>
              ))}
            </div>

            <!-- Big ramp chart -->
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <span class="text-[10.5px] uppercase tracking-[0.14em] text-muted-foreground font-medium">Daily warmup volume · 21 days</span>
                <span class="text-[11px] font-mono text-muted-foreground">10 → 40 / day · per mailbox</span>
              </div>
              <svg viewBox="0 0 600 200" class="w-full h-44">
                <defs>
                  <linearGradient id="warmup-area" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%"   stop-color="rgba(2,132,199,0.35)"/>
                    <stop offset="100%" stop-color="rgba(2,132,199,0)"/>
                  </linearGradient>
                </defs>
                {/* gridlines */}
                {[0, 50, 100, 150, 200].map((y) => (
                  <line x1="0" x2="600" y1={y} y2={y} stroke="#e2e8f0" stroke-dasharray="3 4"/>
                ))}
                {(() => {
                  const series = [10,11,12,14,16,18,20,22,25,27,30,32,33,35,36,37,38,38,39,40,40];
                  const pts = series.map((v, i) => [
                    Math.round((i / (series.length - 1)) * 600),
                    Math.round(200 - ((v - 8) / 36) * 180),
                  ]);
                  const line = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p[0]} ${p[1]}`).join(' ');
                  const area = `${line} L 600 200 L 0 200 Z`;
                  return (
                    <>
                      <path d={area} fill="url(#warmup-area)"/>
                      <path d={line} fill="none" stroke="var(--brand)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" class="sparkline-path"/>
                      {pts.map((p, i) => (
                        <circle cx={p[0]} cy={p[1]} r={i === pts.length - 1 ? 4 : 0} fill="white" stroke="var(--brand)" stroke-width="2.4"/>
                      ))}
                    </>
                  );
                })()}
              </svg>
              <div class="mt-3 flex items-center justify-between text-[10.5px] font-mono text-muted-foreground">
                <span>day 1</span><span>day 21</span>
              </div>
            </div>

            <!-- Health bands strip -->
            <div class="grid grid-cols-4 border-t border-[color:var(--border)]">
              {[
                { name: 'Healthy',     v: '12,308', bg: 'bg-emerald-50', text: 'text-emerald-700' },
                { name: 'Watch',       v: '92',     bg: 'bg-amber-50',   text: 'text-amber-700' },
                { name: 'Quarantined', v: '14',     bg: 'bg-orange-50',  text: 'text-orange-700' },
                { name: 'Blocked',     v: '4',      bg: 'bg-rose-50',    text: 'text-rose-700' },
              ].map((b, i) => (
                <div class={`px-4 py-3 ${b.bg} ${i < 3 ? 'border-r border-[color:var(--border)]' : ''}`}>
                  <div class={`text-[10.5px] uppercase tracking-[0.14em] font-medium ${b.text}`}>{b.name}</div>
                  <div class={`mt-1 text-[16px] font-semibold tabular-nums ${b.text}`}>{b.v}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FEATURE — Unified inbox (sky-themed band)
         Layered reply cards stack, classified by reply type
    ============================================================ -->
    <section class="border-y border-[color:var(--border)] relative overflow-hidden" style="background: linear-gradient(180deg, #f5f8fc 0%, #ffffff 100%);">
      <!-- decorative cloud silhouette top-right -->
      <img src="/backdrops/cloud-4.webp" alt="" aria-hidden="true" class="absolute -top-12 right-0 w-[420px] opacity-50 pointer-events-none select-none" loading="lazy" decoding="async"/>

      <div class="container-page py-20 md:py-28 relative">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          <div class="lg:col-span-5 feature-card">
            <div class="inline-flex items-center gap-2 h-6 px-2.5 rounded-full bg-[color:var(--brand-soft)] ring-1 ring-[color:var(--brand)]/15 mb-5">
              <span class="relative inline-flex w-1.5 h-1.5">
                <span class="absolute inset-0 rounded-full bg-[color:var(--brand)] animate-ping opacity-60"></span>
                <span class="relative inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--brand)]"></span>
              </span>
              <span class="text-[11px] uppercase tracking-[0.16em] text-[color:var(--brand)] font-semibold">Unified inbox</span>
            </div>
            <h2 class="text-[34px] md:text-[48px] font-semibold tracking-[-0.03em] leading-[1.04] text-heading">
              Every reply, classified the second it lands.
            </h2>
            <p class="mt-5 text-[16px] text-foreground/75 leading-relaxed">
              Cross-mailbox, cross-team. Reply detection survives quoted text, signatures and forwarded threads. OOO and unsubscribe auto-suppress.
            </p>
            <!-- Reply distribution donut + legend -->
            <div class="mt-8 rounded-[12px] bg-white ring-1 ring-[color:var(--border)] p-5 flex items-center gap-5"
                 style="box-shadow: var(--shadow-sm);">
              <svg viewBox="0 0 36 36" class="w-24 h-24 -rotate-90 shrink-0">
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#16a34a" stroke-width="3" stroke-dasharray="42 100"/>
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#dc2626" stroke-width="3" stroke-dasharray="14 100" stroke-dashoffset="-42"/>
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#d97706" stroke-width="3" stroke-dasharray="22 100" stroke-dashoffset="-56"/>
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="#64748b" stroke-width="3" stroke-dasharray="22 100" stroke-dashoffset="-78"/>
              </svg>
              <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-[12.5px] flex-1">
                <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-emerald-600"></span><span class="text-foreground">Positive</span><span class="ml-auto font-mono text-muted-foreground">42%</span></div>
                <div class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-rose-600"></span><span class="text-foreground">Negative</span><span class="ml-auto font-mono text-muted-foreground">14%</span></div>
