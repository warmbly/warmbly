---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';
---
<Layout
  title="API & Webhooks — Warmbly"
  description="Programmatic control over mailboxes, campaigns and contacts. HMAC-signed webhooks for every meaningful event."
>
  <PageHero
    eyebrow="Developers"
    title="A boring, predictable API. The way you want it."
    description="REST, JSON, idempotency keys, HMAC-signed webhooks. Rate limits surfaced in headers. Per-key scopes and rotation built in."
  />

  <Section>
    <SectionHead
      eyebrow="API"
      title="Capabilities"
    />
    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        ['Mailboxes', 'List, create, update, pause, delete. Trigger warmup re-evaluation.'],
        ['Sequences', 'CRUD sequences, steps, variants. Trigger campaign starts.'],
        ['Contacts',  'CRUD contacts. Bulk import. Suppression list management.'],
        ['Events',    'Replay-able event stream. Filter by type or campaign.'],
        ['Pipelines & deals', 'Read and write pipelines, deals, stages, tasks.'],
        ['Health',    'Read mailbox, pool and worker health snapshots.'],
      ].map(([t, b]) => (
        <Card>
          <h3 class="text-[15px] font-semibold">{t}</h3>
          <p class="mt-1.5 text-[13.5px] text-muted-foreground leading-relaxed">{b}</p>
        </Card>
      ))}
    </div>
  </Section>

  <Section variant="muted">
    <SectionHead
      eyebrow="Webhooks"
      title="HMAC-signed. Replay-safe. Per-key scopes."
    />
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      <Card padded={false}>
        <div class="px-5 py-3 border-b border-border text-[12.5px] uppercase tracking-wider text-muted-foreground font-semibold">Sample event payload</div>
        <pre class="overflow-x-auto text-[12.5px] font-mono leading-relaxed text-foreground/85 p-5"><code>{`{
  "id": "evt_01HQX9...",
  "type": "reply.received",
  "created_at": "2026-05-25T16:01:33Z",
  "workspace_id": "ws_acme",
  "data": {
    "mailbox_id": "mbx_01HQX...",
    "sequence_id": "seq_01HQX...",
    "contact_id":  "ct_01HQX...",
    "classification": "positive",
    "thread_id": "th_01HQX...",
    "preview": "Sure, send over a calendar invite for Thursday."
  },
  "idempotency_key": "reply:th_01HQX..."
}`}</code></pre>
      </Card>
      <Card>
        <h3 class="text-[15px] font-semibold">Why our webhooks are different</h3>
        <ul class="mt-3 space-y-2">
          {[
            'Every event has an idempotency key — duplicate deliveries are safe to drop.',
            'Per-endpoint HMAC secret with rotation through the dashboard.',
            'Configurable retry: 5 attempts with exponential backoff, dead-letter on the dashboard.',
            'Filter what you receive by event type, sequence, or mailbox.',
            'Signed query parameter on every URL for path-level verification.',
          ].map((l) => (
            <li class="flex items-start gap-2 text-[13.5px] text-foreground/85">
              <Icon name="check" size={13} class="text-success mt-1 shrink-0" />
              <span>{l}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </Section>

  <Section>
    <SectionHead
      eyebrow="SDKs"
      title="Officially supported, lazily generated."
    />
    <div class="mt-10 grid md:grid-cols-3 gap-4">
      {[
        ['TypeScript', '@warmbly/sdk', 'Type-safe client generated from the same OpenAPI spec the docs render from.'],
        ['Python', 'warmbly', 'Async-first. Built on httpx. Same API surface as TypeScript.'],
        ['Go', 'github.com/warmbly/warmbly-go', 'Idiomatic Go client. Context-aware. No reflection magic.'],
      ].map(([lang, pkg, body]) => (
        <Card>
          <h3 class="text-[15px] font-semibold">{lang}</h3>
          <p class="text-[12.5px] text-muted-foreground mt-1"><span class="kbd">{pkg}</span></p>
          <p class="mt-3 text-[13.5px] text-muted-foreground leading-relaxed">{body}</p>
        </Card>
      ))}
    </div>
  </Section>

  <CTA primaryLabel="Get an API key" primaryHref="https://app.warmbly.com/settings/api-keys" />
</Layout>
