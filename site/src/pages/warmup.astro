---
import Layout from '../layouts/Layout.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

// All numbers below come from the Warmbly codebase / CLAUDE.md
// (internal/scheduler/warmup_scheduler.go, internal/repository/pg_warmup.go,
// internal/infrastructure/db/migrations/000010_warmup_pools.up.sql).

const defaults = [
  { k: 'Starting volume',     v: '10 / day',       why: 'Low enough to read as normal individual activity to any provider.' },
  { k: 'Daily ramp',          v: '+1 / day',       why: 'Aggressive ramps trip volume-anomaly heuristics on the receiver.' },
  { k: 'Volume ceiling',      v: '40 / day',       why: 'Maintains reputation without crowding the cold-campaign budget.' },
  { k: 'Recent-partner gap',  v: '7 days',         why: 'Stops two mailboxes from forming a degenerate warmup pair.' },
  { k: 'Spam-score block',    v: '> 50',           why: 'Removes proactively, before mailbox providers act.' },
  { k: 'Invalid token block', v: '≥ 3 / 24h',      why: 'A flurry of malformed tokens is the token-forgery signature.' },
  { k: 'Re-entry probation',  v: '20 deliveries',  why: 'Enough fresh data to confirm health, not just dormancy.' },
];

// Bands from CLAUDE.md "Recommended internal policy for shared paid pools".
const bands = [
  { name: 'Healthy',     tone: 'emerald', spam: '< 10%',  complaint: '< 0.03%', bounce: '< 1%',   action: 'Default state. Continue ramp.' },
  { name: 'Watch',       tone: 'amber',   spam: '≥ 10%',  complaint: '≥ 0.03%', bounce: '—',      action: 'Lower volume, increase spacing.' },
  { name: 'Quarantined', tone: 'rose',    spam: '≥ 20%',  complaint: '≥ 0.10%', bounce: '≥ 5%',   action: 'Removed from shared paid pool for 7 days.' },
  { name: 'Blocked',     tone: 'rose',    spam: '≥ 40%',  complaint: '≥ 0.30%', bounce: '≥ 10%',  action: '30-day block. Review required for re-entry.' },
];

const toneClass = (t: string) => {
  if (t === 'emerald') return { dot: 'bg-emerald-500', chip: 'bg-emerald-50 text-emerald-700' };
  if (t === 'amber')   return { dot: 'bg-amber-500',   chip: 'bg-amber-50 text-amber-700' };
  return { dot: 'bg-rose-500', chip: 'bg-rose-50 text-rose-700' };
};

// Pool model from migration 000010 + pg_warmup.go.
const pools = [
  { name: 'Free pool',     when: 'Free trial',           features: ['Trial mailboxes only', 'Same quarantine thresholds', 'Lower starting volume'] },
  { name: 'Premium pool',  when: 'Starter, Grow, Business', features: ['Vetted mailboxes only', 'Stricter quarantine policy', 'Recovery pool for cooldown senders'], featured: true },
  { name: 'Dedicated',     when: 'Enterprise',           features: ['Isolated worker + IP', 'Still participates in premium pool', 'Per-mailbox reputation, not infrastructure shortcut'] },
];

const faq = [
  ['How long does warmup take?', 'Plan on 3 to 6 weeks for a brand new mailbox to reach a stable warmed state. We ramp +1 / day from a 10 / day start with a 40 / day ceiling.'],
  ['Do free and premium pools mix?', 'No. Free pool mailboxes never silently appear in the premium pool. Dedicated workers still participate in the premium pool by default.'],
  ['What triggers quarantine?', '3 or more invalid warmup tokens in 24h, spam score above 50, complaint rate over 0.10%, or spam-folder placement over 20% on at least 20 deliveries in 7 days.'],
  ['Can I keep warming after campaigns start?', 'Yes, and you should. Warmup runs in parallel with cold sending so any reputation dip is caught and offset before campaigns hit it.'],
];
---
<Layout
  title="Warmup · Warmbly"
  description="Reputation-safe warmup pools. Verification tokens, gradual ramps, and quarantine bands stricter than provider enforcement."
>
  <!-- ============================================================
       HERO — HeroAtmosphere, same as home and pricing
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-40 md:pb-52 text-center">
      <div class="inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white" style="color:#0369a1;">
          Warmup
        </span>
        Reputation-safe pools, on every paid plan
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        Warmup that earns<br/>reputation.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Mailboxes ramp gradually inside the premium pool. Verification tokens distinguish real warmup from forged traffic. Bands quarantine before mailbox providers act.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Start warming</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="/learn/email-warmup/" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          How warmup works
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       THE RAMP CURVE · unique to warmup
       A real SVG line chart showing the actual 30-day ramp.
  ============================================================ -->
  <section class="relative -mt-32 md:-mt-40 pb-16 md:pb-24 z-10">
    <div class="container-page">
      <div class="rounded-[18px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden shadow-[0_30px_60px_-20px_rgba(2,32,71,0.25),0_8px_24px_-10px_rgba(15,23,42,0.06)]">
        <div class="px-7 py-5 border-b border-[color:var(--border)] flex flex-wrap items-baseline justify-between gap-3">
          <div>
            <div class="text-[10.5px] uppercase tracking-[0.18em] font-mono text-[#0284c7]">The ramp</div>
            <div class="mt-1 text-[16px] font-semibold text-heading">Day 1 to ceiling, one mailbox.</div>
          </div>
          <div class="flex items-center gap-6 text-[11.5px] font-mono text-muted-foreground">
            <span class="inline-flex items-center gap-1.5"><span class="w-2 h-px bg-[#0284c7]"></span>volume / day</span>
            <span class="inline-flex items-center gap-1.5"><span class="w-2 h-px bg-foreground/30" style="border-top:1px dashed"></span>ceiling</span>
          </div>
        </div>

        <div class="px-7 pt-6 pb-5">
          <svg viewBox="0 0 720 220" class="w-full h-[220px]" preserveAspectRatio="none" aria-label="Ramp curve from 10/day to 40/day over 30 days">
            <defs>
              <linearGradient id="rampFill" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#0284c7" stop-opacity="0.18"/>
                <stop offset="100%" stop-color="#0284c7" stop-opacity="0"/>
              </linearGradient>
            </defs>

            <!-- Horizontal grid -->
            {[10, 20, 30, 40].map((v) => (
              <g>
                <line x1="40" x2="700" y1={200 - (v / 50) * 180} y2={200 - (v / 50) * 180} stroke="#e6ebf2" stroke-width="1"/>
                <text x="32" y={200 - (v / 50) * 180 + 4} text-anchor="end" fill="#94a3b8" font-size="10" font-family="ui-monospace,monospace">{v}</text>
              </g>
            ))}

            <!-- Ceiling line (dashed) -->
            <line x1="40" x2="700" y1={200 - (40 / 50) * 180} y2={200 - (40 / 50) * 180} stroke="#0c4a6e" stroke-width="1" stroke-dasharray="4 4" opacity="0.4"/>

            <!-- Ramp polygon -->
            {(() => {
              const pts = [];
              for (let day = 0; day <= 30; day++) {
                const v = Math.min(10 + day, 40);
                const x = 40 + (day / 30) * 660;
                const y = 200 - (v / 50) * 180;
                pts.push(`${x},${y}`);
              }
              return (
                <>
                  <polygon points={`40,200 ${pts.join(' ')} 700,200`} fill="url(#rampFill)"/>
                  <polyline points={pts.join(' ')} fill="none" stroke="#0284c7" stroke-width="2"/>
                </>
              );
            })()}

            <!-- Day-1 marker -->
            <g>
              <circle cx="40" cy={200 - (10 / 50) * 180} r="4" fill="#0284c7" stroke="white" stroke-width="2"/>
              <text x="48" y={200 - (10 / 50) * 180 - 8} fill="#0369a1" font-size="11" font-family="ui-monospace,monospace" font-weight="600">Day 1 · 10</text>
            </g>

            <!-- Ceiling reached marker -->
            <g>
              <circle cx={40 + (30 / 30) * 660} cy={200 - (40 / 50) * 180} r="4" fill="#0284c7" stroke="white" stroke-width="2"/>
              <text x={40 + (30 / 30) * 660 - 8} y={200 - (40 / 50) * 180 - 8} text-anchor="end" fill="#0369a1" font-size="11" font-family="ui-monospace,monospace" font-weight="600">Day 30 · 40</text>
            </g>

            <!-- X-axis labels -->
            {[0, 7, 14, 21, 30].map((d) => (
              <text x={40 + (d / 30) * 660} y="218" text-anchor="middle" fill="#94a3b8" font-size="10" font-family="ui-monospace,monospace">D{d}</text>
            ))}
          </svg>
        </div>

        <div class="px-7 py-3 border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/60 flex flex-wrap items-center justify-between gap-x-6 gap-y-1 text-[11.5px] font-mono text-muted-foreground">
          <div class="flex items-center gap-5">
            <span><span class="text-heading font-semibold text-[13px] mr-1">10/d</span>start</span>
            <span><span class="text-heading font-semibold text-[13px] mr-1">+1/d</span>ramp</span>
            <span><span class="text-heading font-semibold text-[13px] mr-1">40/d</span>ceiling</span>
            <span><span class="text-heading font-semibold text-[13px] mr-1">30d</span>to ceiling</span>
          </div>
          <span>Business-hour scheduling · recipient TZ</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHAT WARMUP DOES — editorial split, real product behavior
  ============================================================ -->
  <section class="border-y border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-20 md:py-28">
    <div class="container-page grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start">
      <div class="lg:sticky lg:top-24" style="align-self: start;">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">What warmup does</div>
        <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.025em] leading-[1.06] text-heading">
          One loop. One mailbox. One day.
        </h2>
        <p class="mt-4 text-[15px] text-foreground/70 leading-relaxed max-w-md">
          Warmup is not a black box. Every step has a defined input and output, and every quarantine has a reason you can read.
        </p>
        <a href="/learn/warmup-pools/" class="mt-6 inline-flex items-center gap-1.5 text-[13.5px] font-medium text-[#0369a1] hover:text-[#075985]">
          Read about warmup pools
          <Icon name="arrowRight" size={12} />
        </a>
      </div>

      <ol class="divide-y divide-[color:var(--border)] border-y border-[color:var(--border)]">
        {[
          { n: '01', t: 'Pool member selection',  b: 'A partner mailbox is drawn from the same pool the sender belongs to. Recent partners are excluded for 7 days to prevent degenerate pairs.' },
          { n: '02', t: 'Verification token',     b: 'A signed token is embedded in the message body. Receivers extract and validate it on classification. Missing or replayed tokens count as suspicious.' },
          { n: '03', t: 'Send through worker',    b: 'The mailbox\'s assigned worker dispatches the message during the recipient\'s business hours, with spacing that matches human typing cadence.' },
          { n: '04', t: 'Partner classification', b: 'The receiving mailbox classifies the message as inbox, Promotions, or spam and reports the result back along with the token.' },
          { n: '05', t: 'Score update',           b: 'Placement, token validity, and any complaint signals feed the per-mailbox rolling spam score. Bands transition on the resulting score.' },
        ].map((s) => (
          <li class="grid grid-cols-[44px_1fr] gap-4 py-5 items-baseline">
            <span class="font-mono text-[12px] text-[#0284c7] font-semibold">{s.n}</span>
            <div>
              <div class="text-[15.5px] font-semibold text-heading">{s.t}</div>
              <p class="mt-1.5 text-[14px] text-foreground/70 leading-relaxed">{s.b}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============================================================
       HEALTH BANDS — full comparison table (pricing matrix pattern)
  ============================================================ -->
  <section class="py-20 md:py-28">
    <div class="container-page">
      <div class="max-w-2xl mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Health bands</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
          Bands that act before providers do.
        </h2>
        <p class="mt-4 text-[15.5px] text-foreground/70 leading-relaxed">
          These thresholds are stricter than Google's and Amazon SES's published enforcement points. We pull a mailbox out of the shared pool weeks before it would get a public complaint.
        </p>
      </div>

      <div class="overflow-x-auto rounded-[14px] ring-1 ring-[color:var(--border)] bg-white shadow-[0_24px_48px_-20px_rgba(15,23,42,0.12),0_4px_12px_-6px_rgba(15,23,42,0.05)]">
        <table class="w-full min-w-[820px] text-[13.5px] border-separate border-spacing-0">
          <thead>
            <tr class="bg-[color:var(--surface-1)] border-b border-[color:var(--border)]">
              <th class="text-left px-5 py-4">
                <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground font-medium">Band</span>
              </th>
              <th class="text-left px-5 py-4">
                <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground font-medium">Spam placement</span>
              </th>
              <th class="text-left px-5 py-4">
                <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground font-medium">Complaint rate</span>
              </th>
              <th class="text-left px-5 py-4">
                <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground font-medium">Bounce rate</span>
              </th>
              <th class="text-left px-5 py-4">
                <span class="text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground font-medium">Action</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {bands.map((b) => {
              const t = toneClass(b.tone);
              return (
                <tr class="border-t border-[color:var(--border)]">
                  <td class="px-5 py-4">
                    <span class={`inline-flex items-center gap-1.5 h-6 px-2 rounded text-[12px] font-medium font-mono ${t.chip}`}>
                      <span class={`w-1.5 h-1.5 rounded-full ${t.dot}`}></span>
                      {b.name}
                    </span>
                  </td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.spam}</td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.complaint}</td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.bounce}</td>
                  <td class="px-5 py-4 text-foreground/75">{b.action}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <p class="mt-4 text-[12.5px] text-muted-foreground italic">
        Spam-placement band requires at least 20 warmup deliveries in the past 7 days; complaint band requires at least 100 delivered messages in the past 30 days.
      </p>
    </div>
  </section>

  <!-- ============================================================
       POOL ISOLATION · unique to warmup
       A single horizontal "rings of trust" diagram with the three
       pool layers stacked, plus a one-line rule for each.
  ============================================================ -->
  <section class="border-y border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-20 md:py-28">
    <div class="container-page">
      <div class="max-w-2xl mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Pool isolation</div>
        <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.025em] leading-[1.06] text-heading">
          Same engine. Three isolation surfaces.
        </h2>
        <p class="mt-4 text-[15px] text-foreground/70 leading-relaxed">
          Free pool mailboxes never silently appear in the premium pool. Recovery pool is for paid mailboxes serving a cooldown. Dedicated infrastructure is isolation at the worker layer, not a reputation shortcut.
        </p>
      </div>

      <div class="rounded-[14px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden">
        <!-- Row: Free pool -->
        <div class="grid grid-cols-[160px_1fr_auto] gap-6 px-7 py-6 items-center border-b border-[color:var(--border)]">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-slate-400"></span>
            <span class="text-[14px] font-semibold text-heading">Free pool</span>
          </div>
          <div class="text-[13.5px] text-foreground/70">
            Trial mailboxes only. Recipients are drawn exclusively from other free-plan mailboxes. Same auto-quarantine thresholds.
          </div>
          <div class="text-[10.5px] font-mono uppercase tracking-[0.16em] text-muted-foreground text-right whitespace-nowrap">Free trial</div>
        </div>

        <!-- Row: Premium pool · featured -->
        <div class="grid grid-cols-[160px_1fr_auto] gap-6 px-7 py-6 items-center border-b border-[color:var(--border)] bg-[color:var(--sky-1)]/40">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-[#0284c7]"></span>
            <span class="text-[14px] font-semibold text-[#0369a1]">Premium pool</span>
          </div>
          <div class="text-[13.5px] text-foreground/80">
            Vetted paid mailboxes only. Stricter quarantine bands than free. Quarantined senders move to the recovery pool, not back to the main premium pool.
          </div>
          <div class="text-[10.5px] font-mono uppercase tracking-[0.16em] text-[#0284c7] text-right whitespace-nowrap">Starter · Grow · Business</div>
        </div>

        <!-- Row: Recovery pool -->
        <div class="grid grid-cols-[160px_1fr_auto] gap-6 px-7 py-6 items-center border-b border-[color:var(--border)]">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-amber-500"></span>
            <span class="text-[14px] font-semibold text-heading">Recovery pool</span>
          </div>
          <div class="text-[13.5px] text-foreground/70">
            Quarantined paid mailboxes during their 7-day cooldown. Isolated from healthy premium senders. Must pass 20-delivery probation before re-entry.
          </div>
          <div class="text-[10.5px] font-mono uppercase tracking-[0.16em] text-muted-foreground text-right whitespace-nowrap">Automatic</div>
        </div>

        <!-- Row: Dedicated -->
        <div class="grid grid-cols-[160px_1fr_auto] gap-6 px-7 py-6 items-center">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-foreground"></span>
            <span class="text-[14px] font-semibold text-heading">Dedicated</span>
          </div>
          <div class="text-[13.5px] text-foreground/70">
            Isolated worker process and IP for one organisation. Still participates in the premium pool. Infrastructure isolation, not a reputation shortcut.
          </div>
          <div class="text-[10.5px] font-mono uppercase tracking-[0.16em] text-muted-foreground text-right whitespace-nowrap">Enterprise</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DEFAULTS SPEC — full data with rationale
  ============================================================ -->
  <section class="py-20 md:py-24">
    <div class="container-page grid lg:grid-cols-[1fr_1.8fr] gap-12 lg:gap-16 items-start">
      <div>
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Defaults</div>
        <h2 class="text-[28px] md:text-[36px] font-semibold tracking-[-0.025em] leading-[1.08] text-heading">
          The numbers we ship with.
        </h2>
        <p class="mt-4 text-[14.5px] text-foreground/70 leading-relaxed max-w-md">
          Defaults that work for the median sender. Override per mailbox if you have a real reason. The "why" column is the reasoning we will defend in an incident.
        </p>
      </div>

      <div class="rounded-[12px] ring-1 ring-[color:var(--border)] bg-white overflow-hidden">
        <div class="grid grid-cols-[1fr_120px_1.6fr] px-5 py-3 bg-[color:var(--surface-1)] border-b border-[color:var(--border)] text-[10.5px] uppercase tracking-[0.16em] font-mono text-muted-foreground">
          <div>Setting</div>
          <div>Default</div>
          <div>Why</div>
        </div>
        {defaults.map((d) => (
          <div class="grid grid-cols-[1fr_120px_1.6fr] gap-4 px-5 py-3.5 border-b border-[color:var(--border)] last:border-b-0 items-baseline text-[13px]">
            <div class="font-medium text-heading">{d.k}</div>
            <div>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded font-mono text-[12px] bg-[color:var(--sky-1)] text-[#075985] ring-1 ring-[color:var(--sky-2)]">{d.v}</span>
            </div>
            <div class="text-foreground/70 text-[12.5px]">{d.why}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ — split sticky title (pricing pattern)
  ============================================================ -->
  <section class="bg-[color:var(--surface-1)]/40 border-t border-[color:var(--border)] py-20 md:py-24">
    <div class="container-page grid lg:grid-cols-[1fr_1.8fr] gap-12 lg:gap-20 items-start">
      <div class="lg:sticky lg:top-24" style="align-self: start;">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Warmup FAQ</div>
        <h2 class="text-[28px] md:text-[36px] font-semibold tracking-[-0.025em] leading-[1.08] text-heading">
          Four questions we get most.
        </h2>
        <p class="mt-4 text-[14.5px] text-foreground/70 leading-relaxed">
          Want the full mental model? Read the <a class="text-[#0369a1] hover:text-[#075985] font-medium" href="/learn/email-warmup/">warmup guide</a>.
        </p>
      </div>
      <div class="divide-y divide-[color:var(--border)]">
        {faq.map(([q, a]) => (
          <details class="group py-5">
            <summary class="flex items-start justify-between gap-4 cursor-pointer list-none">
              <span class="text-[15.5px] font-medium text-heading group-hover:text-[#0369a1] transition-colors">{q}</span>
              <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-white ring-1 ring-[color:var(--border)] text-foreground/60 group-open:rotate-45 transition-transform">
                <Icon name="plus" size={12} />
              </span>
            </summary>
            <p class="mt-3 text-[14px] text-foreground/75 leading-relaxed max-w-2xl">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

