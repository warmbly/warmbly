              </th>
            </tr>
          </thead>
          <tbody>
            {bands.map((b) => {
              const t = toneClass(b.tone);
              return (
                <tr class="border-t border-[color:var(--border)]">
                  <td class="px-5 py-4">
                    <span class={`inline-flex items-center gap-1.5 h-6 px-2 rounded text-[12px] font-medium font-mono ${t.chip}`}>
                      <span class={`w-1.5 h-1.5 rounded-full ${t.dot}`}></span>
                      {b.name}
                    </span>
                  </td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.spam}</td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.complaint}</td>
                  <td class="px-5 py-4 font-mono text-foreground/85">{b.bounce}</td>
                  <td class="px-5 py-4 text-foreground/75">{b.action}</td>
