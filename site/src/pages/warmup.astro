        <!-- Row: Premium pool · featured -->
        <div class="grid grid-cols-[160px_1fr_auto] gap-6 px-7 py-6 items-center border-b border-[color:var(--border)] bg-[color:var(--sky-1)]/40">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-[#0284c7]"></span>
            <span class="text-[14px] font-semibold text-[#0369a1]">Premium pool</span>
          </div>
          <div class="text-[13.5px] text-foreground/80">
            Vetted paid mailboxes only. Stricter quarantine bands than free. Quarantined senders move to the recovery pool, not back to the main premium pool.
          </div>
          <div class="text-[10.5px] font-mono uppercase tracking-[0.16em] text-[#0284c7] text-right whitespace-nowrap">Starter · Grow · Business</div>
