---
import Layout from '../layouts/Layout.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

// Every number on this page is a real default from the codebase:
//   internal/config/constants.go
//   internal/scheduler/{campaign,email,warmup}_scheduler.go
//   internal/app/warmup/service.go  (health bands)
//   internal/repository/pg_warmup.go
//   internal/app/worker/wmail/ratelimit.go
//   internal/app/advanced/service.go  (suppression)
//   internal/infrastructure/db/migrations/000001_baseline.up.sql  (free/premium pools)

// =========================================================================
// What rides along with a single mailbox (the model-section card).
// =========================================================================
const attached = [
  { k: 'Cap',         v: '50 / day',       d: 'The most cold email this mailbox sends in a day.' },
  { k: 'Pace',        v: '600s apart',     d: 'At least ten minutes between any two sends.' },
  { k: 'Warmup',      v: '10 to 40 / day', d: 'Opens at 10, adds one a day, holds at 40.' },
  { k: 'Health',      v: 'rolling 7 days', d: 'A score built from spam, complaints, and bounces.' },
  { k: 'Auth',        v: 'SPF DKIM DMARC', d: 'Re-checked daily, not just at setup.' },
  { k: 'Suppression', v: 'workspace-wide', d: 'One bounce or complaint stops every campaign.' },
];

// Workers the mailbox can run on. Just infrastructure; the mailbox carries
// its own reputation regardless of which one it sits on.
const workers = [
  { id: 'w-01', ip: '192.0.2.14',   dots: ['bg-emerald-500', 'bg-emerald-500', 'bg-amber-500'] },
  { id: 'w-02', ip: '198.51.100.7', dots: ['bg-emerald-500', 'bg-emerald-500', 'bg-emerald-500'] },
  { id: 'w-03', ip: '203.0.113.9',  dots: ['bg-emerald-500', 'bg-amber-500'] },
];

// The mailbox lifecycle shown on the left of the model section. Each step
// pairs with a control on the card to the right.
const lifecycle = [
  { t: 'Connect and verify auth',        d: 'SPF, DKIM, and DMARC have to resolve before the mailbox can send.' },
  { t: 'Warm up 10 to 40',               d: 'Opens at 10 a day, adds one a day, holds at 40.' },
  { t: 'Send within caps, watch health', d: '50 a day, 600s apart, scored on a rolling 7 days.' },
  { t: 'If it slips, pull and recover',  d: 'Out of the pool it cools off, then requalifies before it sends again.' },
];

// =========================================================================
// The product defaults. Real numbers from internal/config/constants.go
// =========================================================================
const defaults = [
  { k: 'Cold campaign cap', v: '50 / day',   why: 'The ceiling for cold email from one mailbox. You can raise it to 100, but only with a reason worth defending.' },
  { k: 'Minimum send gap',  v: '600s',       why: 'Ten minutes between sends, even when the queue is full. People do not fire off mail in bursts.' },
  { k: 'Warmup start',      v: '10 / day',   why: 'Where warmup begins. Low enough to read like a normal person sending mail.' },
  { k: 'Warmup ceiling',    v: '40 / day',   why: 'Warmup stops climbing here. Pushing past it buys no extra reputation.' },
  { k: 'Warmup ramp',       v: '+1 / day',   why: 'One more warmup message per day. Faster ramps look odd to the receiver.' },
  { k: 'Sync burst limit',  v: '100 / 5m',   why: 'If a mailbox pulls in more than 100 new messages in five minutes, the worker throttles it.' },
  { k: 'Sync hourly limit', v: '500 / hr',   why: 'Past this we pause the mailbox ourselves, before the provider has to.' },
  { k: 'Invalid token block', v: '3 / 24h',  why: 'Three malformed warmup tokens in a day drop the mailbox from the pool.' },
];

// =========================================================================
// Auto-quarantine bands. Spam-placement thresholds, per-mailbox window.
// Matches the health states in internal/app/warmup/service.go.
// =========================================================================
const bands = [
  {
    name: 'Healthy',     tone: 'emerald',
    spam: 'under 10%',   complaint: 'under 0.03%', bounce: 'under 5%',
    action: 'Normal. Keeps warming up and stays in the pool.',
  },
  {
    name: 'Watch',       tone: 'amber',
    spam: 'at or above 10%', complaint: 'at or above 0.03%', bounce: 'not used',
    action: 'Volume eases back and the gaps widen, more so as it climbs. Stays in the pool.',
  },
  {
    name: 'Quarantined', tone: 'rose',
    spam: 'at or above 20%', complaint: 'at or above 0.10%', bounce: 'at or above 5%',
    action: 'Out of the shared pool for 7 days. Cools off in recovery.',
  },
  {
    name: 'Blocked',     tone: 'rose-dark',
    spam: 'at or above 40%', complaint: 'at or above 0.30%', bounce: 'at or above 10%',
    action: 'Blocked for 30 days. Cold sending pauses, and a person clears it before re-entry.',
  },
  {
    name: 'Catastrophic', tone: 'rose-dark',
    spam: 'at or above 80%', complaint: 'severe', bounce: 'severe',
    action: 'Long block and a full reputation reset. No automatic way back in.',
  },
];

const toneClass = (t: string) => {
  if (t === 'emerald')   return { dot: 'bg-emerald-500', chip: 'bg-emerald-50 text-emerald-700', bar: 'bg-emerald-500' };
  if (t === 'amber')     return { dot: 'bg-amber-500',   chip: 'bg-amber-50 text-amber-700',     bar: 'bg-amber-500'   };
  if (t === 'rose-dark') return { dot: 'bg-rose-700',    chip: 'bg-rose-100 text-rose-800',      bar: 'bg-rose-700'    };
  return { dot: 'bg-rose-500', chip: 'bg-rose-50 text-rose-700', bar: 'bg-rose-500' };
};

// =========================================================================
// Two warmup pools (free, premium) plus the handling around them:
// recovery is a cooldown state, dedicated is isolated infrastructure.
// =========================================================================
const pools = [
  {
    name: 'Free pool',     accent: '#94a3b8',
    when: 'Free trial',
    summary: 'Trial mailboxes only, held to the same thresholds as paid ones.',
    rules: [
      'Only warms up with other free-plan mailboxes.',
      'Never sends to a premium mailbox.',
      'Kept out of the premium health scoring.',
    ],
  },
  {
    name: 'Premium pool', accent: '#0284c7', featured: true,
    when: 'Starter, Grow, Business',
    summary: 'Vetted paid mailboxes, with tighter bands and less room to drift.',
    rules: [
      'Only warms up with other healthy premium mailboxes.',
      'A mailbox that crosses a band drops to recovery and earns its way back.',
      'Spam placement and complaints are scored per mailbox over rolling windows.',
    ],
  },
  {
    name: 'Recovery',     accent: '#d97706',
    when: 'A cooldown state',
    summary: 'Where a mailbox sits while it cools off after crossing a band. Healthy traffic never sees it.',
    rules: [
      '7 days after a quarantine, 30 days after a hard block.',
      'Comes back at reduced volume for a few days, then gets re-scored.',
      'Authentication and bounce checks have to pass first.',
    ],
  },
  {
    name: 'Dedicated',    accent: '#0f172a',
    when: 'Enterprise infrastructure',
    summary: 'Your own worker and IP. It still warms up inside the premium pool.',
    rules: [
      'One worker process and IP for one organisation.',
      'Reputation is still earned per mailbox.',
      'Same thresholds apply. Your own IP is not a free pass.',
    ],
  },
];

// =========================================================================
// Authentication coverage. SPF, DKIM, DMARC, PTR.
// =========================================================================
const auth = [
  { name: 'SPF',   tag: 'TXT record',
    body: 'We read the domain SPF record and confirm both your mailbox provider and any third-party senders are allowed.',
    fail: 'If it is missing or wrong, the mailbox cannot leave the connection wizard.' },
  { name: 'DKIM',  tag: 'Selector + key',
    body: 'We find the provider DKIM selector, confirm the public key parses, and require at least 1024 bits.',
    fail: 'A missing selector shows you the exact record to publish, ready to copy.' },
  { name: 'DMARC', tag: 'Policy + alignment',
    body: 'We read the policy, the alignment mode, and the reporting address, and flag p=none clearly.',
    fail: 'Reports can point at a Warmbly inbox so they surface inside the dashboard.' },
  { name: 'PTR',   tag: 'Reverse DNS',
    body: 'For your own SMTP, we check the sending IP reverse DNS resolves back to the same hostname.',
    fail: 'A mismatched PTR is one of the fastest ways into the spam folder.' },
];

// =========================================================================
// Suppression engine. Real codepaths (internal/app/advanced/service.go).
// Workspace + email scope only; auto-actions default on per org settings.
// =========================================================================
const suppression = [
  { trigger: 'Bounce',                scope: 'workspace',  source: 'consumer.deliverability',   note: 'When a send bounces, the recipient is dropped across every campaign in the workspace, and nothing else queues to them.' },
  { trigger: 'Complaint (FBL / ARF)', scope: 'workspace',  source: 'consumer.deliverability',   note: 'A Gmail or Microsoft spam complaint suppresses the recipient and nudges the mailbox health score down.' },
  { trigger: 'One-click unsubscribe', scope: 'workspace',  source: 'tracking.unsubscribe',      note: 'RFC 8058 one-click. The recipient is gone before the confirmation page even loads.' },
  { trigger: 'Reply: STOP / REMOVE',  scope: 'workspace',  source: 'consumer.reply.classifier', note: 'Common opt-out phrases in replies are caught and suppressed without anyone in the loop.' },
  { trigger: 'Manual suppression',    scope: 'workspace',  source: 'api / dashboard',           note: 'Suppress by recipient or an uploaded list. CSV uploads are deduplicated against what is already there.' },
];

// =========================================================================
// Recommended cold sending posture.
// =========================================================================
const posture = [
  { stage: 'New mailbox',   range: '10 to 20 / day', note: 'Fresh or just connected. The first couple of weeks are for reputation; pipeline comes later.' },
  { stage: 'Ramping',       range: '+5 / week',      note: 'Add a little each week while complaints and bounces stay clean. Back off the moment they climb.' },
  { stage: 'Stable band',   range: '30 to 50 / day', note: 'The normal range for most cold mailboxes. The default cap sits at the top of it.' },
  { stage: 'Above default', range: 'needs a look',   note: 'Going past 50 / day on one mailbox takes clean signals and a real reason first.' },
];

// =========================================================================
// How we landed differently from most of the category.
// =========================================================================
const approach = [
  { h: 'Sending is spread out on purpose.',
    b: 'Throughput per server is the wrong thing to optimise for. What burns reputation is sending too much from one mailbox, domain, or IP. We keep each mailbox under its own cap and spread the work across many of them, so the risk never piles up in one place.' },
  { h: 'Warmup has to prove itself.',
    b: 'Warmup only helps if it is real. Every warmup message carries a signed token that we check when the reply comes back, so a mailbox cannot fake good behaviour by quietly replying to itself.' },
  { h: 'We pull a mailbox before the provider does.',
    b: 'Once Google or SES throttles a domain, the damage has already gone out. We watch each mailbox on a rolling window and act on our own thresholds, which sit weeks earlier than the public ones.' },
  { h: 'Trials never share a pool with paying customers.',
    b: 'A trial account should never warm up in the same loop as a paying one. If it picks up bad habits, that is its own problem to work off in recovery.' },
];

// =========================================================================
// FAQ.
// =========================================================================
const faq = [
  ['Is deliverability tracked per mailbox or per account?',
   'Per mailbox. Each one is scored and capped on its own, so a single account can hold five mailboxes in five different states at once.'],
  ['What pulls a mailbox out of the pool automatically?',
   'Any of these: three bad warmup tokens in 24 hours, spam placement at or above 20% with at least 20 warmup deliveries in the last 7 days, a complaint rate at or above 0.10%, or a bounce rate at or above 5%.'],
  ['How does suppression carry across campaigns?',
   'Bounces, complaints, and unsubscribes are workspace-wide. Once someone is suppressed, every running campaign skips them on the next send, and nothing else ever queues to them.'],
  ['Why is the cap only 50 a day?',
   'Because 50 a day with a 600-second gap stays comfortably under provider scrutiny everywhere. You can raise it toward 100, but earn it mailbox by mailbox.'],
  ['What happens when a mailbox gets blocked?',
   'It leaves the shared pool, cold sending pauses, and it cools off in recovery: 7 days after a quarantine, 30 after a hard block. When the cooldown ends it comes back at reduced volume for a few days and has to re-pass the health checks before it sends normally again.'],
  ['Shared IPs or dedicated?',
   'Most plans share IPs, which is fine here because we track reputation on the mailbox itself. Enterprise plans can take a dedicated worker and IP, but the same per-mailbox limits still apply.'],
  ['Does warmup keep running once I start a campaign?',
   'Yes. Warmup runs alongside your cold sending to keep the mailbox active and conversational. Switching it off the day you go live is a good way to watch a mailbox go cold.'],
  ['How long before a new mailbox is ready?',
   'Plan on a few weeks. Warmup opens at 10 a day and adds one a day, so a fresh mailbox earns its way up to a normal cold volume instead of jumping straight there.'],
  ['Do you guarantee the inbox?',
   'No, and be careful with anyone who does. Placement also depends on your content, your list quality, and your domain history. What we control is the sending itself: how fast and how much each mailbox sends, whether its authentication is clean, and pulling it the moment it starts to slip.'],
];

// =========================================================================
// Astro JSX parser hoists. Keep any `<` or `<=` out of `{}`; pre-compute
// everything as data and iterate cleanly in JSX.
// =========================================================================
const gaugeTicks = [
  { pct: 0,   label: '0%' },
  { pct: 10,  label: '10%' },
  { pct: 20,  label: '20%' },
  { pct: 40,  label: '40%' },
  { pct: 80,  label: '80%' },
  { pct: 100, label: '100%' },
];

const numbers = [
  { v: '50',    u: '/ day',  l: 'cold cap per mailbox',     src: 'internal/config/constants.go' },
  { v: '600',   u: 's',      l: 'min gap between sends',    src: 'internal/scheduler/email_scheduler.go' },
  { v: '10',    u: '/ day',  l: 'warmup start volume',      src: 'internal/scheduler/warmup_scheduler.go' },
  { v: '40',    u: '/ day',  l: 'warmup ceiling',           src: 'internal/scheduler/warmup_scheduler.go' },
  { v: '+1',    u: '/ day',  l: 'warmup ramp',              src: 'internal/scheduler/warmup_scheduler.go' },
  { v: '500',   u: '/ hr',   l: 'worker sync hourly limit', src: 'internal/app/worker/wmail/ratelimit.go' },
];
---
<Layout
  title="Email deliverability, handled per mailbox | Warmbly"
  description="Warmbly scores and limits each mailbox on its own, and pulls a mailbox from the shared pool weeks before Gmail or Outlook would flag it."
>
  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <!-- warmup fragments arranged as a diagonal ramp: starts low-left, arrives healthy top-right. The vertical middle stays clear of the headline. xl and up. -->
    <div class="hidden xl:block absolute inset-0 z-0 pointer-events-none select-none" aria-hidden="true">

      <!-- TOP-RIGHT · the destination: a warmed-up, healthy mailbox (focal, live dot) -->
      <div class="hero-float absolute top-[9%] right-[calc(50%_-_470px)] z-30" style="--drift:-11px;animation-duration:7.4s;animation-delay:-1.7s">
        <div class="relative rotate-[2deg] w-[182px] px-3.5 py-3 rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_4px_-2px_rgba(2,32,71,0.25),0_18px_36px_-12px_rgba(2,32,71,0.55)]">
          <span class="absolute -top-1 -right-1 inline-flex w-2.5 h-2.5">
            <span class="hero-float-ping absolute inset-0 rounded-full bg-emerald-400 opacity-70 animate-ping"></span>
            <span class="relative w-2.5 h-2.5 rounded-full bg-emerald-500 ring-2 ring-white"></span>
          </span>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
            <span class="font-mono text-[12px] font-semibold text-slate-800 truncate">ben@acme.com</span>
          </div>
          <div class="mt-1 font-mono text-[10.5px] text-slate-500 tabular-nums">healthy · 47/50 today</div>
          <div class="mt-2 h-1 w-full rounded-full bg-slate-100 overflow-hidden">
            <div class="h-full rounded-full bg-sky-500" style="width:94%"></div>
          </div>
        </div>
      </div>

      <!-- TOP-RIGHT · supporting chip just under the card -->
      <div class="hero-float absolute top-[25%] right-[calc(50%_-_432px)] z-20" style="--drift:-7px;animation-duration:8s;animation-delay:-0.9s">
        <div class="rotate-[-2deg] h-7 px-3 rounded-full bg-white/95 ring-1 ring-slate-900/5 shadow-[0_8px_20px_-10px_rgba(2,32,71,0.4)] inline-flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>
          <span class="text-[11px] font-medium text-slate-600">premium pool</span>
        </div>
      </div>

      <!-- TOP-LEFT · a lone accent up high -->
      <div class="hero-float absolute top-[12%] left-[calc(50%_-_446px)] z-20" style="--drift:-9px;animation-duration:6.6s;animation-delay:-2.4s">
        <div class="rotate-[-2deg] px-3 py-2.5 rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_3px_-2px_rgba(2,32,71,0.2),0_14px_30px_-14px_rgba(2,32,71,0.45)]">
          <div class="flex items-center gap-2">
            <span class="w-4 h-4 rounded-full bg-emerald-50 ring-1 ring-emerald-200 inline-flex items-center justify-center shrink-0">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <span class="text-[12px] font-semibold text-slate-800">signed token</span>
          </div>
        </div>
      </div>

      <!-- BOTTOM-LEFT · the start of the ramp: low volume, day one -->
      <div class="hero-float absolute top-[82%] left-[calc(50%_-_474px)] z-20" style="--drift:-10px;animation-duration:7.8s;animation-delay:-1.2s">
        <div class="rotate-[-3deg] w-[156px] px-3.5 py-3 rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_3px_-2px_rgba(2,32,71,0.2),0_14px_30px_-14px_rgba(2,32,71,0.45)]">
          <div class="flex items-center gap-2">
            <div class="flex items-end gap-[3px] h-5">
              <span class="w-1 h-2 rounded-[1px] bg-sky-400"></span>
              <span class="w-1 h-3 rounded-[1px] bg-sky-400"></span>
              <span class="w-1 h-3.5 rounded-[1px] bg-sky-400"></span>
              <span class="w-1 h-4 rounded-[1px] bg-sky-400"></span>
              <span class="w-1 h-5 rounded-[1px] bg-sky-500"></span>
            </div>
            <span class="font-mono text-[12px] font-semibold text-slate-800 tabular-nums">10 to 40</span>
          </div>
          <div class="mt-1.5 text-[10.5px] text-slate-500">starts at 10 a day</div>
        </div>
      </div>

      <!-- BOTTOM-LEFT · the ramp rule, tucked inboard -->
      <div class="hero-float absolute top-[88%] left-[calc(50%_-_322px)] z-10" style="--drift:-6px;animation-duration:8.3s;animation-delay:-3.4s">
        <div class="rotate-[4deg] h-7 px-3 rounded-full bg-white/95 ring-1 ring-slate-900/5 shadow-[0_8px_20px_-10px_rgba(2,32,71,0.4)] inline-flex items-center gap-1.5">
          <span class="font-mono text-[12px] font-semibold text-slate-800">+1</span>
          <span class="text-[10.5px] text-slate-500">/ day</span>
        </div>
      </div>

      <!-- BOTTOM-RIGHT · a warmup reply, low -->
      <div class="hero-float absolute top-[85%] right-[calc(50%_-_440px)] z-10" style="--drift:-8px;animation-duration:7.1s;animation-delay:-2.8s">
        <div class="rotate-[1.5deg] px-3.5 py-2.5 rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_3px_-2px_rgba(2,32,71,0.2),0_14px_30px_-14px_rgba(2,32,71,0.45)]">
          <div class="flex items-center gap-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="text-sky-400 shrink-0" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
            <span class="text-[12px] text-slate-700">thanks, got it</span>
          </div>
        </div>
      </div>

    </div>

    <div class="container-page relative z-10 pt-20 md:pt-28 pb-32 md:pb-44 text-center">
      <div class="inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white" style="color:#0369a1;">
          Deliverability
        </span>
        The work that keeps you out of spam
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        Keep every mailbox<br/>landing in the inbox.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Each mailbox is warmed up, capped, and scored on its own. When one starts drifting toward spam, we slow it down or pull it from the pool before Gmail or Outlook notices.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Audit a mailbox</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="#approach" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          How we think about it
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-float { animation-name: heroFloat; animation-timing-function: ease-in-out; animation-iteration-count: infinite; animation-direction: alternate; will-change: transform; }
    @keyframes heroFloat { from { transform: translateY(0); } to { transform: translateY(var(--drift, -10px)); } }
    @media (prefers-reduced-motion: reduce) { .hero-float { animation: none; } .hero-float-ping { animation: none; } }
  </style>

  <!-- ============================================================
       APPROACH · what we do differently, in plain terms
  ============================================================ -->
  <section id="approach" class="border-y border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-20 md:py-28 scroll-mt-4">
    <div class="container-page">
      <div class="max-w-3xl mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-3">How we think about it</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
          A few decisions that shape the rest.
        </h2>
        <p class="mt-4 text-[15.5px] text-foreground/70 leading-relaxed">
          Deliverability decides whether the rest of the product matters, so we were opinionated about it early. Here is where we ended up differently from most of the category, and each one is a real choice in the code.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 lg:gap-5">
        {approach.map((c, i) => (
          <div class="rounded-[14px] bg-white ring-1 ring-[color:var(--border)] p-6 md:p-7">
            <div class="flex items-baseline gap-3 mb-3">
              <span class="font-mono text-[11px] text-[#0284c7] font-semibold tabular-nums">{String(i + 1).padStart(2, '0')}</span>
              <div class="text-[16px] md:text-[17px] font-semibold tracking-[-0.015em] text-heading leading-snug">{c.h}</div>
            </div>
