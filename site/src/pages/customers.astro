---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHead from '../components/SectionHead.astro';
import Card from '../components/Card.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

const stories = [
  {
    company: 'Northwind',
    industry: 'B2B SaaS',
    headline: 'Reply rate doubled after switching from a single-sender tool.',
    summary: 'Northwind ran sequences through one sender on a legacy tool. Reply rate sat at 2.4%. After redistributing across 12 mailboxes on Warmbly and switching to the premium warmup pool, reply rate climbed to 5.1% in 6 weeks and burn rate dropped to a single mailbox quarantine per quarter.',
    metrics: [
      ['2.4% → 5.1%', 'Reply rate'],
      ['1 / quarter', 'Mailbox quarantines'],
      ['12', 'Active sender mailboxes'],
    ],
  },
  {
    company: 'Loop',
    industry: 'Recruiting agency',
    headline: 'Stopped losing weeks to deliverability triage.',
    summary: 'Loop’s team was running outbound for 14 clients on 14 different domains. With Warmbly’s per-mailbox health view, each recruiter knows whether their inbox is healthy without asking ops. The team reclaimed an estimated 6 hours per recruiter per week.',
    metrics: [
      ['14', 'Client domains'],
      ['6 hrs / wk', 'Saved per recruiter'],
      ['98.4%', 'Mean inbox placement'],
    ],
  },
  {
    company: 'Spruce',
    industry: 'Climate-tech YC startup',
    headline: 'Raised their seed off the back of a single Warmbly sequence.',
    summary: 'Three founders, one cold-mail sequence to 800 climate-focused VCs. Spruce booked 22 meetings in 18 business days and closed a $3.4M seed round from one of those meetings.',
    metrics: [
      ['22', 'Meetings booked'],
      ['18 days', 'Time to close meeting'],
      ['$3.4M', 'Seed round'],
    ],
  },
];
---
<Layout
  title="Customers — Warmbly"
  description="How founders, agencies and sales teams use Warmbly to send cold email that actually lands."
>
  <PageHero
    eyebrow="Customers"
    title="What teams ship when their cold mail actually arrives."
  />

  <Section>
    <div class="grid gap-6">
      {stories.map((s) => (
        <Card class="md:grid md:grid-cols-12 md:gap-8 md:items-start">
          <div class="md:col-span-4">
            <div class="text-[12px] uppercase tracking-wider text-muted-foreground font-semibold">{s.industry}</div>
            <h3 class="mt-2 text-2xl font-extrabold tracking-tight">{s.company}</h3>
            <div class="mt-5 grid grid-cols-3 gap-3">
              {s.metrics.map(([v, k]) => (
                <div>
                  <div class="text-[16px] font-extrabold">{v}</div>
                  <div class="text-[11.5px] text-muted-foreground leading-tight mt-0.5">{k}</div>
                </div>
              ))}
            </div>
          </div>
          <div class="md:col-span-8 mt-6 md:mt-0 md:pl-6 md:border-l border-border">
            <h4 class="text-[17px] font-semibold leading-snug">{s.headline}</h4>
            <p class="mt-3 text-[14px] text-muted-foreground leading-relaxed">{s.summary}</p>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <Section variant="muted">
    <SectionHead
      eyebrow="In their words"
      title="What people say once they’re a few weeks in."
    />
    <div class="mt-10 grid md:grid-cols-2 gap-4">
      {[
        ['“Finally a tool that tells us a mailbox is in trouble before the provider does.”', 'Ops lead, Loop'],
        ['“The pool quarantine logic alone is worth the price.”', 'Founder, Spruce'],
        ['“We rebuilt 3 home-grown scripts when we adopted Warmbly. Better, smaller, and watched in real time.”', 'CTO, Northwind'],
        ['“Their warmup ramp matches what the deliverability community actually recommends.”', 'Deliverability consultant, Heliogen'],
      ].map(([q, a]) => (
        <Card>
          <p class="text-[15px] leading-relaxed">{q}</p>
          <p class="mt-3 text-[12.5px] text-muted-foreground">{a}</p>
        </Card>
      ))}
    </div>
  </Section>

  <CTA />
</Layout>
