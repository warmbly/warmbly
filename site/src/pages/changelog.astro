---
import Layout from '../layouts/Layout.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

// Seeded entries (from the prior changelog) plus 3 new ones grounded
// in the real codebase / CLAUDE.md (SOC 2 in progress, BYOK / KMS,
// SSO, worker assignment, tracking edge, warmup token validation).
const entries = [
  {
    date: '2026-05-26',
    title: 'BYOK envelope encryption for self-host',
    tag: 'shipped',
    body: 'Self-hosted deployments can now register their own AWS KMS key as the root of trust for the per-user DEK envelope. Existing encrypted material is re-wrapped on first key activation. Plaintext DEKs continue to live only in the Redis cache with a bounded TTL.',
  },
  {
    date: '2026-05-22',
    title: 'SAML SSO for Business plans',
    tag: 'shipped',
    body: 'Workspace owners on Business can connect Okta, Azure AD, or any SAML 2.0 IdP. Just-in-time provisioning is on by default and admins can pin a default role for new sign-ins.',
  },
  {
    date: '2026-05-20',
    title: 'API keys dashboard',
    tag: 'shipped',
    body: 'New API keys page in Settings. Per-key scopes, last-used timestamps, and one-click rotation. Existing keys auto-migrated to full-access scope. Rotate when you can.',
  },
  {
    date: '2026-05-15',
    title: 'Per-mailbox health bands',
    tag: 'shipped',
    body: 'Mailboxes now surface a health band: healthy, watch, quarantined, or blocked. Bands are driven by rolling placement, complaint, and bounce signals. Pool selection skips anything not healthy.',
  },
  {
    date: '2026-05-05',
    title: 'Contacts power tools',
    tag: 'shipped',
    body: 'CSV, XLSX, and JSON export with a field picker and a scope toggle. A CSV / XLSX import wizard handles column mapping, dedup, and category assignment. Categories replace Tags in the contact model.',
  },
  {
    date: '2026-04-25',
    title: 'Recovery pool',
    tag: 'shipped',
    body: 'Quarantined mailboxes move to a separate recovery pool, isolated from the main paid pool. 7-day cooldown plus a 20-delivery probation window before any re-entry into premium warmup traffic.',
  },
  {
    date: '2026-04-18',
    title: 'SOC 2 Type I in progress',
    tag: 'changed',
    body: 'We engaged an external auditor for SOC 2 Type I. Trust center now lists subprocessors, the data flow, and the encryption model. Type II observation window starts after the Type I report lands.',
  },
  {
    date: '2026-04-12',
    title: 'Worker concentration warnings',
    tag: 'shipped',
    body: 'Workspace surfaces a warning when a shared worker is carrying too much active cold volume. We add workers and rebalance before forcing any one machine to do more.',
  },
  {
    date: '2026-04-01',
    title: 'Plain-text default',
    tag: 'changed',
    body: 'New sequences default to plain text. HTML is opt-in per step. Existing sequences are untouched, but new templates inherit the plain-text default.',
  },
  {
    date: '2026-03-22',
    title: 'Microsoft 365 OAuth refresh',
    tag: 'fixed',
    body: 'Resolved an intermittent token-refresh failure for Microsoft mailboxes with mandatory MFA. Affected mailboxes auto-reconnect on the next sync window with no manual reauth.',
  },
  {
    date: '2026-03-10',
    title: 'Sequence A/B variants',
    tag: 'shipped',
    body: 'Up to four subject and body variants per step. Per-variant reply-rate reporting, with significance hints once each variant has enough sample.',
  },
  {
    date: '2026-03-01',
    title: 'Tracking edge upgrade',
    tag: 'changed',
    body: 'The tracking edge now dedupes by task and IP at the edge, and again in the consumer. Drops a class of replay-driven noise from analytics without losing real engagement events.',
  },
];

const tagStyle = (t) => {
  if (t === 'shipped') return { dot: 'bg-emerald-500', chip: 'bg-emerald-50 text-emerald-700', accent: 'text-emerald-700' };
  if (t === 'changed') return { dot: 'bg-amber-500',   chip: 'bg-amber-50 text-amber-700',     accent: 'text-amber-700'   };
  return { dot: 'bg-sky-500', chip: 'bg-sky-50 text-sky-700', accent: 'text-sky-700' };
};

const counts = {
  total:   entries.length,
  shipped: entries.filter(e => e.tag === 'shipped').length,
  changed: entries.filter(e => e.tag === 'changed').length,
  fixed:   entries.filter(e => e.tag === 'fixed').length,
};

// Hoisted to avoid `<` / `<=` inside JSX expressions (Astro JSX parser is fragile).
const monthEntries  = entries.filter(e => e.date.startsWith('2026-05'));
const monthCount    = monthEntries.length;
const ytdEntries    = entries.filter(e => e.date.startsWith('2026-'));
const ytdCount      = ytdEntries.length;
const shippedCount  = counts.shipped;
const changedCount  = counts.changed;
const fixedCount    = counts.fixed;
const totalCount    = counts.total;

// Featured = first (latest) entry.
const featured        = entries[0];
const featuredStyle   = tagStyle(featured.tag);
// Long-form body for the featured card (in addition to entry.body).
const featuredExtra = [
  'Self-hosted clusters can now register their own AWS KMS CMK as the root of trust. The plaintext DEK is generated by KMS, used in-memory for AES-256-GCM, and never persisted as plaintext. Only the encrypted DEK blob is written to DynamoDB.',
  'On rotation, all existing per-user DEKs are re-wrapped with the new CMK in the background. Application reads transparently fall back to the previous CMK during the migration window.',
];

// Older entries (everything after the featured one).
const restEntries = entries.slice(1);
---
<Layout
  title="Changelog · Warmbly"
  description="Everything we shipped, changed, and fixed at Warmbly. The actual history of the platform, dated and tagged."
>
  <!-- ============================================================
       HERO · HeroAtmosphere, matches warmup / campaigns / pricing
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <div class="container-page relative pt-16 md:pt-24 pb-44 md:pb-56 text-center">
      <div class="inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white" style="color:#0369a1;">
          Changelog
        </span>
        Everything we shipped, dated and tagged
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        The actual history<br/>of what we ship.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        New features, behavioural changes, and fixes, in the order they reached production. No marketing language, no rewrites of older entries, no quiet deletions.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/changelog/feed.xml" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Subscribe to the feed</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="/roadmap/" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          See the roadmap
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURED · floats under the hero, marquee for the latest
  ============================================================ -->
  <section class="-mt-36 md:-mt-44 pb-16 md:pb-24 z-10 relative">
    <div class="container-page max-w-5xl">
      <article class="rounded-[18px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden shadow-[0_30px_80px_-30px_rgba(2,132,199,0.35),0_10px_30px_-10px_rgba(15,23,42,0.18)]">
        <!-- Top bar: tag + date + permalink -->
        <div class="px-6 md:px-10 pt-6 md:pt-8 flex flex-wrap items-center gap-3">
          <span class={`inline-flex items-center gap-1.5 h-6 px-2 rounded-full text-[10.5px] font-semibold font-mono uppercase tracking-[0.12em] ${featuredStyle.chip}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${featuredStyle.dot}`}></span>
            {featured.tag}
          </span>
          <span class="text-[11.5px] font-mono uppercase tracking-[0.18em] text-muted-foreground">
            {featured.date}
          </span>
          <span class="text-[10px] uppercase tracking-[0.22em] font-mono text-[#0369a1] font-semibold ml-auto">
            Latest
          </span>
        </div>

        <!-- Grid: left = title + prose, right = visual / details -->
        <div class="grid lg:grid-cols-[1.25fr_1fr] gap-8 lg:gap-12 px-6 md:px-10 pt-5 pb-8 md:pb-10">
          <div>
            <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
              {featured.title}
            </h2>
            <p class="mt-5 text-[15.5px] text-foreground/75 leading-relaxed">{featured.body}</p>
            {featuredExtra.map((p) => (
              <p class="mt-3 text-[14.5px] text-foreground/70 leading-relaxed">{p}</p>
            ))}

            <div class="mt-7 flex flex-wrap items-center gap-3">
              <a href="/trust/" class="inline-flex h-10 px-4 items-center gap-2 rounded-[10px] text-[13.5px] font-semibold text-white bg-[#0369a1] hover:bg-[#075985] transition-colors">
                Read the trust notes
                <Icon name="arrowRight" size={12} />
              </a>
              <a href="/learn/encryption/" class="inline-flex h-10 px-4 items-center rounded-[10px] text-[13.5px] font-medium text-[#0369a1] hover:text-[#075985] ring-1 ring-[color:var(--border)] hover:ring-[#0284c7]/40 transition-colors">
                How the envelope works
              </a>
            </div>
          </div>

          <!-- Right side: terminal-style detail card grounded in the encryption model -->
          <div class="lg:pl-2">
            <div class="rounded-[12px] overflow-hidden ring-1 ring-[color:var(--border)] h-full bg-[#0c1224]">
              <div class="px-4 py-2.5 border-b border-white/10 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]/80"></span>
                </div>
                <span class="text-[10.5px] font-mono text-white/55 uppercase tracking-[0.14em]">envelope.sh</span>
              </div>
              <pre class="text-white/85 p-5 text-[12px] leading-[1.65] font-mono overflow-x-auto"><code><span style="color:#94a3b8"># 1. KMS issues a fresh 32-byte DEK</span>
<span style="color:#7dd3fc">dek</span> = <span style="color:#fde68a">kms</span>.GenerateDataKey(<span style="color:#a78bfa">cmk_id</span>, <span style="color:#a78bfa">AES_256</span>)

<span style="color:#94a3b8"># 2. Application seals with AES-GCM in memory</span>
<span style="color:#7dd3fc">ct</span> = <span style="color:#fde68a">aes_gcm</span>.Seal(<span style="color:#a78bfa">dek.plaintext</span>, <span style="color:#a78bfa">field</span>)

<span style="color:#94a3b8"># 3. Encrypted DEK persists in DynamoDB,</span>
<span style="color:#94a3b8">#    plaintext DEK only lives in Redis (TTL)</span>
<span style="color:#7dd3fc">store</span>(<span style="color:#a78bfa">user_id</span>, <span style="color:#fde68a">dek.ciphertext_b64</span>)
<span style="color:#7dd3fc">cache</span>(<span style="color:#a78bfa">user_id</span>, <span style="color:#fde68a">dek.plaintext</span>, <span style="color:#a78bfa">ttl=15m</span>)

<span style="color:#94a3b8"># 4. Self-host: swap to your CMK and re-wrap</span>
<span style="color:#f472b6">warmbly</span> kms rotate --to <span style="color:#fde68a">arn:aws:kms:...</span></code></pre>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============================================================
       COUNT STATS · 3-card strip (mirrors warmup numbers pattern)
  ============================================================ -->
  <section class="border-y border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-14 md:py-16">
    <div class="container-page">
      <div class="grid md:grid-cols-3 gap-px bg-[color:var(--border)] ring-1 ring-[color:var(--border)] rounded-[14px] overflow-hidden">
        <div class="bg-white p-7 md:p-8">
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">This month</div>
          <div class="mt-2 flex items-baseline gap-2">
            <span class="text-[44px] md:text-[52px] font-semibold tracking-[-0.035em] leading-none font-mono text-heading">{monthCount}</span>
            <span class="text-[12.5px] text-foreground/55">entries in May 2026</span>
          </div>
          <p class="mt-4 text-[13.5px] text-foreground/65 leading-relaxed">
            Active month for trust and infrastructure work. BYOK, SAML SSO, and a new API keys dashboard all landed within two weeks.
          </p>
        </div>
        <div class="bg-white p-7 md:p-8">
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">Year to date</div>
          <div class="mt-2 flex items-baseline gap-2">
            <span class="text-[44px] md:text-[52px] font-semibold tracking-[-0.035em] leading-none font-mono text-heading">{ytdCount}</span>
            <span class="text-[12.5px] text-foreground/55">entries in 2026</span>
          </div>
          <p class="mt-4 text-[13.5px] text-foreground/65 leading-relaxed">
            <span class="font-mono text-[#0369a1] font-semibold">{shippedCount}</span> shipped, <span class="font-mono text-amber-700 font-semibold">{changedCount}</span> changed, <span class="font-mono text-sky-700 font-semibold">{fixedCount}</span> fixed. Anything that altered platform behavior is logged here, including quiet defaults.
          </p>
        </div>
        <div class="bg-white p-7 md:p-8">
          <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-muted-foreground">Open source</div>
          <div class="mt-2 flex items-baseline gap-2">
            <span class="text-[44px] md:text-[52px] font-semibold tracking-[-0.035em] leading-none font-mono text-heading">{totalCount}</span>
            <span class="text-[12.5px] text-foreground/55">commits referenced</span>
          </div>
          <p class="mt-4 text-[13.5px] text-foreground/65 leading-relaxed">
            Every entry maps back to a public commit or migration in the warmbly/warmbly repository. The changelog is the source of truth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FILTERS + TIMELINE · editorial rows on hairlines
  ============================================================ -->
  <section class="py-20 md:py-24">
    <div class="container-page max-w-5xl">
      <div class="flex flex-wrap items-end justify-between gap-6 mb-10">
        <div>
          <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Timeline</div>
          <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.025em] leading-[1.06] text-heading">
            Every entry, in order.
          </h2>
        </div>

        <!-- Filter chips (visual; static for now) -->
        <div class="flex flex-wrap gap-1.5">
          <button type="button" class="inline-flex items-center gap-2 h-8 px-3 rounded-full text-[12px] font-medium bg-[#0369a1] text-white">
            All
            <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-mono bg-white/20">{totalCount}</span>
          </button>
          <button type="button" class="inline-flex items-center gap-2 h-8 px-3 rounded-full text-[12px] font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/75 hover:text-heading hover:ring-[#0284c7]/40">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Shipped
            <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-mono bg-emerald-50 text-emerald-700">{shippedCount}</span>
          </button>
          <button type="button" class="inline-flex items-center gap-2 h-8 px-3 rounded-full text-[12px] font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/75 hover:text-heading hover:ring-[#0284c7]/40">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            Changed
            <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-mono bg-amber-50 text-amber-700">{changedCount}</span>
          </button>
          <button type="button" class="inline-flex items-center gap-2 h-8 px-3 rounded-full text-[12px] font-medium bg-white ring-1 ring-[color:var(--border)] text-foreground/75 hover:text-heading hover:ring-[#0284c7]/40">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>
            Fixed
            <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-mono bg-sky-50 text-sky-700">{fixedCount}</span>
          </button>
        </div>
      </div>

      <!-- Editorial rows: date | tag | title + body -->
      <div class="border-t border-[color:var(--border)]">
        {restEntries.map((e) => {
          const t = tagStyle(e.tag);
          return (
            <article class="grid grid-cols-1 md:grid-cols-[120px_110px_1fr] gap-x-6 gap-y-2 py-6 border-b border-[color:var(--border)] items-baseline group hover:bg-[color:var(--surface-1)]/40 -mx-3 px-3 rounded-[6px] transition-colors">
              <div class="text-[11.5px] font-mono uppercase tracking-[0.18em] text-muted-foreground md:pt-1">
                {e.date}
              </div>
              <div class="md:pt-0.5">
                <span class={`inline-flex items-center gap-1.5 h-5 px-2 rounded-full text-[10.5px] font-semibold font-mono uppercase tracking-[0.1em] ${t.chip}`}>
                  <span class={`w-1 h-1 rounded-full ${t.dot}`}></span>
                  {e.tag}
                </span>
              </div>
              <div>
                <h3 class="text-[15.5px] md:text-[16.5px] font-semibold text-heading tracking-[-0.01em] group-hover:text-[#0369a1] transition-colors">
                  {e.title}
                </h3>
                <p class="mt-1.5 text-[13.5px] text-foreground/70 leading-relaxed max-w-3xl">{e.body}</p>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Footer note under the timeline -->
      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-[11.5px] font-mono text-muted-foreground">
        <span>Older than 90 days?</span>
        <a href="https://github.com/warmbly/warmbly/blob/main/CHANGELOG.md" class="text-[#0369a1] hover:text-[#075985]">CHANGELOG.md on GitHub</a>
        <span class="w-1 h-1 rounded-full bg-[color:var(--border)]"></span>
        <span>Every entry maps to a commit SHA.</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SUBSCRIBE · editorial split with feed URL + GitHub follow
  ============================================================ -->
  <section class="border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-20 md:py-24">
    <div class="container-page grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-20 items-start">
      <div class="lg:sticky lg:top-24" style="align-self: start;">
        <div class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-mono mb-3">Follow along</div>
        <h2 class="text-[28px] md:text-[40px] font-semibold tracking-[-0.025em] leading-[1.06] text-heading">
          Get the changelog<br/>in your reader.
        </h2>
        <p class="mt-4 text-[15px] text-foreground/70 leading-relaxed max-w-md">
          The feed updates within minutes of an entry going live. No email signup, no tracking pixels, no batching. Just a plain RSS feed and the public GitHub repository.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <!-- Feed card -->
        <a href="/changelog/feed.xml" class="group rounded-[14px] bg-white ring-1 ring-[color:var(--border)] p-6 hover:ring-[#0284c7]/40 hover:shadow-[0_18px_36px_-18px_rgba(2,132,199,0.3)] transition-all">
          <div class="flex items-center justify-between mb-5">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-[10px] bg-sky-50 text-[#0369a1] ring-1 ring-sky-100">
              <Icon name="bell" size={18} />
            </div>
            <Icon name="arrowUpRight" size={14} class="text-muted-foreground group-hover:text-[#0369a1] transition-colors" />
          </div>
          <div class="text-[16px] font-semibold text-heading tracking-[-0.01em]">RSS feed</div>
          <p class="mt-1.5 text-[13px] text-foreground/65 leading-relaxed">
            Subscribe in any RSS reader. Entries arrive in publication order, with the full body inline.
          </p>
          <div class="mt-4 inline-flex items-center gap-1.5 text-[11.5px] font-mono text-[#0369a1] bg-sky-50 px-2 py-1 rounded">
            /changelog/feed.xml
          </div>
        </a>

        <!-- GitHub card -->
        <a href="https://github.com/warmbly/warmbly" class="group rounded-[14px] bg-white ring-1 ring-[color:var(--border)] p-6 hover:ring-[#0284c7]/40 hover:shadow-[0_18px_36px_-18px_rgba(2,132,199,0.3)] transition-all">
          <div class="flex items-center justify-between mb-5">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-[10px] bg-foreground/5 text-foreground ring-1 ring-foreground/10">
              <Icon name="code" size={18} />
            </div>
            <Icon name="arrowUpRight" size={14} class="text-muted-foreground group-hover:text-[#0369a1] transition-colors" />
          </div>
          <div class="text-[16px] font-semibold text-heading tracking-[-0.01em]">Watch on GitHub</div>
          <p class="mt-1.5 text-[13px] text-foreground/65 leading-relaxed">
            Star the repository to get release notifications. Every changelog entry references a commit or migration.
          </p>
          <div class="mt-4 inline-flex items-center gap-1.5 text-[11.5px] font-mono text-foreground/75 bg-foreground/5 px-2 py-1 rounded">
            warmbly/warmbly
          </div>
        </a>

        <!-- Roadmap card -->
        <a href="/roadmap/" class="group rounded-[14px] bg-white ring-1 ring-[color:var(--border)] p-6 hover:ring-[#0284c7]/40 hover:shadow-[0_18px_36px_-18px_rgba(2,132,199,0.3)] transition-all">
          <div class="flex items-center justify-between mb-5">
            <div class="inline-flex items-center justify-center w-10 h-10 rounded-[10px] bg-amber-50 text-amber-700 ring-1 ring-amber-100">
              <Icon name="layers" size={18} />
            </div>
            <Icon name="arrowUpRight" size={14} class="text-muted-foreground group-hover:text-[#0369a1] transition-colors" />
          </div>
