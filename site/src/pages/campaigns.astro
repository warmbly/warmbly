---
import Layout from '../layouts/Layout.astro';
import HeroAtmosphere from '../components/HeroAtmosphere.astro';
import Icon from '../components/Icon.astro';
import CTA from '../components/CTA.astro';

// ===========================================================================
// Campaigns page. The centrepiece is a faithful, static recreation of the
// in-product sequence builder (web/src/components/app/campaigns/sequences):
// email-step cards with a sky header + "On reply" footer, IF/branch nodes with
// an "instant" badge, action nodes, stop nodes, and wait pills on the
// connectors. Numbers are real defaults from the codebase:
//   internal/config/constants.go      (50/day cap, 600s gap)
//   internal/scheduler/campaign_scheduler.go
//   web sequence builder              (wait_after 0..60 days, weight 1..100)
//
// Astro JSX caveat: never put a literal `<`, `>` or `{{ }}` inside a {}
// expression or in markup. Template tokens are written as {`{{.Field}}`}.
// ===========================================================================

// --- Step types legend -------------------------------------------------------
const stepTypes = [
  {
    icon: 'mail', name: 'Email step', tag: 'sends copy',
    badge: 'bg-sky-100 text-sky-600 ring-sky-200/70',
    desc: 'Sends one templated email. Holds the subject, the body, any A/B variants, and the wait before whatever comes next.',
  },
  {
    icon: 'gitBranch', name: 'Branch', tag: 'routes contacts',
    badge: 'bg-sky-100 text-sky-600 ring-sky-200/70',
    desc: 'Splits the path on a signal: opened, clicked, replied, or a share at random. Then and else can each point anywhere.',
  },
  {
    icon: 'shuffle', name: 'Action', tag: 'side effect',
    badge: 'bg-violet-100 text-violet-600 ring-violet-200/70',
    desc: 'No email. Add a tag, create a task or deal, move a CRM stage, notify a channel, or unsubscribe the contact.',
  },
  {
    icon: 'flag', name: 'Stop', tag: 'ends here',
    badge: 'bg-rose-100 text-rose-600 ring-rose-200/70',
    desc: 'Closes the sequence for that contact. Reached on a break-up step, a met goal, or an else with nowhere left to go.',
  },
];

// --- Branch routing signals --------------------------------------------------
const routing = [
  { sig: 'replied',    instant: true,  desc: 'The moment a reply lands. Usually pulls the contact off the rest of the sequence.' },
  { sig: 'opened',     instant: true,  desc: 'As the open returns, or after a set number of days if you would rather wait and decide.' },
  { sig: 'clicked',    instant: true,  desc: 'A click on any tracked link, instantly or inside a window you choose.' },
  { sig: 'not opened', instant: false, desc: 'No open inside the window. The classic break-up trigger.' },
  { sig: 'random %',   instant: false, desc: 'Send a share of contacts down a different path. A/B at the level of the whole flow.' },
  { sig: 'always',     instant: false, desc: 'An unconditional else. Everyone who reaches it takes this path.' },
];

// --- A/B variants ------------------------------------------------------------
const variants = [
  { name: 'Original',  weight: 60, subject: 'Quick question, {{.FirstName}}', original: true },
  { name: 'Variant B', weight: 25, subject: '{{.Company}} + a 20-minute look', original: false },
  { name: 'Variant C', weight: 15, subject: 'worth closing the loop?',         original: false },
];

// --- Sender pool -------------------------------------------------------------
const senderPool = [
  { addr: 'ben@acme.com',  role: 'AE',  cap: 50, today: 31 },
  { addr: 'sara@acme.com', role: 'AE',  cap: 50, today: 28 },
  { addr: 'mark@acme.com', role: 'BDR', cap: 50, today: 34 },
  { addr: 'kai@acme.com',  role: 'BDR', cap: 50, today: 26 },
];

// --- Auto-stop rules ---------------------------------------------------------
const autoStop = [
  ['Replied',         'The reply pulls the contact off the sequence the instant it lands. Everyone else keeps going.'],
  ['Goal met',        'A booked meeting or a won deal closes the sequence for that contact automatically.'],
  ['Hard bounce',     'The recipient is suppressed across the whole workspace. Nothing else ever queues to them.'],
  ['Unsubscribed',    'One-click unsubscribe, RFC 8058. Suppression applies before the confirmation page loads.'],
  ['Reply: STOP',     'Opt-out phrases in a reply are caught and suppressed without anyone in the loop.'],
  ['Manual suppress', 'An operator or an uploaded list suppresses the contact across every sequence at once.'],
];

// --- Limits / defaults -------------------------------------------------------
const limits = [
  { k: 'Wait between steps', v: '0 to 60 days', why: 'Set per step. Same-day follow-ups read as automation, so most steps sit a few business days apart.' },
  { k: 'Branch signals',     v: 'open · click · reply', why: 'Route on a real engagement signal, inside a window you set or the instant it happens.' },
  { k: 'A/B split',          v: 'weight 1 to 100', why: 'Add variants to any email step. Volume splits by weight and we track which one earns the reply.' },
  { k: 'Per-mailbox cap',    v: '50 / day', why: 'Default cold budget per mailbox. Raise it toward 100 once the mailbox has earned it.' },
  { k: 'Send spacing',       v: '600s minimum', why: 'At least ten minutes between two sends from the same mailbox. No bursts.' },
  { k: 'Business hours',     v: 'recipient TZ', why: 'Steps land inside the recipient working window, not the sender clock.' },
];

// --- Templating fields -------------------------------------------------------
const mergeFields = ['{{.FirstName}}', '{{.Company}}', '{{.Role}}', '{{.Trigger}}', '{{.City}}'];

// --- FAQ ---------------------------------------------------------------------
const faq = [
  ['Can a branch route on more than one signal?',
   'Each branch takes one path on one signal: opened, clicked, replied, or a random share. Chain branches to combine them. The then and else paths can each point at any step, an action, or a stop.'],
  ['What does "instant" mean on a branch?',
   'Reply, open and click can route the moment they happen instead of waiting for the next scheduled step. A reply can pull the contact off the sequence and notify the owner within seconds.'],
  ['How do A/B variants get chosen?',
   'Each contact is assigned a variant at the step by a stable weighted split, so a retry always lands on the same copy. We report which variant earned the reply.'],
  ['Where does a sequence actually send from?',
   'A pool of your mailboxes, not one. The scheduler round-robins across the pool under each mailbox cap, the 600s spacing rule, and its current health band, so no single mailbox carries the campaign.'],
  ['What stops a sequence for a contact?',
   'A reply, a met goal, a bounce, an unsubscribe, a STOP reply, or a manual suppression. Suppression is workspace-wide, so another sequence never picks the contact back up by accident.'],
];

const totalToday = senderPool.reduce((a, m) => a + m.today, 0);
const totalCap = senderPool.reduce((a, m) => a + m.cap, 0);
---
<Layout
  title="Cold Email Sequences & Campaign Builder | Warmbly"
  description="A visual builder for multi-step, branching sequences. Email steps, waits, branches that route on opens, clicks and replies, A/B variants, sent through a pool of mailboxes in the recipient time zone."
>
  <!-- ============================================================
       HERO · clean, with floating builder fragments (xl+)
  ============================================================ -->
  <section class="relative isolate overflow-hidden">
    <HeroAtmosphere />

    <!-- Floating fragments that tease the builder. xl and up only. -->
    <div class="hidden xl:block absolute inset-0 z-0 pointer-events-none select-none" aria-hidden="true">

      <!-- TOP-LEFT · a mini email step node, the start -->
      <div class="hero-float absolute top-[12%] left-[calc(50%_-_484px)] z-30" style="--drift:-10px;animation-duration:7.6s;animation-delay:-1.4s">
        <div class="rotate-[-2deg] w-[210px] rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_4px_-2px_rgba(2,32,71,0.25),0_18px_36px_-12px_rgba(2,32,71,0.5)] overflow-hidden">
          <div class="flex items-center gap-2 border-b border-slate-200/70 bg-gradient-to-r from-sky-50/80 to-white px-2.5 py-1.5">
            <span class="inline-flex size-5 items-center justify-center rounded-md bg-sky-100 text-sky-600 ring-1 ring-sky-200/70"><Icon name="mail" size={11} /></span>
            <span class="flex-1 truncate text-[12px] font-semibold text-slate-800">First touch</span>
            <span class="rounded bg-sky-600 px-1.5 py-px text-[8.5px] font-semibold uppercase tracking-[0.12em] text-white">Start</span>
          </div>
          <div class="px-2.5 py-1.5">
            <div class="text-[8.5px] font-semibold uppercase tracking-[0.14em] text-slate-300">Email</div>
            <div class="mt-0.5 truncate text-[11px] text-slate-500">Quick question, Maya</div>
          </div>
        </div>
      </div>

      <!-- TOP-RIGHT · an IF branch chip with instant badge (focal) -->
      <div class="hero-float absolute top-[14%] right-[calc(50%_-_470px)] z-30" style="--drift:-12px;animation-duration:7.2s;animation-delay:-2.1s">
        <div class="rotate-[2deg] inline-flex items-center gap-1.5 rounded-lg border border-sky-200 bg-gradient-to-b from-sky-50 to-white px-2.5 py-1.5 shadow-[0_2px_4px_-2px_rgba(2,32,71,0.25),0_16px_32px_-12px_rgba(2,32,71,0.5)]">
          <Icon name="gitBranch" size={12} class="text-sky-600" />
          <span class="text-[9px] font-semibold uppercase tracking-[0.14em] text-sky-500">if</span>
          <span class="text-[12px] font-medium text-sky-800">opened &ge; 1</span>
          <span class="inline-flex items-center gap-0.5 rounded bg-violet-50 px-1 py-px text-[8.5px] font-semibold uppercase tracking-[0.1em] text-violet-600 ring-1 ring-violet-200/70"><Icon name="zap" size={8} />instant</span>
        </div>
      </div>

      <!-- MID-RIGHT · a wait pill on a connector -->
      <div class="hero-float absolute top-[30%] right-[calc(50%_-_404px)] z-20" style="--drift:-7px;animation-duration:8.2s;animation-delay:-0.7s">
        <div class="rotate-[-2deg] inline-flex items-center gap-1.5 h-7 px-2.5 rounded-full bg-white/95 ring-1 ring-slate-900/5 shadow-[0_8px_20px_-10px_rgba(2,32,71,0.4)]">
          <Icon name="clock" size={12} class="text-slate-400" />
          <span class="font-mono text-[11px] font-semibold text-slate-700">wait 2 days</span>
        </div>
      </div>

      <!-- BOTTOM-LEFT · an action node fragment -->
      <div class="hero-float absolute top-[82%] left-[calc(50%_-_466px)] z-20" style="--drift:-9px;animation-duration:7.9s;animation-delay:-2.6s">
        <div class="rotate-[2deg] inline-flex items-center gap-2 rounded-[12px] bg-white ring-1 ring-slate-900/5 shadow-[0_2px_3px_-2px_rgba(2,32,71,0.2),0_14px_30px_-14px_rgba(2,32,71,0.45)] px-3 py-2">
          <span class="inline-flex size-5 items-center justify-center rounded-md bg-slate-100 ring-1 ring-slate-200/70"><Icon name="send" size={11} class="text-sky-600" /></span>
          <span class="text-[12px] font-semibold text-slate-800">Notify #ae-west</span>
        </div>
      </div>

      <!-- BOTTOM-RIGHT · a stop node fragment -->
      <div class="hero-float absolute top-[85%] right-[calc(50%_-_438px)] z-10" style="--drift:-8px;animation-duration:7.0s;animation-delay:-3.2s">
        <div class="rotate-[-2deg] inline-flex items-center gap-1.5 rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 shadow-[0_10px_24px_-12px_rgba(2,32,71,0.4)]">
          <Icon name="flag" size={11} class="text-rose-500" />
          <span class="text-[11.5px] font-medium text-rose-600">Ends here</span>
        </div>
      </div>

    </div>

    <div class="container-page relative z-10 pt-16 md:pt-24 pb-24 md:pb-32 text-center">
      <div class="inline-flex items-center gap-2 h-7 pl-1 pr-3 rounded-full bg-white/15 backdrop-blur ring-1 ring-white/25 text-[12px] text-white/95 shadow-[0_4px_14px_-4px_rgba(0,0,0,0.25)]">
        <span class="inline-flex items-center h-5 px-1.5 rounded-full text-[10.5px] font-semibold uppercase tracking-[0.06em] bg-white" style="color:#0369a1;">
          Campaigns
        </span>
        A visual builder for branching sequences
      </div>

      <h1 class="mt-8 md:mt-10 text-[44px] sm:text-6xl md:text-[72px] lg:text-[80px] font-semibold tracking-[-0.04em] leading-[0.98] text-white max-w-4xl mx-auto">
        Draw the whole sequence,<br/>branch by branch.
      </h1>
      <p class="mt-6 text-[17px] md:text-[19px] text-white/80 max-w-2xl mx-auto leading-relaxed">
        Email steps, waits, and branches that route every contact on what they actually do: opened, clicked, replied. Add A/B variants to any step, then send the whole thing through a pool of mailboxes in the recipient time zone.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="https://app.warmbly.com/register" class="inline-flex h-11 px-5 items-center gap-2 rounded-[10px] text-[14.5px] font-semibold bg-white hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-6px_rgba(0,0,0,0.3)] transition-all duration-200 ease-out shadow-[0_4px_14px_-2px_rgba(0,0,0,0.18)]">
          <span style="color:#075985;">Build your first sequence</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#075985" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="#builder" class="inline-flex h-11 px-5 items-center rounded-[10px] text-[14.5px] font-medium bg-white/10 backdrop-blur ring-1 ring-white/40 text-white hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ease-out">
          See the builder
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-float { animation-name: heroFloat; animation-timing-function: ease-in-out; animation-iteration-count: infinite; animation-direction: alternate; will-change: transform; }
    @keyframes heroFloat { from { transform: translateY(0); } to { transform: translateY(var(--drift, -10px)); } }
    @media (prefers-reduced-motion: reduce) { .hero-float { animation: none; } }
  </style>

  <!-- ============================================================
       THE BUILDER · faithful recreation of the sequence canvas
  ============================================================ -->
  <section id="builder" class="border-y border-[color:var(--border)] bg-[color:var(--surface-1)]/40 py-20 md:py-28 scroll-mt-4">
    <div class="container-page">
      <div class="max-w-2xl mb-10 md:mb-12">
        <div class="text-[11px] uppercase tracking-[0.18em] font-mono text-[#0284c7] mb-3">The builder</div>
        <h2 class="text-[32px] md:text-[44px] font-semibold tracking-[-0.03em] leading-[1.05] text-heading">
          The sequence is a map, not a list.
        </h2>
        <p class="mt-4 text-[15.5px] text-foreground/70 leading-relaxed">
          You lay the whole follow-up out on a canvas. Every email is a step, every gap is a wait you set in days, and a branch sends each contact down its own path the moment they open, click, or reply. This is the real builder, drawn out.
        </p>
      </div>

      <!-- Builder frame -->
      <div class="rounded-[16px] bg-white ring-1 ring-[color:var(--border)] overflow-hidden shadow-[0_40px_90px_-30px_rgba(2,32,71,0.32),0_12px_30px_-12px_rgba(15,23,42,0.1)]">

        <!-- Toolbar, mirrors the in-product top panel -->
        <div class="flex items-center justify-between gap-3 px-3 sm:px-4 py-2.5 border-b border-[color:var(--border)] bg-[color:var(--surface-1)]/70">
          <div class="flex items-center gap-1.5">
            <span class="inline-flex h-8 items-center gap-1.5 rounded-md bg-sky-600 px-3 text-[12px] font-medium text-white shadow-sm">
              <Icon name="zap" size={13} /> Add step
            </span>
            <span class="hidden sm:inline-flex h-8 items-center gap-1.5 rounded-md border border-slate-200 bg-white px-2.5 text-[12px] font-medium text-slate-700">
              <Icon name="shuffle" size={13} class="text-slate-400" /> Tidy up
            </span>
            <span class="inline-flex items-center gap-2 h-8 rounded-md border border-slate-200 bg-white px-2.5">
              <span class="text-[11.5px] text-slate-600">Stop on reply</span>
              <span class="relative inline-flex h-5 w-9 items-center rounded-full bg-sky-600">
                <span class="inline-block size-4 translate-x-4 rounded-full bg-white shadow-sm"></span>
              </span>
            </span>
          </div>
          <div class="hidden sm:flex items-center gap-1.5 font-mono text-[11px] text-muted-foreground">
            <span class="inline-flex size-6 items-center justify-center rounded border border-slate-200 bg-white text-slate-500">&minus;</span>
            <span class="tabular-nums">100%</span>
            <span class="inline-flex size-6 items-center justify-center rounded border border-slate-200 bg-white text-slate-500">+</span>
          </div>
        </div>

        <!-- Canvas -->
        <div class="builder-canvas relative px-4 sm:px-8 py-10 md:py-14">
          <div class="relative mx-auto max-w-[720px]">

            <!-- A · email step (start) -->
            <div class="flow-node mx-auto w-full sm:w-[280px]" style="--i:0">
              <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                <div class="flex items-center gap-2 rounded-t-xl border-b border-slate-200/70 bg-gradient-to-r from-sky-50/80 to-white px-3 py-2">
                  <span class="inline-flex size-6 items-center justify-center rounded-md bg-sky-100 text-sky-600 ring-1 ring-sky-200/70"><Icon name="mail" size={13} /></span>
                  <span class="flex-1 truncate text-[13px] font-semibold text-slate-800">First touch</span>
                  <span class="rounded bg-sky-600 px-1.5 py-px text-[9px] font-semibold uppercase tracking-[0.12em] text-white">Start</span>
                </div>
                <div class="px-3 py-2">
                  <div class="text-[9.5px] font-semibold uppercase tracking-[0.12em] text-slate-300">Email</div>
                  <div class="mt-0.5 truncate text-[12px] text-slate-500">{`Quick question, {{.FirstName}}`}</div>
                </div>
                <div class="flex items-center gap-1.5 border-t border-slate-200/70 px-3 py-1.5 text-[10.5px] font-medium text-violet-600">
                  <Icon name="zap" size={11} /> On reply
                </div>
              </div>
            </div>

            <!-- connector + wait -->
            <div class="flow-conn flow-node" style="--i:1">
              <span class="flow-line"></span>
              <span class="flow-wait"><Icon name="clock" size={12} class="text-slate-400" /> wait 2 days</span>
              <span class="flow-line"></span>
            </div>

            <!-- B · branch -->
            <div class="flow-node flex justify-center" style="--i:2">
              <div class="inline-flex items-center gap-1.5 rounded-lg border border-sky-200 bg-gradient-to-b from-sky-50 to-white px-2.5 py-1.5 shadow-sm">
                <Icon name="gitBranch" size={13} class="text-sky-600" />
                <span class="text-[9.5px] font-semibold uppercase tracking-[0.12em] text-sky-500">if</span>
                <span class="text-[12.5px] font-medium text-sky-800">opened &ge; 1?</span>
                <span class="inline-flex items-center gap-0.5 rounded bg-violet-50 px-1 py-px text-[8.5px] font-semibold uppercase tracking-[0.1em] text-violet-600 ring-1 ring-violet-200/70"><Icon name="zap" size={8} /> instant</span>
              </div>
            </div>

            <!-- split connector (sm+ flourish) -->
            <div class="flow-node hidden sm:flex justify-center" style="--i:3">
              <span class="flow-line h-5"></span>
            </div>

            <!-- two columns, each headed by its own branch label -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">

              <!-- THEN column -->
              <div class="flow-node" style="--i:4">
                <div class="flex flex-col items-center">
                  <span class="flow-branch flow-branch-then">then · opened</span>
                  <span class="flow-line h-4"></span>
                </div>
                <!-- C · email -->
                <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                  <div class="flex items-center gap-2 rounded-t-xl border-b border-slate-200/70 bg-gradient-to-r from-sky-50/80 to-white px-3 py-2">
                    <span class="inline-flex size-6 items-center justify-center rounded-md bg-sky-100 text-sky-600 ring-1 ring-sky-200/70"><Icon name="mail" size={13} /></span>
                    <span class="flex-1 truncate text-[13px] font-semibold text-slate-800">Case study nudge</span>
                  </div>
                  <div class="px-3 py-2">
                    <div class="text-[9.5px] font-semibold uppercase tracking-[0.12em] text-slate-300">Email</div>
                    <div class="mt-0.5 truncate text-[12px] text-slate-500">{`Saw {{.Company}} shipped {{.Trigger}}`}</div>
                  </div>
                  <div class="flex items-center gap-1.5 border-t border-slate-200/70 px-3 py-1.5 text-[10.5px] font-medium text-violet-600">
                    <Icon name="zap" size={11} /> On reply
                  </div>
                </div>

                <div class="flow-conn"><span class="flow-line"></span><span class="flow-wait"><Icon name="clock" size={12} class="text-slate-400" /> wait 3 days</span><span class="flow-line"></span></div>

                <!-- E · email -->
                <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                  <div class="flex items-center gap-2 rounded-t-xl border-b border-slate-200/70 bg-gradient-to-r from-sky-50/80 to-white px-3 py-2">
                    <span class="inline-flex size-6 items-center justify-center rounded-md bg-sky-100 text-sky-600 ring-1 ring-sky-200/70"><Icon name="mail" size={13} /></span>
                    <span class="flex-1 truncate text-[13px] font-semibold text-slate-800">Last call</span>
                  </div>
                  <div class="px-3 py-2">
                    <div class="text-[9.5px] font-semibold uppercase tracking-[0.12em] text-slate-300">Email</div>
                    <div class="mt-0.5 truncate text-[12px] text-slate-500">Should I close this out?</div>
                  </div>
                </div>

                <div class="flow-conn"><span class="flow-line"></span></div>

                <!-- F · stop -->
                <div class="flex justify-center">
                  <span class="inline-flex items-center gap-1.5 rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-[11.5px] font-medium text-rose-600">
                    <Icon name="flag" size={11} /> Ends here
                  </span>
                </div>
              </div>

              <!-- ELSE column -->
              <div class="flow-node" style="--i:5">
                <div class="flex flex-col items-center">
                  <span class="flow-branch flow-branch-else">else · no open · 4d</span>
                  <span class="flow-line h-4"></span>
                </div>
                <!-- D · action -->
                <div class="rounded-xl border border-slate-200 bg-white shadow-sm">
                  <div class="flex items-center gap-2 rounded-t-xl border-b border-slate-200/70 bg-gradient-to-r from-slate-50 to-white px-3 py-2">
                    <span class="inline-flex size-6 items-center justify-center rounded-md bg-slate-100 ring-1 ring-slate-200/70"><Icon name="shuffle" size={12} class="text-sky-600" /></span>
                    <span class="flex-1 truncate text-[13px] font-semibold text-slate-800">Move deal stage</span>
                  </div>
                  <div class="px-3 py-2">
                    <div class="text-[9.5px] font-semibold uppercase tracking-[0.12em] text-slate-300">Action</div>
                    <div class="mt-0.5 truncate text-[12px] text-slate-500">HubSpot &middot; to Nurture</div>
                  </div>
                </div>

                <div class="flow-conn"><span class="flow-line"></span></div>

                <!-- G · stop -->
                <div class="flex justify-center">
                  <span class="inline-flex items-center gap-1.5 rounded-md border border-rose-200 bg-rose-50 px-3 py-1.5 text-[11.5px] font-medium text-rose-600">
                    <Icon name="flag" size={11} /> Ends here
                  </span>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- footer strip -->
        <div class="px-4 sm:px-7 py-3 border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/60 flex flex-wrap items-center justify-between gap-2 text-[11.5px] font-mono text-muted-foreground">
          <span>4 steps &middot; 1 branch &middot; 1 action</span>
