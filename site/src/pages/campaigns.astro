  <!-- Builder canvas styling: dot grid, connectors, wait + branch pills,
       and a gentle staggered reveal on the nodes. -->
  <style>
    .builder-canvas {
      background-image: radial-gradient(circle, #e2e9f3 1px, transparent 1px);
      background-size: 22px 22px;
      background-position: -1px -1px;
    }
    .flow-conn { display: flex; flex-direction: column; align-items: center; }
    .flow-line { width: 1.5px; height: 1rem; background: var(--border-strong); }
    .flow-wait {
      display: inline-flex; align-items: center; gap: 0.35rem;
      height: 1.6rem; padding-inline: 0.6rem; margin-block: 0.15rem;
      border-radius: 9999px; background: #fff;
      border: 1px solid var(--border);
      font-family: ui-monospace, monospace; font-size: 11px; color: #475569;
      box-shadow: 0 4px 10px -6px rgba(15,23,42,0.25);
    }
    .flow-branch {
      display: inline-flex; align-items: center;
      height: 1.25rem; padding-inline: 0.45rem;
      border-radius: 0.3rem;
      font-family: ui-monospace, monospace; font-size: 10px;
      text-transform: uppercase; letter-spacing: 0.08em;
    }
    .flow-branch-then { background: #f0f9ff; color: #0369a1; box-shadow: inset 0 0 0 1px #bae6fd; }
    .flow-branch-else { background: #f1f5f9; color: #475569; box-shadow: inset 0 0 0 1px #e2e8f0; }

    .flow-node { animation: flowReveal 0.5s cubic-bezier(0.22, 1, 0.36, 1) both; animation-delay: calc(var(--i, 0) * 90ms); }
    @keyframes flowReveal { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) {
