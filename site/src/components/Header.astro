---
import Wordmark from './Wordmark.astro';
import Icon from './Icon.astro';

interface Props {
  /** Render as transparent over the sky hero, with light text. Becomes solid once scrolled past the hero. */
  onSky?: boolean;
}
const { onSky = false } = Astro.props;

const path = Astro.url.pathname;

// Product mega-menu items (6 meaningful products)
const products = [
  { icon: 'flame',    href: '/warmup/',    title: 'Warmup',         desc: 'Reputation-safe pools and gradual ramps that earn placement, not just inflate it.', tag: 'Deliverability' },
  { icon: 'webhook',  href: '/developers/', title: 'API & webhooks', desc: 'REST + HMAC-signed webhooks. Idempotency keys. Per-key scopes.',                     tag: 'Developers' },
  { icon: 'inbox',    href: '/inbox/',     title: 'Unified inbox',  desc: 'Every reply, bounce, OOO and click across every connected mailbox, classified.',     tag: 'Triage' },
  { icon: 'workflow', href: '/campaigns/', title: 'Campaigns',      desc: 'Multi-step sequences with branching, A/B variants and business-hour scheduling.',    tag: 'Outreach' },
  { icon: 'chart',    href: '/analytics/', title: 'Analytics',      desc: 'Placement, complaints, bounces and warmup health, by mailbox and by worker.',        tag: 'Reporting' },
  { icon: 'contact',  href: '/crm/',       title: 'CRM',            desc: 'Pipelines, deals, tasks and a contacts table built around cold-outbound workflow.',  tag: 'Workflow' },
];

// Use cases mega-menu items
const useCases = [
  { icon: 'rocket',  href: '/use-cases/founders/',    title: 'Founders',    desc: 'Run intro sequences without burning founder@.',     tag: 'Solo + early' },
  { icon: 'users',   href: '/use-cases/agencies/',    title: 'Agencies',    desc: 'Outbound for many clients on many domains.',       tag: 'Multi-tenant' },
  { icon: 'chart',   href: '/use-cases/sales/',       title: 'Sales teams', desc: 'Distribute sends across reps, surface positives.', tag: 'Growth' },
  { icon: 'contact', href: '/use-cases/recruiters/',  title: 'Recruiters',  desc: 'Candidate outreach from personal mailboxes.',      tag: 'Talent' },
  { icon: 'star',    href: '/use-cases/fundraising/', title: 'Fundraising', desc: 'A focused VC sequence that lands in the inbox.',   tag: 'Founders' },
];

type MegaItem = { icon: string; href: string; title: string; desc: string; tag: string };
type NavItem = {
  label: string;
  href: string;
  match?: string;
  mega?: boolean;
  megaTitle?: string;
  megaTagline?: string;
  megaItems?: MegaItem[];
};

const nav: NavItem[] = [
  {
    label: 'Product',
    href: '/warmup/',
    match: '/warmup|/developers|/inbox|/campaigns|/analytics|/crm',
    mega: true,
    megaTitle: 'The cold-email platform.',
    megaTagline: 'Six systems designed to work together. Warmup that earns reputation, sending that respects it.',
    megaItems: products,
  },
  {
    label: 'Use cases',
    href: '/use-cases/founders/',
    match: '/use-cases',
    mega: true,
    megaTitle: 'Who uses Warmbly.',
    megaTagline: 'Founders, agencies, sales teams, recruiters, fundraising. Pick the closest one.',
    megaItems: useCases,
  },
  { label: 'Deliverability',href: '/deliverability/',match: '/deliverability' },
  { label: 'Pricing',       href: '/pricing/',       match: '/pricing' },
  { label: 'Learn',         href: '/learn/',         match: '/learn' },
];

function active(match?: string) {
  if (!match) return false;
  // Support pipe-delimited multi-match for the Product mega item
  const parts = match.split('|');
  return parts.some((m) => path === m || path.startsWith(m + '/'));
}
---
<header
  id="site-header"
  data-on-sky={onSky ? 'true' : 'false'}
  class={[
    'sticky top-0 z-50 transition-colors duration-200',
    onSky ? 'header-on-sky' : 'border-b border-border/70 bg-background/70 backdrop-blur-md supports-[backdrop-filter]:bg-background/55',
  ].join(' ')}
>
  <div class="container-page flex h-14 items-center gap-6">
    <Wordmark size="md" />

    <nav class="hidden md:flex items-center gap-1 ml-2 relative">
      {nav.map((n) => (
        n.mega ? (
          <div class="mega-wrapper relative" data-mega>
            <a
              href={n.href}
              class={
                'nav-link h-8 px-3 inline-flex items-center gap-1 rounded-md text-[13px] transition-colors ' +
                (active(n.match)
                  ? (onSky ? 'is-active' : 'text-foreground bg-surface-2')
                  : (onSky ? '' : 'text-muted-foreground hover:text-foreground hover:bg-surface-2/60'))
              }
            >
              {n.label}
              <svg width="9" height="9" viewBox="0 0 12 12" fill="none" class="mega-caret transition-transform duration-200" aria-hidden="true">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <!-- Mega-menu · full-bleed panel, container-width inner content -->
            <div class="mega-panel pointer-events-none opacity-0 transition-opacity duration-200 ease-out" style="position: fixed; top: 56px; left: 0; right: 0;">
              <!-- Full-bleed chrome: spans the entire viewport -->
              <div class="bg-white border-b border-[color:var(--border)]" style="box-shadow: 0 40px 90px -30px rgba(2,32,71,0.3), 0 12px 36px -10px rgba(15,23,42,0.08);">
                <!-- Body: container-width content -->
                <div class="container-page">
                  <div class="grid lg:grid-cols-[300px_1fr]">
                    <!-- LEFT: clean white intro block -->
                    <div class="py-10 pr-10 border-b lg:border-b-0 lg:border-r border-[color:var(--border)]">
                      <div class="text-[10.5px] uppercase tracking-[0.22em] font-mono text-foreground/55">{n.label}</div>
                      <h3 class="mt-4 text-[32px] md:text-[40px] font-semibold tracking-[-0.03em] leading-[1.02] text-heading">
                        {n.megaTitle}
                      </h3>
                      <p class="mt-4 text-[14px] text-foreground/65 leading-relaxed max-w-xs">
                        {n.megaTagline}
                      </p>
                      <a href="/learn/deliverability/" class="mt-6 inline-flex items-center gap-1.5 text-[12.5px] font-medium text-[#0369a1] hover:text-[#075985]">
                        Read the handbook
                        <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </a>
                    </div>

                    <!-- RIGHT: 3-column product grid -->
                    <div class="grid grid-cols-2 lg:grid-cols-3">
                      {(n.megaItems ?? []).map((it, i) => {
                        const isCurrent = path === it.href || path.startsWith(it.href);
                        const colBreak = (i + 1) % 3 !== 0;
                        const rowBreak = i < 3;
                        return (
                          <a
                            href={it.href}
                            aria-current={isCurrent ? 'page' : undefined}
                            style={`--stagger: ${i * 35}ms; transition: background-color 140ms ease-out;`}
                            class={`mega-card group flex flex-col p-7 ${colBreak ? 'lg:border-r border-[color:var(--border)]' : ''} ${rowBreak ? 'border-b border-[color:var(--border)]' : ''} ${isCurrent ? 'bg-[color:var(--sky-1)]/60' : 'hover:bg-[color:var(--surface-1)]'}`}
                          >
                            <div class="text-[10px] uppercase tracking-[0.22em] font-mono text-foreground/45 mb-3">{it.tag}</div>
                            <div class={`text-[18px] font-semibold tracking-[-0.015em] flex items-center gap-2 ${isCurrent ? 'text-[#0369a1]' : 'text-heading group-hover:text-[#0369a1]'}`} style="transition: color 140ms ease-out;">
                              {it.title}
                              {isCurrent && <span class="w-1.5 h-1.5 rounded-full bg-[#0284c7]"></span>}
                            </div>
                            <p class="mt-2 text-[13px] text-foreground/60 leading-relaxed flex-1">{it.desc.split('.')[0]}.</p>
                            <div class="mt-5 inline-flex items-center gap-1 text-[11.5px] font-medium text-foreground/45 group-hover:text-[#0369a1]" style="transition: color 140ms ease-out;">
                              Open
                              <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3.5 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </div>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                </div>

                <!-- Footer band: full-bleed, container-width content -->
                <div class="border-t border-[color:var(--border)] bg-[color:var(--surface-1)]/60">
                  <div class="container-page py-3 flex items-center justify-between text-[11.5px] font-mono">
                    <a href="https://github.com/warmbly/warmbly" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-foreground/65 hover:text-foreground transition-colors">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.9.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.5 4.6-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
                      github.com/warmbly/warmbly
                    </a>
                    <div class="flex items-center gap-5 text-foreground/55">
                      <a href="/deliverability/" class="hover:text-foreground transition-colors">Deliverability</a>
                      <a href="/integrations/" class="hover:text-foreground transition-colors">Integrations</a>
                      <a href="/learn/" class="hover:text-foreground transition-colors">Learn</a>
                      <a href="/pricing/" class="hover:text-foreground transition-colors font-semibold text-[#0369a1]">See pricing →</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <a
            href={n.href}
            class={
              'nav-link h-8 px-3 inline-flex items-center rounded-md text-[13px] transition-colors ' +
              (active(n.match)
                ? (onSky ? 'is-active' : 'text-foreground bg-surface-2')
                : (onSky ? '' : 'text-muted-foreground hover:text-foreground hover:bg-surface-2/60'))
            }
          >
            {n.label}
          </a>
        )
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a
        href="https://app.warmbly.com/login"
        class={
          'cta-ghost hidden sm:inline-flex h-8 px-3 items-center rounded-md text-[13px] transition-colors ' +
          (onSky ? '' : 'text-muted-foreground hover:text-foreground hover:bg-surface-2')
        }
      >
        Log in
      </a>
      <a
        href="https://app.warmbly.com/register"
        class={
          'cta-primary inline-flex h-8 px-3.5 items-center rounded-md text-[13px] font-medium transition-colors ' +
          (onSky ? '' : 'bg-foreground text-background hover:bg-foreground/85')
        }
      >
        Start free
      </a>
      <button
        id="nav-toggle"
        class={
          'md:hidden inline-flex h-8 w-8 items-center justify-center rounded-md ' +
          (onSky ? 'cta-ghost' : 'text-muted-foreground hover:text-foreground hover:bg-surface-2')
        }
        aria-label="Toggle navigation"
        aria-expanded="false"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-background">
    <div class="container-page py-3 grid gap-1">
      {nav.map((n) => (
        <a
          href={n.href}
          class={
            'h-9 px-2 inline-flex items-center rounded-md text-sm ' +
            (active(n.match)
              ? 'text-foreground bg-surface-2'
              : 'text-muted-foreground hover:text-foreground hover:bg-surface-2/60')
          }
        >
          {n.label}
        </a>
      ))}
      <div class="h-px bg-border my-2" />
      <a href="https://app.warmbly.com/login" class="h-9 px-2 inline-flex items-center rounded-md text-sm text-muted-foreground hover:text-foreground hover:bg-surface-2">Log in</a>
      <a href="https://app.warmbly.com/register" class="h-9 px-2 inline-flex items-center rounded-md text-sm font-medium text-background bg-foreground">Start free</a>
    </div>
  </div>
</header>

<style>
  /* Mega panel: only fade opacity to keep bounds stable while open */
  .mega-panel.open {
    opacity: 1;
    pointer-events: auto;
  }
  /* Invisible hover-bridge above the panel so cursor can travel
     from the trigger without crossing a dead gap. */
  .mega-panel.open::before {
    content: '';
    position: absolute;
    top: -24px;
    left: 0;
    right: 0;
    height: 24px;
  }
  .mega-wrapper.open .mega-caret { transform: rotate(180deg); }
</style>

<script is:inline>
  (function () {
    // Mobile nav toggle
    var toggle = document.getElementById('nav-toggle');
    var menu = document.getElementById('mobile-nav');
    if (toggle) {
      toggle.addEventListener('click', function () {
        var open = menu && menu.classList.toggle('hidden') === false;
        toggle.setAttribute('aria-expanded', String(!!open));
      });
    }

    // Mega-menu — hover state driven by hit-testing the cursor against
    // both the trigger and the panel. Avoids the fixed-positioning
    // mouseleave quirks that caused the panel to flicker shut as soon
    // as the cursor entered it.
    var wrappers = Array.prototype.slice.call(document.querySelectorAll('[data-mega]'));
    var bag = [];
    wrappers.forEach(function (wrapper) {
      var panel = wrapper.querySelector('.mega-panel');
      if (!panel) return;

      var entry = {
        wrapper: wrapper,
        panel: panel,
        closeTimer: null,
        moveHandler: null,
        isOpen: false,
        forceClose: null,
      };

      function insideRect(x, y, el, padTop) {
        if (!el) return false;
        var r = el.getBoundingClientRect();
        var top = r.top - (padTop || 0);
        return x >= r.left && x <= r.right && y >= top && y <= r.bottom;
      }
      // The panel hit-area extends 40px above its top so the gap between
      // the trigger and the fixed panel acts as an invisible bridge.
      function inside(x, y, el) {
        return el === panel ? insideRect(x, y, el, 40) : insideRect(x, y, el, 0);
      }

      function detachMoveHandler() {
        if (entry.moveHandler) {
          document.removeEventListener('mousemove', entry.moveHandler);
          entry.moveHandler = null;
        }
      }

      function forceClose() {
        if (entry.closeTimer) { clearTimeout(entry.closeTimer); entry.closeTimer = null; }
        detachMoveHandler();
        entry.isOpen = false;
        wrapper.classList.remove('open');
        panel.classList.remove('open');
      }
      entry.forceClose = forceClose;

      function open() {
        // Synchronously close any other mega panel so only one is ever visible.
        for (var i = 0; i < bag.length; i++) {
          if (bag[i] !== entry) bag[i].forceClose();
        }
        if (entry.closeTimer) { clearTimeout(entry.closeTimer); entry.closeTimer = null; }
        if (entry.isOpen) return;
        entry.isOpen = true;
        wrapper.classList.add('open');
        panel.classList.add('open');
        // Stagger-animate cards on each open
        var cards = panel.querySelectorAll('.mega-card');
        cards.forEach(function (c, i) {
          c.style.opacity = '0';
          c.style.transform = 'translateY(6px)';
          c.style.transition = 'none';
          setTimeout(function () {
            c.style.transition = 'opacity 220ms ease-out, transform 280ms cubic-bezier(0.22,1,0.36,1), background-color 140ms ease-out';
            c.style.opacity = '1';
            c.style.transform = 'translateY(0)';
          }, 40 + i * 32);
        });
        // Track cursor globally so we know when to close
        if (!entry.moveHandler) {
          entry.moveHandler = function (e) {
            if (entry.closeTimer) return; // already scheduled
            if (!inside(e.clientX, e.clientY, wrapper) && !inside(e.clientX, e.clientY, panel)) {
              scheduleClose();
            }
          };
          document.addEventListener('mousemove', entry.moveHandler);
        }
      }
      function scheduleClose() {
        if (entry.closeTimer) clearTimeout(entry.closeTimer);
        entry.closeTimer = setTimeout(function () {
          entry.isOpen = false;
          wrapper.classList.remove('open');
          panel.classList.remove('open');
          detachMoveHandler();
        }, 180);
      }
      function cancelClose() {
        if (entry.closeTimer) { clearTimeout(entry.closeTimer); entry.closeTimer = null; }
      }

      wrapper.addEventListener('mouseenter', open);
      panel.addEventListener('mouseenter', cancelClose);

      // Keyboard support
      wrapper.addEventListener('focusin', open);
      wrapper.addEventListener('focusout', function (e) {
        if (!wrapper.contains(e.relatedTarget)) scheduleClose();
      });

      bag.push(entry);
    });

    // Close on Escape (global, all panels)
    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Escape') return;
      bag.forEach(function (entry) { entry.forceClose(); });
    });

    // Hovering any non-mega nav item instantly closes any open mega panel.
    // Picks up the desktop nav links that are not inside a [data-mega] wrapper.
    var siblingNavLinks = document.querySelectorAll('#site-header nav .nav-link');
    siblingNavLinks.forEach(function (link) {
      if (link.closest('[data-mega]')) return;
      link.addEventListener('mouseenter', function () {
        bag.forEach(function (entry) { entry.forceClose(); });
      });
    });

    // If the header is rendered "on sky", flip it to solid once the hero's
    // bottom sentinel scrolls past the header.
    var header = document.getElementById('site-header');
    if (header && header.dataset.onSky === 'true') {
      var sentinel = document.getElementById('hero-sentinel');
      if (sentinel) {
        var io = new IntersectionObserver(function (entries) {
          var entry = entries[0];
          if (entry.isIntersecting) {
            header.classList.add('header-on-sky');
            header.classList.remove('border-b', 'border-border/70', 'bg-background/70', 'backdrop-blur-md');
          } else {
            header.classList.remove('header-on-sky');
            header.classList.add('border-b', 'border-border/70', 'bg-background/70', 'backdrop-blur-md');
          }
        }, { rootMargin: '-56px 0px 0px 0px', threshold: 0 });
        io.observe(sentinel);
      }
    }
  })();
</script>
