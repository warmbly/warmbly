{
    "url": "/unibox",
    "method": "GET",
    "qs": {
        "limit": 100
    },
    "response": {
        "iterate": "{{body.data}}",
        "trigger": {
            "id": "{{item.id}}",
            "date": "{{item.internal_date}}",
            "type": "id",
            "order": "desc"
        },
        "output": "{{item}}"
    }
}
