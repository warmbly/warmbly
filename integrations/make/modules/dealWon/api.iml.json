{
    "url": "/crm/deals",
    "method": "GET",
    "qs": {
        "limit": 100,
        "status": "won"
    },
    "response": {
        "iterate": "{{body.data}}",
        "trigger": {
            "id": "{{item.id}}",
            "date": "{{item.created_at}}",
            "type": "id",
            "order": "desc"
        },
        "output": "{{item}}"
    }
}
