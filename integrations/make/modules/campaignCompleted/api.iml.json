{
    "url": "/campaigns",
    "method": "GET",
    "qs": {
        "limit": 100
    },
    "response": {
        "iterate": "{{filterByStatus(body.data, 'completed')}}",
        "trigger": {
            "id": "{{item.id}}",
            "date": "{{item.created_at}}",
            "type": "id",
            "order": "desc"
        },
        "output": "{{item}}"
    }
}
